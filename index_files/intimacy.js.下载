function parsePlaySheet(rawSheet) {
    const displayArea = document.getElementById('play-sheet-display');
    displayArea.innerHTML = '';
    displayArea.style.position = 'relative';
    displayArea.style.height = '60px'; // 给一个固定高度容纳单行
    
    playParsedMelody = [];
    const lines = rawSheet.split('\n');
    lines.forEach((line, lineIndex) => {
        const lineDiv = document.createElement('div');
        lineDiv.className = 'play-sheet-line';
        if (lineIndex === 0) lineDiv.classList.add('active'); // 默认显示第一行
        
        for (let char of line) {
            if (/[1-7]/.test(char)) {
                const span = document.createElement('span');
                span.className = 'play-sheet-note';
                span.innerText = char;
                span.dataset.index = playParsedMelody.length; 
                lineDiv.appendChild(span);
                playParsedMelody.push(playNoteMapping[char]); 
            } else {
                const span = document.createElement('span');
                span.innerText = char;
                lineDiv.appendChild(span);
            }
        }
        displayArea.appendChild(lineDiv);
    });
}

let playDropStep = 0; // 用于记录节奏模式下落到第几个音符

function showPlayHitEffect(type) {
    const area = document.getElementById('play-falling-area');
    const text = document.createElement('div');
    text.className = `play-hit-text ${type}`;
    text.innerText = type === 'perfect' ? 'Perfect!' : 'Miss';
    area.appendChild(text);
    setTimeout(() => text.remove(), 500);
}

function startPlayPiano(mode) {
    initPlayAudio(); 
    closePlayDetailModal();
    document.getElementById('play-piano-song-title').innerText = document.getElementById('play-detail-title').innerText;
    
    parsePlaySheet(currentPlayRawSheet);
    document.querySelectorAll('.play-page').forEach(p => p.classList.remove('active'));
    document.getElementById('play-page-piano').classList.add('active');
    
    clearInterval(playPianoInterval);
    playCurrentStep = 0;
    playDropStep = 0;
    playCurrentScore = 0;
    
    const scoreDisplay = document.getElementById('play-piano-score-display');
    const isRhythm = (currentPlayModeSetting === 'rhythm');
    const sheetDisplay = document.getElementById('play-sheet-display');
    const fallingArea = document.getElementById('play-falling-area');
    const staffSvg = document.querySelector('.play-staff-svg');
    
    // 根据模式切换 UI
    if (isRhythm) {
        sheetDisplay.style.display = 'none';
        staffSvg.style.opacity = '0.2';
        fallingArea.style.display = 'block';
        // 保留判定线，清空其他音符
        Array.from(fallingArea.children).forEach(child => {
            if (child.id !== 'play-hit-line') child.remove();
        });
    } else {
        sheetDisplay.style.display = 'block';
        staffSvg.style.opacity = '1';
        fallingArea.style.display = 'none';
    }
    
    const keys = document.querySelectorAll('.play-key-white, .play-key-black');
    keys.forEach(key => {
        key.onclick = () => {
            const noteIndex = parseInt(key.getAttribute('data-note'));
            activatePlayKey(noteIndex, key);
            
            if (playIsManualMode) {
                if (isRhythm) {
                    // 节奏大师模式：严格判定
                    // 查找当前轨道上处于判定区间 (hittable) 的音符
                    const hittableNote = Array.from(fallingArea.querySelectorAll('.play-falling-note')).find(n => 
                        n.dataset.noteIndex == noteIndex && n.dataset.hittable === 'true'
                    );
                    
                    if (hittableNote) {
                        // 击中
                        hittableNote.remove();
                        playCurrentScore += 10;
                        scoreDisplay.innerText = `得分: ${playCurrentScore}`;
                        showPlayHitEffect('perfect');
                        playCurrentStep++;
                    } else {
                        // 没击中或按错
                        showPlayHitEffect('miss');
                    }
                    
                    if (playCurrentStep >= playParsedMelody.length) {
                        document.getElementById('play-ta-hint').innerText = '挑战结束！';
                        document.getElementById('play-ta-hint').style.display = 'block';
                    }
                } else {
                    // 古典模式：宽松判定
                    if (playCurrentStep < playParsedMelody.length && noteIndex === playParsedMelody[playCurrentStep]) {
                        playCurrentStep++;
                        playCurrentScore += 10;
                        scoreDisplay.innerText = `得分: ${playCurrentScore}`;
                        highlightPlaySheetNote(playCurrentStep);
                        
                        if (playCurrentStep >= playParsedMelody.length) {
                            document.getElementById('play-ta-hint').innerText = '挑战成功！';
                            document.getElementById('play-ta-hint').style.display = 'block';
                        }
                    }
                }
            }
        };
    });

    if (mode === 'auto') {
        playIsManualMode = false;
        scoreDisplay.style.display = 'none';
        document.getElementById('play-ta-hint').innerText = 'TA 正在弹奏';
        document.getElementById('play-ta-hint').style.display = 'block';
        
        playPianoInterval = setInterval(() => {
            if (playCurrentStep >= playParsedMelody.length) {
                clearInterval(playPianoInterval);
                document.getElementById('play-ta-hint').innerText = '演奏结束';
                return;
            }
            const noteIndex = playParsedMelody[playCurrentStep];
            const keyEl = document.querySelector(`[data-note="${noteIndex}"]`);
            
            if (isRhythm) {
                createFallingNote(noteIndex, keyEl, true);
            } else {
                if (keyEl) activatePlayKey(noteIndex, keyEl);
                highlightPlaySheetNote(playCurrentStep);
            }
            playCurrentStep++;
        }, 600);
    } else {
        playIsManualMode = true;
        scoreDisplay.style.display = 'block';
        scoreDisplay.innerText = `得分: 0`;
        document.getElementById('play-ta-hint').style.display = 'none';
        
        if (isRhythm) {
            // 节奏模式手动：按节奏掉落音符，等待用户点击
            playPianoInterval = setInterval(() => {
                if (playDropStep >= playParsedMelody.length) {
                    clearInterval(playPianoInterval);
                    return;
                }
                const noteIndex = playParsedMelody[playDropStep];
                const keyEl = document.querySelector(`[data-note="${noteIndex}"]`);
                createFallingNote(noteIndex, keyEl, false);
                playDropStep++;
            }, 800);
        } else {
            highlightPlaySheetNote(playCurrentStep);
        }
    }
}

