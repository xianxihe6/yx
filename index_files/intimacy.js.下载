function handleIntimacyInviteAction(isAccept) {
    if (currentIntimacyInviteMsgIndex === null) return;

    const currentLoginId = ChatDB.getItem('current_login_account');
    let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    const msg = history[currentIntimacyInviteMsgIndex];

    if (!msg) return;

    if (isAccept) {
        if (msg.subType === 'lover') {
            const myLover = ChatDB.getItem(`intimacy_lover_${currentLoginId}`);
            const taLover = ChatDB.getItem(`intimacy_lover_${currentChatRoomCharId}`);
            if (myLover) {
                alert('你已经绑定了恋人，无法接受新的邀请！\n请先解除原有的恋人关系。');
                return; 
            }
            if (taLover) {
                alert('对方已经绑定了恋人，无法接受邀请！');
                return; 
            }
        }

        msg.status = 'accepted';
        ChatDB.setItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(history));

        let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`) || '[]');
        let targetMsgIndex = targetHistory.findIndex(m => m.type === 'intimacy_invite' && m.timestamp === msg.timestamp);
        if (targetMsgIndex !== -1) {
            targetHistory[targetMsgIndex].status = 'accepted';
            ChatDB.setItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`, JSON.stringify(targetHistory));
        }

        if (msg.subType === 'lover') {
            ChatDB.setItem(`intimacy_lover_${currentLoginId}`, JSON.stringify({ charId: currentChatRoomCharId, bindTime: Date.now() }));
            ChatDB.setItem(`intimacy_lover_${currentChatRoomCharId}`, JSON.stringify({ charId: currentLoginId, bindTime: Date.now() }));
        } else {
            let members = JSON.parse(ChatDB.getItem(`intimacy_members_${currentLoginId}_${msg.groupName}`) || '[]');
            if (!members.includes(currentChatRoomCharId)) {
                members.push(currentChatRoomCharId);
                ChatDB.setItem(`intimacy_members_${currentLoginId}_${msg.groupName}`, JSON.stringify(members));
            }
            let targetMembers = JSON.parse(ChatDB.getItem(`intimacy_members_${currentChatRoomCharId}_${msg.groupName}`) || '[]');
            if (!targetMembers.includes(currentLoginId)) {
                targetMembers.push(currentLoginId);
                ChatDB.setItem(`intimacy_members_${currentChatRoomCharId}_${msg.groupName}`, JSON.stringify(targetMembers));
            }
        }
        alert('已同意邀请！');
    } else {
        msg.status = 'rejected';
        ChatDB.setItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(history));

        let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`) || '[]');
        let targetMsgIndex = targetHistory.findIndex(m => m.type === 'intimacy_invite' && m.timestamp === msg.timestamp);
        if (targetMsgIndex !== -1) {
            targetHistory[targetMsgIndex].status = 'rejected';
            ChatDB.setItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`, JSON.stringify(targetHistory));
        }
        alert('已婉拒邀请。');
    }

    renderChatHistory(currentChatRoomCharId);
    closeIntimacyNormalInviteModal();
    closeIntimacyLoverLetterModal();
}
