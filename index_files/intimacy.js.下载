function createFallingNote(noteIndex, keyEl, autoPlay) {
    if (!keyEl) return;
    const area = document.getElementById('play-falling-area');
    const note = document.createElement('div');
    note.className = 'play-falling-note';
    note.dataset.noteIndex = noteIndex;
    
    if (keyEl.classList.contains('play-key-black')) {
        note.classList.add('black-key');
    }
    
    const keyboardRect = document.getElementById('play-keyboard').getBoundingClientRect();
    const keyRect = keyEl.getBoundingClientRect();
    const areaRect = area.getBoundingClientRect();
    
    const leftPercent = ((keyRect.left - keyboardRect.left) / keyboardRect.width) * 100;
    const widthPercent = (keyRect.width / keyboardRect.width) * 100;
    
    note.style.left = leftPercent + '%';
    note.style.width = widthPercent + '%';
    note.style.height = '30px';
    
    area.appendChild(note);

    // 使用 requestAnimationFrame 实现丝滑下落
    let start = null;
    const duration = 1500; // 下落总时间 1.5秒
    const targetY = areaRect.height; // 落到底部
    
    function step(timestamp) {
        if (!start) start = timestamp;
        const progress = (timestamp - start) / duration;
        
        if (progress < 1) {
            const currentY = progress * targetY;
            note.style.transform = `translateY(${currentY}px)`;
            
            // 判定区间：到达底部 75% ~ 90% 之间算作可击中 (判定线在 85%)
            if (!autoPlay) {
                const percent = progress * 100;
                if (percent >= 75 && percent <= 90) {
                    note.dataset.hittable = 'true';
                } else {
                    note.dataset.hittable = 'false';
                }
                
                // 如果掉出屏幕还没被击中，算 Miss
                if (percent > 90 && !note.dataset.missed && document.body.contains(note)) {
                    note.dataset.missed = 'true';
                    showPlayHitEffect('miss');
                    playCurrentStep++; 
                    if (playCurrentStep >= playParsedMelody.length) {
                        document.getElementById('play-ta-hint').innerText = '挑战结束！';
                        document.getElementById('play-ta-hint').style.display = 'block';
                    }
                }
            }
            
            if (document.body.contains(note)) {
                requestAnimationFrame(step);
            }
        } else {
            if (document.body.contains(note)) {
                note.remove();
            }
            if (autoPlay) {
                activatePlayKey(noteIndex, keyEl);
            }
        }
    }
    requestAnimationFrame(step);
}

// 新增：黑胶唱片播放逻辑
let vinylPlayInterval = null;
let vinylCurrentStep = 0;

function togglePlayVinylMusic() {
    const vinyl = document.getElementById('play-vinyl-record');
    const tonearm = document.getElementById('play-vinyl-tonearm');
    
    if (vinyl.classList.contains('playing')) {
        // 停止播放：唱片停止旋转，唱针移开
        vinyl.classList.remove('playing');
        tonearm.classList.remove('playing');
        clearInterval(vinylPlayInterval);
    } else {
        // 开始播放
        initPlayAudio();
        parsePlaySheet(currentPlayRawSheet);
        if (playParsedMelody.length === 0) return;
        
        // 唱片开始旋转，唱针落到唱片上
        vinyl.classList.add('playing');
        tonearm.classList.add('playing');
        vinylCurrentStep = 0;
        
        vinylPlayInterval = setInterval(() => {
            if (vinylCurrentStep >= playParsedMelody.length) {
                vinyl.classList.remove('playing');
                tonearm.classList.remove('playing');
                clearInterval(vinylPlayInterval);
                return;
            }
            const noteIndex = playParsedMelody[vinylCurrentStep];
            playNoteSound(noteIndex);
            vinylCurrentStep++;
        }, 600);
    }
}

