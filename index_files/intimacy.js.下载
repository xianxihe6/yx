let isIntimacyGroupEditing = false;

function toggleIntimacyGroupEdit() {
    isIntimacyGroupEditing = !isIntimacyGroupEditing;
    const btn = document.getElementById('intimacyGroupEditBtn');
    if (isIntimacyGroupEditing) {
        btn.innerText = 'Done';
        btn.style.color = '#111';
    } else {
        btn.innerText = 'Edit';
        btn.style.color = '#888';
    }
    renderIntimacyGroups(); // 重新渲染列表以显示/隐藏删除按钮
}

function openIntimacyApp() {
    document.getElementById('intimacyAppPanel').style.display = 'flex';
    
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    if (currentLoginId) {
        // 已登录
        document.getElementById('intimacyLoginPage').style.transform = 'translateY(100%)';
        renderIntimacyMainPage();
    } else {
        // 未登录
        document.getElementById('intimacyLoginPage').style.transform = 'translateY(0)';
        renderIntimacyAccountList();
    }
}

function closeIntimacyApp() {
    document.getElementById('intimacyAppPanel').style.display = 'none';
}

// --- 登录逻辑 ---
function renderIntimacyAccountList() {
    const listEl = document.getElementById('intimacyAccountList');
    if (!listEl) return;
    listEl.innerHTML = '';

    let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
    
    if (accounts.length === 0) {
        listEl.innerHTML = '<div style="text-align: center; color: #aaa; font-size: 13px; padding: 20px 0;">暂无可用账号，请先在 Chat 中注册</div>';
        return;
    }

    accounts.forEach(acc => {
        const item = document.createElement('div');
        item.style.cssText = 'background: #f9f9f9; border-radius: 16px; padding: 15px; display: flex; align-items: center; gap: 15px; cursor: pointer; border: 1px solid #eee;';
        item.onclick = () => {
            ChatDB.setItem('intimacy_current_account', acc.id);
            document.getElementById('intimacyLoginPage').style.transform = 'translateY(100%)';
            renderIntimacyMainPage();
        };
        item.innerHTML = `
            <div style="width: 48px; height: 48px; border-radius: 12px; background-image: url('${acc.avatarUrl || ''}'); background-size: cover; background-position: center; background-color: #eee;"></div>
            <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                <div style="font-size: 16px; font-weight: bold; color: #111;">${acc.netName || '未命名'}</div>
                <div style="font-size: 12px; color: #888; font-family: monospace;">${acc.account}</div>
            </div>
        `;
        listEl.appendChild(item);
    });
}

function intimacyLoginWithPassword() {
    const account = document.getElementById('intimacyLoginAccount').value.trim();
    const password = document.getElementById('intimacyLoginPassword').value.trim();
    
    if (!account || !password) return alert('请输入账号和密码！');
    
    let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
    const validAccount = accounts.find(a => a.account === account && a.password === password);
    
    if (validAccount) {
        ChatDB.setItem('intimacy_current_account', validAccount.id);
        document.getElementById('intimacyLoginPage').style.transform = 'translateY(100%)';
        renderIntimacyMainPage();
    } else {
        alert('账号或密码错误！');
    }
}

// --- 设置与切换账号逻辑 ---
function openIntimacySettingsPage() {
    const listEl = document.getElementById('intimacySwitchAccountList');
    listEl.innerHTML = '';
    
    let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    
    accounts.forEach(acc => {
        const isCurrent = acc.id === currentLoginId;
        const item = document.createElement('div');
        item.style.cssText = `display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid #f5f5f5; cursor: pointer; background: ${isCurrent ? '#f9f9f9' : '#fff'}; flex-shrink: 0;`;
        item.onclick = () => {
            if (!isCurrent) {
                ChatDB.setItem('intimacy_current_account', acc.id);
                renderIntimacyMainPage();
                closeIntimacySettingsPage();
                showIntimacyToast('已切换账号');
            }
        };
        item.innerHTML = `
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 40px; height: 40px; border-radius: 10px; background-image: url('${acc.avatarUrl || ''}'); background-size: cover; background-position: center; background-color: #eee;"></div>
                <div style="font-size: 15px; font-weight: bold; color: #111;">${acc.netName || '未命名'}</div>
            </div>
            ${isCurrent ? '<svg viewBox="0 0 24 24" width="20" height="20" stroke="#111" stroke-width="2" fill="none"><polyline points="20 6 9 17 4 12"></polyline></svg>' : ''}
        `;
        listEl.appendChild(item);
    });
    
    const apiSelect = document.getElementById('intimacyApiSelect');
    if (apiSelect) {
        apiSelect.innerHTML = '<option value="">默认全局 API</option>';
        let presets = JSON.parse(ChatDB.getItem('api_presets') || '[]');
        presets.forEach(p => {
            const opt = document.createElement('option');
            opt.value = p.id;
            opt.innerText = p.name;
            apiSelect.appendChild(opt);
        });
        
        const savedApiId = ChatDB.getItem(`intimacy_api_preset_${currentLoginId}`);
        if (savedApiId) {
            apiSelect.value = savedApiId;
        }
    }

    document.getElementById('intimacySettingsPage').style.display = 'flex';
}

function saveIntimacyApiSelect() {
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    const val = document.getElementById('intimacyApiSelect').value;
    if (val) {
        ChatDB.setItem(`intimacy_api_preset_${currentLoginId}`, val);
    } else {
        ChatDB.removeItem(`intimacy_api_preset_${currentLoginId}`);
    }
}

function closeIntimacySettingsPage() {
    document.getElementById('intimacySettingsPage').style.display = 'none';
}

function intimacyLogout() {
    if (confirm('确定要退出当前账号吗？')) {
        ChatDB.removeItem('intimacy_current_account');
        closeIntimacySettingsPage();
        document.getElementById('intimacyLoginPage').style.transform = 'translateY(0)';
        renderIntimacyAccountList();
    }
}

function renderIntimacyMainPage() {
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    if (!currentLoginId) return;

    let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
    const me = accounts.find(a => a.id === currentLoginId);
    if (!me) return;

    // 渲染我的头像
    const avatarMeEl = document.getElementById('intimacyLoverAvatarMe');
    if (me.avatarUrl) {
        avatarMeEl.style.backgroundImage = `url('${me.avatarUrl}')`;
        avatarMeEl.style.backgroundSize = 'cover';
        avatarMeEl.style.backgroundPosition = 'center';
        avatarMeEl.innerHTML = '';
    } else {
        avatarMeEl.style.backgroundImage = 'none';
        avatarMeEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
    }

    // 检查是否绑定了恋人
    const loverDataStr = ChatDB.getItem(`intimacy_lover_${currentLoginId}`);
    const avatarTaEl = document.getElementById('intimacyLoverAvatarTa');
    const nameTextEl = document.getElementById('intimacyLoverNameText');
    const daysTextEl = document.getElementById('intimacyLoverDaysText');

    if (loverDataStr) {
        const loverData = JSON.parse(loverDataStr);
        let allEntities = typeof getAllEntities === 'function' ? getAllEntities() : [];
        const char = allEntities.find(c => c.id === loverData.charId);
        
        if (char) {
            avatarTaEl.classList.remove('empty');
            if (char.avatarUrl) {
                avatarTaEl.style.backgroundImage = `url('${char.avatarUrl}')`;
                avatarTaEl.style.backgroundSize = 'cover';
                avatarTaEl.style.backgroundPosition = 'center';
                avatarTaEl.innerHTML = '';
            } else {
                avatarTaEl.style.backgroundImage = 'none';
                avatarTaEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
            }
            
            const myName = me.netName || '我';
            const taName = char.netName || char.name || 'TA';
            nameTextEl.innerHTML = `${myName}<span>&</span>${taName}`;
            
            const days = Math.floor((Date.now() - loverData.bindTime) / (1000 * 60 * 60 * 24));
            daysTextEl.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>在一起 ${days} 天`;
        }
    } else {
        avatarTaEl.classList.add('empty');
        avatarTaEl.style.backgroundImage = 'none';
        avatarTaEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>';
        nameTextEl.innerHTML = `我<span>&</span>等TA来`;
        daysTextEl.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>点击邀请恋人`;
    }

    // 渲染关系组
    renderIntimacyGroups();
}

function renderIntimacyGroups() {
    const container = document.getElementById('intimacyGroupsContainer');
    if (!container) return;
    container.innerHTML = '';

    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    if (!currentLoginId) return;

    // 默认分组
    let groups = JSON.parse(ChatDB.getItem(`intimacy_groups_${currentLoginId}`) || '["闺蜜", "基友", "家人"]');
    let allEntities = typeof getAllEntities === 'function' ? getAllEntities() : [];

    groups.forEach(groupName => {
        let membersIds = JSON.parse(ChatDB.getItem(`intimacy_members_${currentLoginId}_${groupName}`) || '[]');
        let members = membersIds.map(id => allEntities.find(c => c.id === id)).filter(c => c);

        const groupEl = document.createElement('div');
        groupEl.className = 'intimacy-rel-group';
        
        let avatarsHtml = '';
        if (members.length >= 2) {
            avatarsHtml = `
                <div class="intimacy-ra" style="background-image: url('${members[0].avatarUrl || ''}'); background-size: cover; background-position: center;">${!members[0].avatarUrl ? '<svg viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.6" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' : ''}</div>
                <div class="intimacy-ra" style="background-image: url('${members[1].avatarUrl || ''}'); background-size: cover; background-position: center;">${!members[1].avatarUrl ? '<svg viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.6" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' : ''}</div>
            `;
        } else if (members.length === 1) {
            avatarsHtml = `
                <div class="intimacy-ra" style="background-image: url('${members[0].avatarUrl || ''}'); background-size: cover; background-position: center;">${!members[0].avatarUrl ? '<svg viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.6" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' : ''}</div>
                <div class="intimacy-ra placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></div>
            `;
        } else {
            avatarsHtml = `
                <div class="intimacy-ra placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></div>
                <div class="intimacy-ra placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></div>
            `;
        }

        let membersHtml = '';
        members.forEach(m => {
            membersHtml += `
                <div class="intimacy-mem-row" onclick="openIntimacyDetail('member', '${m.id}', '${groupName}', 0)">
                    <div class="intimacy-mem-av" style="background-image: url('${m.avatarUrl || ''}'); background-size: cover; background-position: center;">${!m.avatarUrl ? '<svg viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' : ''}</div>
                    <div class="intimacy-mem-info"><div class="intimacy-mem-name">${m.netName || m.name}</div><div class="intimacy-mem-sub">已加入</div></div>
                </div>
            `;
        });

        membersHtml += `
            <div class="intimacy-mem-row empty" onclick="showIntimacyAddMemberModal('${groupName}')">
                <div class="intimacy-mem-av"><svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></div>
                <div class="intimacy-mem-info"><div class="intimacy-mem-name">添加成员</div></div>
            </div>
        `;

        let deleteBtnHtml = '';
        if (isIntimacyGroupEditing) {
            deleteBtnHtml = `<div class="intimacy-rel-delete" onclick="deleteIntimacyGroup('${groupName}', ${members.length}, event)" style="margin-right: 10px; color: #ff3b30; font-size: 12px; font-weight: bold; padding: 4px 8px; background: #ffe5e5; border-radius: 8px;">删除</div>`;
        }

        groupEl.innerHTML = `
            <div class="intimacy-rel-head" onclick="${isIntimacyGroupEditing ? '' : 'toggleIntimacyGroup(this)'}">
                <div class="intimacy-rel-pair">
                    ${avatarsHtml}
                </div>
                <div class="intimacy-rel-meta">
                    <div class="intimacy-rel-name">${groupName}</div>
                    <div class="intimacy-rel-count">${members.length} 人</div>
                </div>
                ${deleteBtnHtml}
                <div class="intimacy-rel-arrow" style="${isIntimacyGroupEditing ? 'display:none;' : ''}"><svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg></div>
            </div>
            <div class="intimacy-rel-body">
                <div class="intimacy-rel-body-inner">
                    ${membersHtml}
                </div>
            </div>
        `;
        container.appendChild(groupEl);
    });
}

function handleLoverCardClick() {
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    if (!currentLoginId) return;
    const loverDataStr = ChatDB.getItem(`intimacy_lover_${currentLoginId}`);
    if (loverDataStr) {
        openIntimacyDetail('lover');
    } else {
        openLoverInviteModal();
    }
}

function openLoverInviteModal() {
    const listEl = document.getElementById('intimacyLoverInviteList');
    listEl.innerHTML = '';
    
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    let allEntities = typeof getAllEntities === 'function' ? getAllEntities() : [];
    
    document.querySelector('#intimacyLoverInviteModalOverlay .preset-modal-title').innerText = '邀请恋人';

    // 过滤出可以邀请的对象：排除自己、排除NPC、排除群聊、排除已绑定恋人的对象
    let inviteTargets = allEntities.filter(c => {
        if (c.id === currentLoginId) return false;
        if (c.isNPC || c.isGroup) return false;
        const taLover = ChatDB.getItem(`intimacy_lover_${c.id}`);
        return !taLover;
    });

    if (inviteTargets.length === 0) {
        listEl.innerHTML = '<div style="text-align:center; color:#aaa; font-size:12px;">暂无单身角色或用户可邀请</div>';
    } else {
        inviteTargets.forEach(c => {
            const typeTag = c.isAccount ? '<span style="font-size:10px; background:#eee; color:#888; padding:2px 4px; border-radius:4px; margin-left:4px;">用户</span>' : '';
            const item = document.createElement('div');
            item.style.cssText = 'display: flex; align-items: center; gap: 10px; padding: 10px; background: #f9f9f9; border-radius: 10px; cursor: pointer;';
            item.innerHTML = `
                <div style="width: 36px; height: 36px; border-radius: 8px; background-image: url('${c.avatarUrl || ''}'); background-size: cover; background-position: center; background-color: #eee;"></div>
                <div style="font-size: 14px; font-weight: bold; color: #333; flex: 1;">${c.netName || c.name}${typeTag}</div>
            `;
            item.onclick = () => bindLover(c.id);
            listEl.appendChild(item);
        });
    }
    document.getElementById('intimacyLoverInviteModalOverlay').classList.add('show');
}

function closeLoverInviteModal() {
    document.getElementById('intimacyLoverInviteModalOverlay').classList.remove('show');
}

let pendingLoverCharId = null;

function bindLover(charId) {
    pendingLoverCharId = charId;
    closeLoverInviteModal();
    document.getElementById('userConfessionInput').value = '';
    document.getElementById('userConfessionModalOverlay').classList.add('show');
}

function closeUserConfessionModal() {
    document.getElementById('userConfessionModalOverlay').classList.remove('show');
    pendingLoverCharId = null;
}

function confirmUserConfession() {
    const text = document.getElementById('userConfessionInput').value.trim() || "“我观察你很久了，每次看到你，我的心跳都会漏半拍。这段时间以来的相处，让我确信你就是那个对的人。<br><br>你愿意，成为我的唯一吗？”";
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    if (typeof sendIntimacyInviteMsg === 'function') {
        sendIntimacyInviteMsg(currentLoginId, pendingLoverCharId, 'lover', '', text);
    }
    closeUserConfessionModal();
    showIntimacyToast('已发送恋人邀请至聊天室！');
}

