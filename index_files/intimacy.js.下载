async function triggerPlayApiGenerate() {
    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    if (!currentLoginId || !currentIntimacyCharId) return alert('未找到当前角色');

    let apiConfig = null;
    const selectedApiId = ChatDB.getItem(`intimacy_api_preset_${currentLoginId}`);
    if (selectedApiId) {
        let presets = JSON.parse(ChatDB.getItem('api_presets') || '[]');
        apiConfig = presets.find(p => p.id.toString() === selectedApiId);
    }
    if (!apiConfig) {
        apiConfig = JSON.parse(ChatDB.getItem('current_api_config') || '{}');
    }

    if (!apiConfig.url || !apiConfig.key || !apiConfig.model) {
        return alert('请先在设置中配置 API！');
    }

    const modal = document.getElementById('play-loading-modal');
    const textEl = document.getElementById('play-loading-text');
    modal.classList.add('show');
    textEl.innerText = "正在提取记忆与设定...";

    try {
        // 1. 获取基础实体信息
        let allEntities = typeof getAllEntities === 'function' ? getAllEntities() : [];
        const char = allEntities.find(c => c.id === currentIntimacyCharId);
        const me = allEntities.find(a => a.id === currentLoginId);
        
        if (!char || !me) throw new Error("角色或用户数据丢失");

        // 2. 获取用户面具与真名
        let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
        const account = accounts.find(a => a.id === currentLoginId);
        let personas = JSON.parse(ChatDB.getItem('chat_personas') || '[]');
        const persona = personas.find(p => p.id === (account ? account.personaId : null));
        
        const userRealName = persona ? (persona.realName || me.netName || 'User') : (me.netName || 'User');
        const userPersonaDesc = persona ? (persona.persona || '普通用户') : '普通用户';
        const charName = char.netName || char.name || 'Char';
        const charDesc = char.description || '无';

        // 3. 获取世界书
        let activeWbs = [];
        if (char.wbEntries && char.wbEntries.length > 0) {
            let wbData = JSON.parse(ChatDB.getItem('worldbook_data')) || { entries: [] };
            let entries = wbData.entries.filter(e => char.wbEntries.includes(e.id));
            entries.forEach(entry => {
                if (entry.constant) activeWbs.push(entry.content);
            });
        }

        // 4. 获取角色记忆库
        const currentPersonaId = persona ? persona.id : currentLoginId;
        let memory = JSON.parse(ChatDB.getItem(`char_memory_${currentPersonaId}_${currentIntimacyCharId}`) || '{}');
        let memoryText = "";
        if (memory.core && memory.core.length > 0) {
            memoryText += "[核心记忆]\n" + memory.core.map(m => m.content).join('\n') + "\n";
        }
        if (memory.summary && memory.summary.length > 0) {
            memoryText += "[近期剧情]\n" + memory.summary.slice(-3).map(m => m.content).join('\n') + "\n";
        }

        // 5. 获取最近 30 条聊天记录
        let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${currentIntimacyCharId}`) || '[]');
        let recentHistory = history.slice(-30).map(m => {
            let sender = m.role === 'user' ? userRealName : charName;
            let content = m.content.replace(/<[^>]+>/g, ''); // 简单过滤 HTML 标签
            return `${sender}: ${content}`;
        }).join('\n');

        // 6. 组装 Prompt
        const prompt = `你是一个专属曲谱生成助手。请根据以下角色设定、记忆和聊天记录，为我们谱写一首专属的钢琴简谱。

【角色设定】：
${charName}的设定：${charDesc}
${userRealName}的设定：${userPersonaDesc}

【世界书背景】：
${activeWbs.join('\n') || '无'}

【记忆库】：
${memoryText || '无'}

【最近聊天记录】：
${recentHistory || '暂无聊天记录'}

要求：
1. 简谱只包含数字 1-7，用空格分隔，可以用横线 - 表示长音。
2. 曲谱请尽量长一点，至少包含 4 到 8 行旋律，让演奏更有沉浸感。
3. 必须返回 JSON 格式：
{
  "title": "曲谱名称",
  "desc": "简单优雅的曲子简介（20字以内，如：记录了海边漫步的足迹）",
  "charMsg": "角色对这首曲子的内心独白或寄语（如：这首曲子，是我看着你的侧脸时想到的...）",
  "sheet": "1 2 3 4 5 5 5\\n5 4 3 2 1 - -\\n3 4 5 6 5 - -\\n1 2 3 2 1 - -"
}`;

        textEl.innerText = "AI 正在谱写专属曲谱...";

        const response = await fetch(`${apiConfig.url.replace(/\/$/, '')}/chat/completions`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${apiConfig.key}` },
            body: JSON.stringify({
                model: apiConfig.model,
                messages: [{ role: 'user', content: prompt }],
                temperature: 0.8
            })
        });

        if (response.ok) {
            const data = await response.json();
            let replyRaw = data.choices[0].message.content.trim();
            replyRaw = replyRaw.replace(/^```json/i, '').replace(/^```/i, '').replace(/```$/i, '').trim();
            const parsed = JSON.parse(replyRaw);

            let records = JSON.parse(ChatDB.getItem(`intimacy_play_records_${currentLoginId}_${currentIntimacyCharId}`) || '[]');
            records.push({
                id: Date.now().toString(),
                title: parsed.title || '《未命名的羁绊》',
                desc: parsed.desc || 'AI根据最新聊天记录生成的专属旋律。',
                charMsg: parsed.charMsg || '“这是属于我们现在的旋律，你听到了吗？”',
                sheet: parsed.sheet || '1 2 3 4 5 5 5\n5 4 3 2 1 - -',
                date: new Date().toISOString().split('T')[0].replace(/-/g, '.'),
                img: '',
                creator: 'char' // 新增：标记为角色创作
            });
            ChatDB.setItem(`intimacy_play_records_${currentLoginId}_${currentIntimacyCharId}`, JSON.stringify(records));

            modal.classList.remove('show');
            renderPlayLibrary();
        } else {
            throw new Error('API 请求失败');
        }
    } catch (e) {
        modal.classList.remove('show');
        alert('生成失败: ' + e.message);
    }
}

function renderPlayLibrary() {
    const wrapper = document.getElementById('play-timeline-wrapper');
    wrapper.innerHTML = '';

    const currentLoginId = ChatDB.getItem('intimacy_current_account');
    if (!currentLoginId || !currentIntimacyCharId) return;

    let records = JSON.parse(ChatDB.getItem(`intimacy_play_records_${currentLoginId}_${currentIntimacyCharId}`) || '[]');

    if (records.length === 0) {
        wrapper.innerHTML = '<div style="text-align:center; color:#aaa; font-size:13px; margin-top:40px;">暂无专属曲谱，点击右上角生成</div>';
        return;
    }

    // 倒序渲染
    records.slice().reverse().forEach((record, index) => {
        const isLeft = index % 2 === 0;
        const nodeClass = isLeft ? 'left' : 'right';
        
        const safeTitle = record.title.replace(/'/g, "\\'");
        const safeDate = record.date.replace(/'/g, "\\'");
        const safeDesc = record.desc.replace(/'/g, "\\'").replace(/\n/g, " ");
        const safeCharMsg = (record.charMsg || record.desc).replace(/'/g, "\\'").replace(/\n/g, " ");
        const safeSheet = record.sheet.replace(/'/g, "\\'").replace(/\n/g, "\\n");

        const nodeHTML = `
            <div class="play-polaroid-node ${nodeClass}">
                <div class="play-polaroid-card" onclick="openPlayDetailModal('${safeTitle}', '${safeDate}', '${safeDesc}', '${safeSheet}', '${safeCharMsg}', this, '${record.id}')">
                    <div class="play-polaroid-img" style="background-image: url('${record.img || ''}'); ${record.img ? 'background-size: cover;' : ''}">
                        ${!record.img ? '<svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>' : ''}
                    </div>
                    <div class="play-polaroid-title">${record.title}</div>
                    <div class="play-polaroid-date">${record.date}</div>
                </div>
            </div>
        `;
        
        wrapper.insertAdjacentHTML('beforeend', nodeHTML);

        if (index < records.length - 1) {
            const svgHTML = `<svg class="play-svg-connector" viewBox="0 0 100 50"><path d="${isLeft ? 'M 20 0 C 20 25, 80 25, 80 50' : 'M 80 0 C 80 25, 20 25, 20 50'}" /></svg>`;
            wrapper.insertAdjacentHTML('beforeend', svgHTML);
        }
    });
}

