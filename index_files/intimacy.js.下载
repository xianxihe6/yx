function sendIntimacyInviteMsg(userId, charId, type, groupName = '', confessionText = '') {
    let newMsg = {
        role: 'user',
        type: 'intimacy_invite',
        subType: type, // 'lover' or 'friend'
        groupName: groupName,
        confessionText: confessionText,
        status: 'pending',
        timestamp: Date.now(),
        content: type === 'lover' ? '[恋人邀请]' : `[${groupName}邀请]`
    };


    let history = JSON.parse(ChatDB.getItem(`chat_history_${userId}_${charId}`) || '[]');
    history.push(newMsg);
    ChatDB.setItem(`chat_history_${userId}_${charId}`, JSON.stringify(history));

    // 双向同步给对方
    let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${charId}_${userId}`) || '[]');
    let targetMsg = { ...newMsg, role: 'char' };
    targetHistory.push(targetMsg);
    ChatDB.setItem(`chat_history_${charId}_${userId}`, JSON.stringify(targetHistory));

    let targetSessions = JSON.parse(ChatDB.getItem(`chat_sessions_${charId}`) || '[]');
    targetSessions = targetSessions.filter(id => id !== userId);
    targetSessions.unshift(userId);
    ChatDB.setItem(`chat_sessions_${charId}`, JSON.stringify(targetSessions));

    let unreadCount = parseInt(ChatDB.getItem(`unread_${charId}_${userId}`) || '0');
    ChatDB.setItem(`unread_${charId}_${userId}`, (unreadCount + 1).toString());

    if (typeof renderChatList === 'function') renderChatList();
    if (currentChatRoomCharId === charId) {
        renderChatHistory(charId);
    }
}

let currentIntimacyInviteMsgIndex = null;

function handleIntimacyInviteClick(index) {
    const currentLoginId = ChatDB.getItem('current_login_account');
    if (!currentLoginId || !currentChatRoomCharId) return;

    let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    const msg = history[index];

    if (!msg || msg.type !== 'intimacy_invite') return;
    if (msg.status !== 'pending') return;

    currentIntimacyInviteMsgIndex = index;

    let allEntities = getAllEntities();
    const char = allEntities.find(c => c.id === currentChatRoomCharId);
    const me = allEntities.find(a => a.id === currentLoginId);
    const charName = char ? (char.netName || char.name) : 'TA';
    const myName = me ? (me.netName || me.name) : '我';
    
    // 获取真实姓名用于信纸显示
    const charRealName = char ? char.name : 'TA';
    const myRealName = me ? me.name : '我';

    const isUserSender = msg.role === 'user';

    if (msg.subType === 'lover') {
        // 恋人邀请，弹出信封 (使用真实姓名)
        document.getElementById('letterTitle').innerText = isUserSender ? `To: ${charRealName}` : `To: ${myRealName}`;
        document.getElementById('letterSignature').innerText = isUserSender ? `From: ${myRealName}` : `From: ${charRealName}`;
        
