    history.push(newMsg);
    ChatDB.setItem(`chat_history_${currentLoginId}_${currentIntimacyCharId}`, JSON.stringify(history));
    
    // 双向同步
    let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentIntimacyCharId}_${currentLoginId}`) || '[]');
    let targetMsg = { ...newMsg, role: 'char' };
    targetHistory.push(targetMsg);
    ChatDB.setItem(`chat_history_${currentIntimacyCharId}_${currentLoginId}`, JSON.stringify(targetHistory));

    let targetSessions = JSON.parse(ChatDB.getItem(`chat_sessions_${currentIntimacyCharId}`) || '[]');
    targetSessions = targetSessions.filter(id => id !== currentLoginId);
    targetSessions.unshift(currentLoginId);
    ChatDB.setItem(`chat_sessions_${currentIntimacyCharId}`, JSON.stringify(targetSessions));

    let unreadCount = parseInt(ChatDB.getItem(`unread_${currentIntimacyCharId}_${currentLoginId}`) || '0');
    ChatDB.setItem(`unread_${currentIntimacyCharId}_${currentLoginId}`, (unreadCount + 1).toString());

    showIntimacyToast('已分享给 TA！');
}

function activatePlayKey(noteIndex, keyEl) {
    if(keyEl) {
        keyEl.classList.add('active');
        playNoteSound(noteIndex); 
        createPlayFloatingNote(keyEl); 
        setTimeout(() => keyEl.classList.remove('active'), 150);
    }
}

function createPlayFloatingNote(keyEl) {
    const area = document.getElementById('play-staff-area');
    const noteSymbols = ['♪', '♫', '♬'];
    const symbol = noteSymbols[Math.floor(Math.random() * noteSymbols.length)];
    const note = document.createElement('div');
    note.className = 'play-floating-note';
    note.innerText = symbol;
    const rect = keyEl.getBoundingClientRect();
    const areaRect = area.getBoundingClientRect();
    const leftPos = rect.left - areaRect.left + (rect.width / 2);
    note.style.left = leftPos + 'px';
    note.style.bottom = '0px';
    area.appendChild(note);
    setTimeout(() => note.remove(), 1500);
}

