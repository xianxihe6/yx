let playAudioCtx;
const playFrequencies = [261.63, 277.18, 293.66, 311.13, 329.63, 349.23, 369.99, 392.00, 415.30, 440.00, 466.16, 493.88];
const playNoteMapping = { '1': 0, '2': 2, '3': 4, '4': 5, '5': 7, '6': 9, '7': 11 };

function initPlayAudio() {
    if (!playAudioCtx) {
        playAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }
    if (playAudioCtx.state === 'suspended') {
        playAudioCtx.resume();
    }
}

function playNoteSound(noteIndex) {
    if (!playAudioCtx) return;
    const osc = playAudioCtx.createOscillator();
    const gainNode = playAudioCtx.createGain();
    osc.type = 'sine'; 
    osc.frequency.setValueAtTime(playFrequencies[noteIndex % 12], playAudioCtx.currentTime);
    gainNode.gain.setValueAtTime(0.5, playAudioCtx.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, playAudioCtx.currentTime + 0.5);
    osc.connect(gainNode);
    gainNode.connect(playAudioCtx.destination);
    osc.start();
    osc.stop(playAudioCtx.currentTime + 0.5);
}

