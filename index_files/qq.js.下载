function closeQQGroupAdminModal() {
    document.getElementById('qqGroupAdminModalOverlay').classList.remove('show');
}

function toggleQQGroupAdmin(id, isChecked) {
    if (isChecked) {
        if (!tempQQGroupAdmins.includes(id)) tempQQGroupAdmins.push(id);
    } else {
        tempQQGroupAdmins = tempQQGroupAdmins.filter(m => m !== id);
    }
}

function confirmQQGroupAdmin() {
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let group = friends.find(f => f.id === currentQQChatId);
    if (group) {
        group.adminIds = [...tempQQGroupAdmins];
        ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
        renderQQGroupMembers(group);
        broadcastQQGroupUpdate(group.id, { adminIds: group.adminIds });
    }
    closeQQGroupAdminModal();
}

// 邀请新成员
function inviteQQGroupMember(group) {
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]').filter(f => !f.isGroup && !group.members.includes(f.id));
    if (friends.length === 0) return alert('没有可邀请的好友');
    
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; justify-content: center; align-items: center;';
    
    const modal = document.createElement('div');
    modal.style.cssText = 'background: #fff; width: 80%; max-width: 320px; border-radius: 16px; padding: 20px; display: flex; flex-direction: column; max-height: 70vh;';
    
    const title = document.createElement('div');
    title.innerText = '邀请好友';
    title.style.cssText = 'font-size: 16px; font-weight: bold; text-align: center; margin-bottom: 15px; color: #333;';
    modal.appendChild(title);
    
    const list = document.createElement('div');
    list.style.cssText = 'flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; margin-bottom: 15px;';
    
    let selectedIds = [];
    
    friends.forEach(f => {
        const item = document.createElement('label');
        item.style.cssText = 'display: flex; align-items: center; gap: 10px; padding: 10px; background: #f9f9f9; border-radius: 10px; cursor: pointer;';
        item.innerHTML = `
            <input type="checkbox" value="${f.id}" style="width: 18px; height: 18px; accent-color: #111;">
            <div style="width: 36px; height: 36px; border-radius: 8px; background-image: url('${f.avatar || ''}'); background-size: cover; background-color: #eee;"></div>
            <div style="font-size: 14px; font-weight: bold; color: #333; flex: 1;">${f.alias || f.name}</div>
        `;
        const checkbox = item.querySelector('input');
        checkbox.onchange = (e) => {
            if (e.target.checked) selectedIds.push(f.id);
            else selectedIds = selectedIds.filter(id => id !== f.id);
        };
        list.appendChild(item);
    });
    modal.appendChild(list);
    
    const btnRow = document.createElement('div');
    btnRow.style.cssText = 'display: flex; gap: 10px;';
    
    const cancelBtn = document.createElement('div');
    cancelBtn.innerText = '取消';
    cancelBtn.style.cssText = 'flex: 1; padding: 10px; text-align: center; background: #f4f4f4; color: #333; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 14px;';
    cancelBtn.onclick = () => document.body.removeChild(overlay);
    
    const confirmBtn = document.createElement('div');
    confirmBtn.innerText = '确定';
    confirmBtn.style.cssText = 'flex: 1; padding: 10px; text-align: center; background: #111; color: #fff; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 14px;';
    confirmBtn.onclick = () => {
        if (selectedIds.length === 0) return alert('请至少选择一个好友');
        document.body.removeChild(overlay);
        
        selectedIds.forEach(targetId => {
            group.members.push(targetId);
        });
        
        let allFriends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let gIndex = allFriends.findIndex(f => f.id === group.id);
        if (gIndex > -1) allFriends[gIndex] = group;
        ChatDB.setItem('qq_online_friends', JSON.stringify(allFriends));
        
        renderQQGroupMembers(group);
        
        selectedIds.forEach(targetId => {
            publishSupabaseBroadcast("user_" + targetId, { 
                senderId: qqMyOnlineId, 
                type: 'group_invite', 
                groupId: group.id, 
                groupName: group.name, 
                members: group.members,
                ownerId: group.ownerId,
                adminIds: group.adminIds,
                chars: group.chars
            });
        });
        
        broadcastQQGroupUpdate(group.id, { members: group.members });
        
        let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名"}');
        let invitedNames = friends.filter(f => selectedIds.includes(f.id)).map(f => f.alias || f.name).join('、');
        sendQQSystemMessage(group.id, `${myProfile.name} 邀请 ${invitedNames} 加入了群聊`);
        
        alert('邀请成功！');
    };
    
    btnRow.appendChild(cancelBtn);
    btnRow.appendChild(confirmBtn);
    modal.appendChild(btnRow);
    overlay.appendChild(modal);
    document.body.appendChild(overlay);
}

// 踢出成员
function kickQQGroupMember(memberId, groupId, groupName) {
    if (confirm('确定要将该成员移出群聊吗？')) {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let group = friends.find(f => f.id === groupId);
