// 三图床自动切换上传引擎 (带跨域代理 + Base64终极兜底)
async function uploadImageToUrl(file) {
    if (typeof showToast === 'function') showToast('正在处理图片...', 'loading');
    
    // 尝试 1: img.scdn.io (使用 corsproxy.io 代理绕过本地跨域拦截)
    try {
        let fd1 = new FormData();
        fd1.append('file', file);
        let res1 = await fetch('https://corsproxy.io/?https://img.scdn.io/api/v1/upload', { 
            method: 'POST', 
            body: fd1,
            headers: { 'Accept': 'application/json' }
        });
        let data1 = await res1.json();
        if (data1 && data1.status && data1.data && data1.data.links && data1.data.links.url) {
            if (typeof hideToast === 'function') hideToast();
            return data1.data.links.url;
        }
    } catch (e) {
        console.warn("img.scdn.io 代理上传失败...", e);
    }

    // 尝试 2: imgtp.com (使用 corsproxy.io 代理)
    try {
        let fd2 = new FormData();
        fd2.append('image', file);
        let res2 = await fetch('https://corsproxy.io/?https://www.imgtp.com/api/upload', { 
            method: 'POST', 
            body: fd2,
            headers: { 'Accept': 'application/json' }
        });
        let data2 = await res2.json();
        if (data2 && data2.code === 200 && data2.data && data2.data.url) {
            if (typeof hideToast === 'function') hideToast();
            return data2.data.url;
        }
    } catch (e) {
        console.warn("imgtp 代理上传失败...", e);
    }

    // 尝试 3: ImgBB (原生支持跨域)
    try {
        let fd3 = new FormData();
        fd3.append('image', file);
        let res3 = await fetch('https://api.imgbb.com/1/upload?key=32db6a8711c014cb0f8f11b238260127', { method: 'POST', body: fd3 });
        let data3 = await res3.json();
        if (data3 && data3.success) {
            if (typeof hideToast === 'function') hideToast();
            return data3.data.url;
        }
    } catch (e) {
        console.warn("ImgBB 上传失败...", e);
    }

    // 终极兜底：如果所有图床都因为网络或跨域失败，直接转为 Base64 本地存储！(保证100%能发图)
    console.warn("所有图床均失败，启用 Base64 本地直存模式");
    return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => {
            if (typeof hideToast === 'function') hideToast();
            resolve(reader.result);
        };
        reader.onerror = () => {
            if (typeof hideToast === 'function') hideToast();
            reject(new Error("图片处理失败，请重试"));
        };
        reader.readAsDataURL(file);
    });
}


// 自动将 Base64 头像转为 URL 的辅助函数
async function ensureAvatarUrl(avatarStr) {
    if (!avatarStr || !avatarStr.startsWith('data:image/')) return avatarStr;
    try {
        let res = await fetch(avatarStr);
        let blob = await res.blob();
        let url = await uploadImageToUrl(blob);
        return url;
    } catch (e) {
        console.warn("Base64转URL失败", e);
        return avatarStr;
    }
}

