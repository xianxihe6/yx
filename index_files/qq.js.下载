        profile: myProfile
    });
    
    alert(`已向群聊 [${foundGroup.name}] 发送加群申请，等待管理员同意`);
    closeQQSearchResultModal();
};

// 处理好友请求
async function acceptQQFriendRequest(peerId) {
    let requests = JSON.parse(ChatDB.getItem('qq_friend_requests') || '[]');
    let req = requests.find(r => r.id === peerId);
    if (!req) return;

    addQQOnlineFriend(peerId, req.name, req.avatar);
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":""}');
    
    if (myProfile.avatar && myProfile.avatar.startsWith('data:image/')) {
        myProfile.avatar = await ensureAvatarUrl(myProfile.avatar);
        ChatDB.setItem('qq_my_profile', JSON.stringify(myProfile));
    }
    
    publishSupabaseBroadcast("user_" + peerId, {
        senderId: qqMyOnlineId,
        type: 'friend_accept',
        profile: myProfile
    });
    removeQQFriendRequest(peerId);
}

function rejectQQFriendRequest(peerId) {
    removeQQFriendRequest(peerId);
}

// 同意加群申请
function acceptQQGroupRequest(userId, groupId) {
    let requests = JSON.parse(ChatDB.getItem('qq_group_requests') || '[]');
    let req = requests.find(r => r.userId === userId && r.groupId === groupId);
    if (!req) return;
    
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let group = friends.find(f => f.id === groupId);
    
    if (group) {
        if (!group.members.includes(userId)) {
            group.members.push(userId);
        }
        ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
        
        let allPublicGroups = JSON.parse(ChatDB.getItem('qq_all_public_groups') || '[]');
        let pubGroupIndex = allPublicGroups.findIndex(g => g.id === groupId);
        if (pubGroupIndex > -1) {
            allPublicGroups[pubGroupIndex] = group;
            ChatDB.setItem('qq_all_public_groups', JSON.stringify(allPublicGroups));
        }
        
        publishSupabaseBroadcast("user_" + userId, {
            senderId: qqMyOnlineId,
            type: 'group_join_approved',
            group: group
        });
        
        broadcastQQGroupUpdate(groupId, { members: group.members });
        sendQQSystemMessage(groupId, `${req.name} 通过搜索群号加入了群聊`);
    }
    
    rejectQQGroupRequest(userId, groupId);
}

// 拒绝加群申请
function rejectQQGroupRequest(userId, groupId) {
    let requests = JSON.parse(ChatDB.getItem('qq_group_requests') || '[]');
    requests = requests.filter(r => !(r.userId === userId && r.groupId === groupId));
    ChatDB.setItem('qq_group_requests', JSON.stringify(requests));
    
    if (requests.length === 0 && JSON.parse(ChatDB.getItem('qq_friend_requests') || '[]').length === 0) {
        document.getElementById('qqContactRedDot').style.display = 'none';
    }
    renderQQContactList();
}

function removeQQFriendRequest(peerId) {
    let requests = JSON.parse(ChatDB.getItem('qq_friend_requests') || '[]');
    requests = requests.filter(r => r.id !== peerId);
    ChatDB.setItem('qq_friend_requests', JSON.stringify(requests));
    if (requests.length === 0) document.getElementById('qqContactRedDot').style.display = 'none';
    renderQQContactList();
}

// 创建群聊弹窗逻辑
let tempQQGroupMembers = [];

function createQQGroup() {
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]').filter(f => !f.isGroup);
    let chars = JSON.parse(ChatDB.getItem('chat_chars') || '[]'); 
    
    let allInvitees = [...friends];
    chars.forEach(c => {
        if (!allInvitees.find(f => f.id === c.id)) {
            allInvitees.push({
                id: c.id,
                name: c.name,
                alias: c.netName || c.name,
                avatar: c.avatarUrl || '',
                isChar: true 
            });
        }
    });

    if (allInvitees.length === 0) return alert('没有可邀请的好友或角色');
    
    tempQQGroupMembers = [];
    document.getElementById('qqGroupNameInput').value = '';
    const listEl = document.getElementById('qqGroupContactList');
    listEl.innerHTML = '';
    
    allInvitees.forEach(f => {
        const item = document.createElement('label');
        item.style.cssText = 'display: flex; align-items: center; gap: 10px; padding: 10px; background: #f9f9f9; border-radius: 10px; cursor: pointer;';
        const typeTag = f.isChar ? '<span style="font-size:10px; background:#eee; color:#888; padding:2px 4px; border-radius:4px; margin-left:4px;">角色</span>' : '';
        item.innerHTML = `
            <input type="checkbox" value="${f.id}" style="width: 18px; height: 18px; accent-color: #111;" onchange="toggleQQGroupMember('${f.id}', this.checked)">
            <div style="width: 36px; height: 36px; border-radius: 8px; background-image: url('${f.avatar || ''}'); background-size: cover; background-color: #eee;"></div>
            <div style="font-size: 14px; font-weight: bold; color: #333; flex: 1;">${f.alias || f.name}${typeTag}</div>
        `;
        listEl.appendChild(item);
    });
    
    document.getElementById('qqCreateGroupModalOverlay').classList.add('show');
}

function closeQQCreateGroupModal() {
    document.getElementById('qqCreateGroupModalOverlay').classList.remove('show');
}

function toggleQQGroupMember(id, isChecked) {
    if (isChecked) {
        if (!tempQQGroupMembers.includes(id)) tempQQGroupMembers.push(id);
    } else {
        tempQQGroupMembers = tempQQGroupMembers.filter(m => m !== id);
    }
}

async function confirmCreateQQGroup() {
    const groupName = document.getElementById('qqGroupNameInput').value.trim() || '未命名群聊';
    if (tempQQGroupMembers.length === 0) return alert('请至少选择一个好友！');
    
    if (typeof showToast === 'function') showToast('正在处理角色数据...', 'loading');

    let realMembers = [qqMyOnlineId];
    let groupChars = [];
    
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let localChars = JSON.parse(ChatDB.getItem('chat_chars') || '[]');
    
    for (let id of tempQQGroupMembers) {
        let isReal = friends.find(f => f.id === id);
        if (isReal) {
            realMembers.push(id);
        } else {
            let charObj = localChars.find(c => c.id === id);
            if (charObj) {
                let avatarToSave = charObj.avatarUrl || '';
                if (avatarToSave.startsWith('data:image/')) {
                    avatarToSave = await ensureAvatarUrl(avatarToSave);
                    let cIndex = localChars.findIndex(c => c.id === charObj.id);
                    if (cIndex > -1) {
                        localChars[cIndex].avatarUrl = avatarToSave;
                        ChatDB.setItem('chat_chars', JSON.stringify(localChars));
                    }
                }
                groupChars.push({
                    charId: charObj.id,
                    inviterId: qqMyOnlineId,
                    name: charObj.name,
                    avatar: avatarToSave
                });
            }
        }
    }
    
    let groupId = 'group_' + Date.now();
    let groupNumber = Math.floor(10000000 + Math.random() * 90000000).toString();
    
    let groupObj = {
        id: groupId,
        groupNumber: groupNumber,
        name: groupName,
        alias: '',
        avatar: '',
        isGroup: true,
        members: realMembers,
        ownerId: qqMyOnlineId,
        adminIds: [],
        chars: groupChars 
    };
    friends.push(groupObj);
    ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
    
    let allPublicGroups = JSON.parse(ChatDB.getItem('qq_all_public_groups') || '[]');
    allPublicGroups.push(groupObj);
    ChatDB.setItem('qq_all_public_groups', JSON.stringify(allPublicGroups));

    realMembers.forEach(memberId => {
        if (memberId === qqMyOnlineId) return;
        publishSupabaseBroadcast("user_" + memberId, {
            senderId: qqMyOnlineId,
            type: 'group_invite', 
            groupId: groupId, 
            groupName: groupName, 
            members: realMembers,
            ownerId: qqMyOnlineId,
            adminIds: [],
            chars: groupChars
        });
    });
    
    if (typeof hideToast === 'function') hideToast(); 
    alert('群聊创建成功！');
    closeQQCreateGroupModal();
    renderQQMessageList();
    renderQQContactList();
}

