// 邀请角色进群
function openQQInviteCharModal(group) {
    if (!group.chars) group.chars = [];
    if (group.chars.some(c => c.inviterId === qqMyOnlineId)) {
        return alert('每个真实用户只能携带一个角色进群！');
    }

    const listEl = document.getElementById('qqInviteCharList');
    listEl.innerHTML = '';
    let chars = JSON.parse(ChatDB.getItem('chat_chars') || '[]');

    if (chars.length === 0) {
        listEl.innerHTML = '<div style="text-align:center; color:#aaa; font-size:12px;">本地暂无角色</div>';
    } else {
        chars.forEach(c => {
            const item = document.createElement('div');
            item.style.cssText = 'display: flex; align-items: center; gap: 10px; padding: 10px; background: #f9f9f9; border-radius: 10px; cursor: pointer;';
            item.innerHTML = `
                <div style="width: 36px; height: 36px; border-radius: 8px; background-image: url('${c.avatarUrl || ''}'); background-size: cover; background-color: #eee;"></div>
                <div style="font-size: 14px; font-weight: bold; color: #333; flex: 1;">${c.name}</div>
            `;
            item.onclick = () => confirmInviteQQGroupChar(c, group);
            listEl.appendChild(item);
        });
    }
    document.getElementById('qqInviteCharModalOverlay').classList.add('show');
}

function closeQQInviteCharModal() {
    document.getElementById('qqInviteCharModalOverlay').classList.remove('show');
}

async function confirmInviteQQGroupChar(char, group) {
    if (!group.chars) group.chars = [];
    
    if (typeof showToast === 'function') showToast('正在处理角色数据...', 'loading');
    
    let avatarToSave = char.avatarUrl || '';
    if (avatarToSave.startsWith('data:image/')) {
        avatarToSave = await ensureAvatarUrl(avatarToSave);
        let chars = JSON.parse(ChatDB.getItem('chat_chars') || '[]');
        let cIndex = chars.findIndex(c => c.id === char.id);
        if (cIndex > -1) {
            chars[cIndex].avatarUrl = avatarToSave;
            ChatDB.setItem('chat_chars', JSON.stringify(chars));
        }
    }

    group.chars.push({
        charId: char.id,
        inviterId: qqMyOnlineId,
        name: char.name,
        avatar: avatarToSave
    });

    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let gIndex = friends.findIndex(f => f.id === group.id);
    if (gIndex > -1) friends[gIndex] = group;
    ChatDB.setItem('qq_online_friends', JSON.stringify(friends));

    renderQQGroupMembers(group);
    broadcastQQGroupUpdate(group.id, { chars: group.chars });
    closeQQInviteCharModal();
    
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名"}');
    sendQQSystemMessage(group.id, `${myProfile.name} 邀请角色 ${char.name} 加入了群聊`);
    
    if (typeof hideToast === 'function') hideToast();
    alert(`已成功邀请角色 [${char.name}] 进群！`);
}

// 踢出角色
function kickQQGroupChar(charId, groupId) {
    if (confirm('确定要将该角色移出群聊吗？')) {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let group = friends.find(f => f.id === groupId);
        if (group && group.chars) {
            group.chars = group.chars.filter(c => c.charId !== charId);
            ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
            renderQQGroupMembers(group);
            broadcastQQGroupUpdate(group.id, { chars: group.chars });
        }
    }
}

