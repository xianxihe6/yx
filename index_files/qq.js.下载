// 侧边栏切换
function switchQQTab(pageId, element) {
    document.querySelectorAll('.qq-nav-item').forEach(el => el.classList.remove('active'));
    if (element) element.classList.add('active');
    
    document.querySelectorAll('.qq-page').forEach(el => el.classList.remove('active'));
    document.getElementById('qq-page-' + pageId).classList.add('active');
    
    if (pageId === 'messages') renderQQMessageList();
    if (pageId === 'contacts') renderQQContactList();
    if (pageId === 'moments') renderQQMoments();
    if (pageId === 'profile') renderQQProfile();
}

// ==========================================
// 初始化 Supabase 引擎
// ==========================================
async function initQQPeer() {
    if (supabasePresenceChannel) return; // 已初始化
    
    // 1. 获取或生成本地联机 ID
    qqMyOnlineId = ChatDB.getItem('qq_online_id');
    if (!qqMyOnlineId) {
        qqMyOnlineId = Math.floor(100000 + Math.random() * 900000).toString();
        ChatDB.setItem('qq_online_id', qqMyOnlineId);
    }
    
    let el = document.getElementById('qqMyOnlineIdText');
    if(el) el.innerText = '联机ID: ' + qqMyOnlineId;

    // 2. 将当前用户注册/更新到云端数据库
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":""}');
    try {
        const { error } = await qqSupabase.from('qq_users').upsert({
            id: String(qqMyOnlineId),
            name: myProfile.name || '未命名',
            avatar: myProfile.avatar || ''
        });
        if (error) {
            console.warn("用户上云失败(可能未建表)，但不影响在线广播:", error.message);
        } else {
            console.log("Supabase 初始化成功，当前用户已上云:", qqMyOnlineId);
        }
    } catch (e) {
        console.warn("用户上云异常:", e);
    }

    // 3. 开启在线状态感知 (Presence)
    setupSupabasePresence();

    // 4. 开启实时广播通道 (Broadcast - 用于游戏、邀请等瞬时指令)
    setupSupabaseBroadcast();

    // 5. 监听云端数据库变化 (Database Changes - 用于聊天和朋友圈)
    setupSupabaseDBListeners();

    // 6. 拉取云端公开朋友圈
    syncCloudMoments();
    
    // 7. 全局拉取离线数据（好友请求、离线消息）
    syncAllOfflineData();
    
    isInitializingQQ = false; // 初始化完成，释放锁
}

// 新增：全局拉取离线数据引擎
async function syncAllOfflineData() {
    try {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let groupIds = friends.filter(f => f.isGroup).map(f => f.id);
        
        let query = supabaseClient.from('qq_messages').select('*');
        if (groupIds.length > 0) {
            let groupIdsStr = groupIds.map(id => `"${id}"`).join(',');
            query = query.or(`receiver_id.eq.${qqMyOnlineId},group_id.in.(${groupIdsStr})`);
        } else {
            query = query.eq('receiver_id', qqMyOnlineId);
        }
        
        const { data, error } = await query.order('created_at', { ascending: false }).limit(100);
        if (data && data.length > 0) {
            let changed = false;
            // 修复：使用 for...of 替代 forEach，确保 await 按顺序执行，防止并发写入覆盖
            for (let msg of data.reverse()) {
                if (msg.msg_type === 'friend_request') {
                    let profile = JSON.parse(msg.content);
                    let requests = JSON.parse(ChatDB.getItem('qq_friend_requests') || '[]');
                    // 修复：强制转换为字符串比对
                    if (!requests.find(r => String(r.id) === String(msg.sender_id))) {
                        requests.push({ id: String(msg.sender_id), name: profile.name, avatar: profile.avatar });
                        ChatDB.setItem('qq_friend_requests', JSON.stringify(requests));
                        document.getElementById('qqContactRedDot').style.display = 'block';
                        changed = true;
                    }
                } else {
                    await handleIncomingCloudMessage(msg, true);
                }
            }
            if (changed) {
                renderQQContactList();
                renderQQMessageList();
            }
        }
    } catch (e) {
        console.warn("拉取离线数据失败", e);
    }
}

function setupSupabasePresence() {
    supabasePresenceChannel = qqSupabase.channel('qq_online_users');

    supabasePresenceChannel.on('presence', { event: 'sync' }, () => {
        const newState = supabasePresenceChannel.presenceState();
        qqOnlineStatus = {};
        for (const key in newState) {
            const users = newState[key];
            users.forEach(u => {
                qqOnlineStatus[u.user_id] = true;
            });
        }
        renderQQMessageList();
        renderQQContactList();
    });

    supabasePresenceChannel.subscribe(async (status) => {
        if (status === 'SUBSCRIBED') {
            await supabasePresenceChannel.track({ user_id: qqMyOnlineId, online_at: new Date().toISOString() });
        }
    });
}

function setupSupabaseBroadcast() {
    supabaseBroadcastChannel = qqSupabase.channel('qq_global_broadcast');

    supabaseBroadcastChannel.on('broadcast', { event: '*' }, (payload) => {
        const channel = payload.event;
        const data = payload.payload;
        
        // 过滤：只处理发给我的、公共的、或者我所在的群聊/游戏的广播
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let isMyGroup = friends.some(f => f.isGroup && channel === "group_" + f.id);

        if (channel === "user_" + qqMyOnlineId || 
            channel === "public_moments" || 
            channel === "global_search" ||
            isMyGroup ||
            channel.startsWith("game_")) {
            
            handleQQOnlineData(data.senderId, data);
        }
    }).subscribe();
}

function setupSupabaseDBListeners() {
    // 监听新消息
    supabaseClient.channel('public:qq_messages')
        .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'qq_messages' }, payload => {
            const newMsg = payload.new;
            if (newMsg.sender_id === qqMyOnlineId) return; // 防回音

            // 如果是发给我的单聊，或者是群聊
            if (newMsg.receiver_id === qqMyOnlineId || newMsg.group_id) {
                handleIncomingCloudMessage(newMsg);
            }
        })
        .subscribe();

    // 监听朋友圈新动态
    supabaseClient.channel('public:qq_moments')
        .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'qq_moments' }, payload => {
            const newMoment = payload.new;
            if (newMoment.author_id === qqMyOnlineId) return;
            handleIncomingCloudMoment(newMoment);
        })
        .subscribe();
}

// 处理云端推送来的新消息
async function handleIncomingCloudMessage(newMsg, isOfflineSync = false) {
    // 修复：强制将云端返回的 ID 转换为字符串，防止存入 localStorage 时键名不一致
    let chatId = newMsg.group_id ? String(newMsg.group_id) : String(newMsg.sender_id);
    
    let senderName = "未知用户";
    if (newMsg.group_id) {
        const { data: userData } = await supabaseClient.from('qq_users').select('name').eq('id', newMsg.sender_id).single();
        if (userData) senderName = userData.name;
    }

    let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${chatId}`) || '[]');
    let displayContent = newMsg.group_id ? `${senderName}: ${newMsg.content}` : newMsg.content;
    let msgTime = new Date(newMsg.created_at).getTime();
    
    // 去重检测：如果广播已经把这条消息加进去了，就不再重复添加
    let exists = history.find(m => Math.abs(m.timestamp - msgTime) < 5000 && m.content === displayContent);
    
    if (!exists) {
        // 角色反转：云端存的是真实发送者，对我来说是 'other'
        history.push({ 
            role: newMsg.msg_type === 'system' ? 'system' : 'other', 
            content: displayContent, 
            quote: newMsg.quote || '', 
            timestamp: msgTime, 
            senderName: senderName 
        });
        
        ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${chatId}`, JSON.stringify(history));
        incrementUnread(chatId); // 增加未读红点
        
        if (currentQQChatId === chatId && document.getElementById('qq-page-chat').classList.contains('show')) {
            renderQQChatHistory();
        } else if (!isOfflineSync) {
            renderQQMessageList();
        }
    }
}

// 处理云端推送来的朋友圈
async function handleIncomingCloudMoment(newMoment) {
    // 如果不是公开的，且不是好友，则不显示
    if (newMoment.visibility !== 'public') {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        if (!friends.find(f => f.id === newMoment.author_id)) return;
    }

    let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
    if (!moments.find(m => m.id === newMoment.id)) {
        let authorName = "未知用户";
        let authorAvatar = "";
        try {
            const { data: userData } = await qqSupabase.from('qq_users').select('name, avatar').eq('id', newMoment.author_id).single();
            if (userData) {
                authorName = userData.name;
                authorAvatar = userData.avatar;
            }
        } catch(e){}

        let formattedMoment = {
            id: newMoment.id,
            authorId: newMoment.author_id,
            name: authorName,
            avatar: authorAvatar,
            text: newMoment.content,
            image: newMoment.image_url,
            fileData: newMoment.file_url,
            fileName: newMoment.file_url ? "附件" : null,
            time: new Date(newMoment.created_at).getTime(),
            visibility: newMoment.visibility,
            likes: [],
            comments: []
        };
        moments.unshift(formattedMoment);
        moments.sort((a, b) => b.time - a.time);
        if (moments.length > 200) moments = moments.slice(0, 200);
        ChatDB.setItem('qq_moments', JSON.stringify(moments));
        if (document.getElementById('qq-page-moments').classList.contains('active')) renderQQMoments();
    }
}

// 新增：启动时同步云端公开朋友圈
async function syncCloudMoments() {
    try {
        const { data, error } = await qqSupabase.from('qq_moments')
            .select('*')
            .order('created_at', { ascending: false })
            .limit(50);
        
        if (data && data.length > 0) {
            let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
            let changed = false;
            let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
            
            for (let newMoment of data) {
                // 修复：强制转换为字符串比对
                if (newMoment.visibility !== 'public' && String(newMoment.author_id) !== String(qqMyOnlineId)) {
                    if (!friends.find(f => String(f.id) === String(newMoment.author_id))) continue;
                }
                
                // 修复：强制转换为字符串比对
                if (!moments.find(m => String(m.id) === String(newMoment.id))) {
                    let authorName = "未知用户";
                    let authorAvatar = "";
                    try {
                        const { data: userData } = await qqSupabase.from('qq_users').select('name, avatar').eq('id', newMoment.author_id).single();
                        if (userData) {
                            authorName = userData.name;
                            authorAvatar = userData.avatar;
                        }
                    } catch(e){}

                    moments.push({
                        id: String(newMoment.id),
                        authorId: String(newMoment.author_id),
                        name: authorName,
                        avatar: authorAvatar,
                        text: newMoment.content,
                        image: newMoment.image_url,
                        fileData: newMoment.file_url,
                        fileName: newMoment.file_url ? "附件" : null,
                        time: newMoment.created_at ? new Date(newMoment.created_at).getTime() : Date.now(), // 修复：防止 created_at 为空导致时间变成 NaN 无法排序显示
                        visibility: newMoment.visibility,
                        likes: [],
                        comments: []
                    });
                    changed = true;
                }
            }
            
            if (changed) {
                moments.sort((a, b) => b.time - a.time);
                if (moments.length > 200) moments = moments.slice(0, 200);
                ChatDB.setItem('qq_moments', JSON.stringify(moments));
                if (document.getElementById('qq-page-moments').classList.contains('active')) {
                    renderQQMoments();
                }
            }
        }
    } catch (e) {
        console.warn("拉取云端朋友圈失败", e);
    }
}

function addQQOnlineFriend(peerId, name, avatar = '', isGroup = false, members = []) {
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let existing = friends.find(f => f.id === peerId);
    if (!existing) {
        friends.push({ id: peerId, name: name, alias: '', avatar: avatar, isGroup: isGroup, members: members });
        ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
    }
}

// 处理接收瞬时广播数据 (邀请、游戏、点赞等)
function handleQQOnlineData(peerId, data) {
    if (data.senderId === qqMyOnlineId) return;

    if (data.type === 'moment_action') {
        let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
        let actionData = data.actionData;
        let changed = false;
        
        if (actionData.action === 'delete') {
            let len = moments.length;
            moments = moments.filter(m => m.id !== actionData.momentId);
            if (moments.length !== len) changed = true;
        } else {
            let moment = moments.find(m => m.id === actionData.momentId);
            if (moment) {
                if (actionData.action === 'like') {
                    if (!moment.likes) moment.likes = [];
                    if (actionData.isLike) {
                        if (!moment.likes.find(l => l.id === actionData.user.id)) {
                            moment.likes.push(actionData.user);
                            changed = true;
                        }
                    } else {
                        let idx = moment.likes.findIndex(l => l.id === actionData.user.id);
                        if (idx > -1) {
                            moment.likes.splice(idx, 1);
                            changed = true;
                        }
                    }
                } else if (actionData.action === 'comment') {
                    if (!moment.comments) moment.comments = [];
                    if (!moment.comments.find(c => c.id === actionData.comment.id)) {
                        moment.comments.push(actionData.comment);
                        changed = true;
                    }
                }
            }
        }
        
        if (changed) {
            ChatDB.setItem('qq_moments', JSON.stringify(moments));
            if (document.getElementById('qq-page-moments').classList.contains('active')) renderQQMoments();
        }
    } else if (data.type === 'update_profile') {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let friend = friends.find(f => f.id === peerId);
        if (friend) {
            friend.name = data.profile.name;
            friend.avatar = data.profile.avatar;
            ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
            renderQQMessageList();
            renderQQContactList();
            if (currentQQChatId === peerId) {
                document.getElementById('qqChatTitle').innerText = friend.alias || friend.name;
                renderQQChatHistory();
            }
        }
    } else if (data.type === 'friend_request') {
        let requests = JSON.parse(ChatDB.getItem('qq_friend_requests') || '[]');
        if (!requests.find(r => r.id === peerId)) {
            requests.push({ id: peerId, name: data.profile.name, avatar: data.profile.avatar });
            ChatDB.setItem('qq_friend_requests', JSON.stringify(requests));
            document.getElementById('qqContactRedDot').style.display = 'block';
            if (document.getElementById('qq-page-contacts').classList.contains('active')) {
                renderQQContactList();
            }
        }
    } else if (data.type === 'friend_accept') {
        addQQOnlineFriend(peerId, data.profile.name, data.profile.avatar);
        alert(`${data.profile.name} 已同意你的好友请求！`);
        renderQQContactList();
        renderQQMessageList();
    } else if (data.type === 'group_join_apply') {
        let requests = JSON.parse(ChatDB.getItem('qq_group_requests') || '[]');
        if (!requests.find(r => r.userId === peerId && r.groupId === data.groupId)) {
            requests.push({ 
                userId: peerId, 
                name: data.profile.name, 
                avatar: data.profile.avatar, 
                groupId: data.groupId, 
                groupName: data.groupName 
            });
            ChatDB.setItem('qq_group_requests', JSON.stringify(requests));
            document.getElementById('qqContactRedDot').style.display = 'block';
            if (document.getElementById('qq-page-contacts').classList.contains('active')) {
                renderQQContactList();
            }
        }
    } else if (data.type === 'group_join_approved') {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        if (!friends.find(f => f.id === data.group.id)) {
            friends.push(data.group);
            ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
        }
        alert(`管理员已同意你加入群聊: ${data.group.name}`);
        renderQQMessageList();
        renderQQContactList();
    } else if (data.type === 'group_invite') {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        if (!friends.find(f => f.id === data.groupId)) {
            friends.push({
                id: data.groupId, name: data.groupName, alias: '', avatar: '', isGroup: true,
                members: data.members, ownerId: data.ownerId, adminIds: data.adminIds || [], chars: data.chars || []
            });
            ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
        }
        renderQQMessageList();
        renderQQContactList();
    } else if (data.type === 'update_group_info') {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let group = friends.find(f => f.id === data.groupId);
        if (group) {
            if (data.groupName) group.name = data.groupName;
            if (data.avatar) group.avatar = data.avatar;
            if (data.members) group.members = data.members;
            if (data.adminIds) group.adminIds = data.adminIds;
            if (data.chars) group.chars = data.chars;
            ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
            
            renderQQMessageList();
            renderQQContactList();
            
            if (currentQQChatId === data.groupId) {
                document.getElementById('qqChatTitle').innerText = group.name;
                if (document.getElementById('qqChatSettingsPanel').style.display === 'flex') {
                    document.getElementById('qqGroupNameDisplay').innerText = group.name;
                    if (data.avatar) {
                        document.getElementById('qqGroupAvatarPreview').style.backgroundImage = `url(${data.avatar})`;
                        document.getElementById('qqGroupAvatarPreview').innerText = '';
                    }
                    renderQQGroupMembers(group);
                }
            }
        }
    } else if (data.type === 'group_kick') {
        if (data.kickedId === qqMyOnlineId) {
            let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
            friends = friends.filter(f => f.id !== data.groupId);
            ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
            ChatDB.removeItem(`qq_online_chat_${qqMyOnlineId}_${data.groupId}`);
            
            if (currentQQChatId === data.groupId) closeQQChat();
            renderQQMessageList();
            renderQQContactList();
            alert(`您已被移出群聊: ${data.groupName}`);
        }
    } else if (data.type === 'gomoku_join_req') {
        if (gomokuCurrentGameId === data.gameId && gomokuHostId === qqMyOnlineId) {
            if (!gomokuPlayerWhite) {
                gomokuPlayerWhite = data.peerId;
                publishSupabaseBroadcast("user_" + data.peerId, { 
                    senderId: qqMyOnlineId, 
                    type: 'gomoku_join_res', 
                    role: 2, 
                    gameId: data.gameId, 
                    blackId: gomokuPlayerBlack, 
                    whiteId: gomokuPlayerWhite 
                });
                broadcastQQGroupGomoku({ type: 'gomoku_update_players', gameId: data.gameId, blackId: gomokuPlayerBlack, whiteId: gomokuPlayerWhite });
                updateGomokuLoadingUI();
            } else {
                if (!gomokuSpectators.includes(data.peerId)) gomokuSpectators.push(data.peerId);
                publishSupabaseBroadcast("user_" + data.peerId, { 
                    senderId: qqMyOnlineId, 
                    type: 'gomoku_join_res', 
                    role: 3, 
                    gameId: data.gameId, 
                    blackId: gomokuPlayerBlack, 
                    whiteId: gomokuPlayerWhite, 
                    board: gomokuBoard, 
                    currentTurn: gomokuCurrentTurn 
                });
            }
        }
    } else if (data.type === 'gomoku_join_res') {
        if (gomokuCurrentGameId === data.gameId) {
            gomokuPlayerBlack = data.blackId;
            gomokuPlayerWhite = data.whiteId;
            if (data.role === 2) {
                openGomokuLoading(2);
            } else if (data.role === 3) {
                gomokuMyColor = 3; 
                gomokuBoard = data.board || Array(15).fill(0).map(() => Array(15).fill(0));
                gomokuCurrentTurn = data.currentTurn || 1;
                document.getElementById('gomokuLoadingPanel').style.display = 'none';
                openGomokuGame(3);
                document.getElementById('gomokuStatusText').innerText = '观战中...';
                document.getElementById('gomokuStatusText').style.color = '#888';
                alert("你已作为观战者加入游戏");
            }
        }
    } else if (data.type === 'gomoku_update_players') {
        if (gomokuCurrentGameId === data.gameId) {
            gomokuPlayerBlack = data.blackId;
            gomokuPlayerWhite = data.whiteId;
            updateGomokuLoadingUI();
        }
    } else if (data.type === 'gomoku_move') {
        if (document.getElementById('gomokuPanel').style.display === 'flex') {
            receiveGomokuMove(data.r, data.c, data.color);
        }
    } else if (data.type === 'gomoku_restart') {
        if (document.getElementById('gomokuPanel').style.display === 'flex') {
            alert('对方重新开始了游戏！');
            initGomokuGame(gomokuMyColor === 1 ? 2 : 1); 
        }
    } else if (data.type === 'gomoku_effect') {
        if (document.getElementById('gomokuPanel').style.display === 'flex') {
            showGomokuEffect(data.emoji);
        }
    } else if (data.type === 'gomoku_ready') {
        if (data.gameId === gomokuCurrentGameId) {
            if (data.peerId === gomokuPlayerWhite) {
                gomokuOppReady = true;
                if (gomokuMyColor === 1) {
                    document.getElementById('gomokuLoadOppStatus').innerText = '已准备';
                    document.getElementById('gomokuLoadOppStatus').style.color = '#34c759';
                }
            } else if (data.peerId === gomokuPlayerBlack) {
                gomokuOppReady = true;
                if (gomokuMyColor === 2) {
                    document.getElementById('gomokuLoadMyStatus').innerText = '已准备';
                    document.getElementById('gomokuLoadMyStatus').style.color = '#34c759';
                }
            }
            checkGomokuStart();
        }
    } else if (data.type === 'gomoku_danmu') {
        if (document.getElementById('gomokuPanel').style.display === 'flex') {
            showGomokuDanmu(data.senderName, data.text);
        }
    } else if (data.type === 'search_req') {
        if (data.searchType === 'friend' && data.keyword === qqMyOnlineId) {
            let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":""}');
            publishSupabaseBroadcast("user_" + data.senderId, {
                senderId: qqMyOnlineId,
                type: 'search_res',
                searchType: 'friend',
                resultData: { id: qqMyOnlineId, name: myProfile.name, avatar: myProfile.avatar }
            });
        } else if (data.searchType === 'group') {
            let allPublicGroups = JSON.parse(ChatDB.getItem('qq_all_public_groups') || '[]');
            let foundGroup = allPublicGroups.find(g => g.groupNumber === data.keyword || g.id === data.keyword);
            if (foundGroup) {
                publishSupabaseBroadcast("user_" + data.senderId, {
                    senderId: qqMyOnlineId,
                    type: 'search_res',
                    searchType: 'group',
                    resultData: foundGroup
                });
            }
        }
    } else if (data.type === 'search_res') {
        if (typeof hideToast === 'function') hideToast();
        if (window.searchTimeout) clearTimeout(window.searchTimeout);
        showQQSearchResultModal(data.resultData, data.searchType);
    } else if (data.type === 'chat') {
        // 处理单聊 P2P 消息
        let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${data.senderId}`) || '[]');
        // 去重检测
        if (!history.find(m => m.timestamp === data.timestamp && m.content === data.content)) {
            history.push({
                role: 'other',
                content: data.content,
                quote: data.quote || '',
                timestamp: data.timestamp || Date.now(),
                senderName: data.senderName || '',
                senderId: data.charId || data.senderId
            });
            ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${data.senderId}`, JSON.stringify(history));
            incrementUnread(data.senderId); // 增加未读红点
            
            if (currentQQChatId === data.senderId && document.getElementById('qq-page-chat').classList.contains('show')) {
                renderQQChatHistory();
            } else {
                renderQQMessageList();
            }
        }
    } else if (data.type === 'group_chat') {
        // 处理群聊 P2P 消息
        let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${data.groupId}`) || '[]');
        // 去重检测
        if (!history.find(m => m.timestamp === data.timestamp && m.content === data.content)) {
            let displayContent = data.senderName ? `${data.senderName}: ${data.content}` : data.content;
            // 如果内容已经包含了名字前缀，就不再重复添加
            if (data.content.startsWith(data.senderName + ':') || data.content.startsWith(data.senderName + '：')) {
                displayContent = data.content;
            }
            
            history.push({
                role: 'other',
                content: displayContent,
                quote: data.quote || '',
                timestamp: data.timestamp || Date.now(),
                senderName: data.senderName || '',
                senderId: data.charId || data.senderId
            });
            ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${data.groupId}`, JSON.stringify(history));
            incrementUnread(data.groupId); // 增加未读红点
            
            if (currentQQChatId === data.groupId && document.getElementById('qq-page-chat').classList.contains('show')) {
                renderQQChatHistory();
            } else {
                renderQQMessageList();
            }
        }
    } else if (data.type === 'new_moment') {
        let newMoment = data.moment;
        if (newMoment.visibility !== 'public') {
            let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
            if (!friends.find(f => f.id === newMoment.authorId)) return;
        }
        let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
        if (!moments.find(m => m.id === newMoment.id)) {
            moments.unshift(newMoment);
            moments.sort((a, b) => b.time - a.time);
            if (moments.length > 200) moments = moments.slice(0, 200);
            ChatDB.setItem('qq_moments', JSON.stringify(moments));
            if (document.getElementById('qq-page-moments').classList.contains('active')) renderQQMoments();
        }
    }
}

