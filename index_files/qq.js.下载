async function handleQQChatImageUpload(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    try {
        const imageUrl = await uploadImageToUrl(file);
        const imgContent = `<img src="${imageUrl}" style="max-width: 100%; border-radius: 8px; cursor: pointer; -webkit-touch-callout: none; -webkit-user-select: none;" onclick="event.stopPropagation(); safeOpenImagePreview('${imageUrl}')">`;
        sendQQImageMessage(imgContent);
    } catch (error) {
        alert(error.message);
    } finally {
        event.target.value = ''; 
    }
}

async function sendQQImageMessage(content) {
    if (!currentQQChatId) return;
    
    let nowTime = Date.now();
    
    // 1. 本地渲染
    let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`) || '[]');
    history.push({ role: 'me', content: content, timestamp: nowTime });
    ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`, JSON.stringify(history));
    
    renderQQChatHistory();
    renderQQMessageList();

    // 2. 写入 Supabase 数据库
    try {
        const msgData = { sender_id: qqMyOnlineId, content: content, msg_type: 'image' };
        if (isGroupChat) msgData.group_id = currentQQChatId;
        else msgData.receiver_id = currentQQChatId;
        await qqSupabase.from('qq_messages').insert(msgData);
    } catch (error) {
        console.error("图片/文件发送到云端失败:", error);
    }

    // 3. 增加：实时广播发送
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名"}');
    if (isGroupChat) {
        publishSupabaseBroadcast("group_" + currentQQChatId, {
            senderId: qqMyOnlineId,
            type: 'group_chat',
            groupId: currentQQChatId,
            senderName: myProfile.name,
            content: content,
            quote: '',
            timestamp: nowTime
        });
    } else {
        publishSupabaseBroadcast("user_" + currentQQChatId, {
            senderId: qqMyOnlineId,
            type: 'chat',
            senderName: myProfile.name,
            content: content,
            quote: '',
            timestamp: nowTime
        });
    }
}

