function deleteQQFriend() {
    if (confirm("确定要删除该好友/退出群聊吗？")) {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        friends = friends.filter(f => f.id !== currentQQChatId);
