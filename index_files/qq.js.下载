function actionQQQuote() {
    if (!qqCurrentMenuMsg) return;
    qqQuoteContent = `${qqCurrentMenuMsg.senderName}: ${qqCurrentMenuMsg.content}`;
    
    document.getElementById('qqQuotePreviewBar').style.display = 'block';
    document.getElementById('qqQuotePreviewText').innerText = qqQuoteContent;
    
    closeQQBubbleMenu();
    document.getElementById('qqChatInput').focus();
}

function cancelQQQuote() {
    qqQuoteContent = '';
    document.getElementById('qqQuotePreviewBar').style.display = 'none';
    document.getElementById('qqQuotePreviewText').innerText = '';
}

function actionQQAt() {
    if (!qqCurrentMenuMsg) return;
    const inputEl = document.getElementById('qqChatInput');
    inputEl.value += `@${qqCurrentMenuMsg.senderName} `;
    inputEl.focus();
    closeQQBubbleMenu();
}

function actionQQDeleteMsg() {
    if (!qqCurrentMenuMsg) return;
    if (confirm('确定删除这条消息吗？(仅删除本地记录)')) {
        let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`) || '[]');
        history = history.filter(m => m.timestamp.toString() !== qqCurrentMenuMsg.timestamp.toString());
        ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`, JSON.stringify(history));
        renderQQChatHistory();
    }
    closeQQBubbleMenu();
}

function actionQQMultiSelect() {
    closeQQBubbleMenu();
    qqMultiSelectMode = true;
    qqSelectedMsgs.clear();
    document.getElementById('qqMultiActionBar').style.display = 'flex';
    renderQQChatHistory(); 
}

function exitQQMultiSelect() {
    qqMultiSelectMode = false;
    qqSelectedMsgs.clear();
    document.getElementById('qqMultiActionBar').style.display = 'none';
    renderQQChatHistory(); 
}

function toggleQQMsgSelect(timestamp, element) {
    if (!qqMultiSelectMode) return;
    const tsStr = timestamp.toString();
    if (qqSelectedMsgs.has(tsStr)) {
        qqSelectedMsgs.delete(tsStr);
        element.classList.remove('selected');
    } else {
        qqSelectedMsgs.add(tsStr);
        element.classList.add('selected');
    }
}

function deleteSelectedQQMessages() {
    if (qqSelectedMsgs.size === 0) return alert('请先选择要删除的消息');
    if (confirm(`确定删除选中的 ${qqSelectedMsgs.size} 条消息吗？(仅删除本地记录)`)) {
        let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`) || '[]');
        history = history.filter(m => !qqSelectedMsgs.has(m.timestamp.toString()));
        ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`, JSON.stringify(history));
        exitQQMultiSelect();
    }
}

window.openQQGroupAvatarTypeModal = function() {
    document.getElementById('qqGroupAvatarTypeModalOverlay').classList.add('show');
};

window.closeQQGroupAvatarTypeModal = function() {
    document.getElementById('qqGroupAvatarTypeModalOverlay').classList.remove('show');
};

window.openQQGroupAvatarUrlModal = function() {
    closeQQGroupAvatarTypeModal();
    document.getElementById('qqGroupAvatarUrlInput').value = '';
    document.getElementById('qqGroupAvatarUrlModalOverlay').classList.add('show');
};

window.closeQQGroupAvatarUrlModal = function() {
    document.getElementById('qqGroupAvatarUrlModalOverlay').classList.remove('show');
};

window.confirmQQGroupAvatarUrl = function() {
    const url = document.getElementById('qqGroupAvatarUrlInput').value.trim();
    if (!url) return alert('请输入图片 URL');
    
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let group = friends.find(f => f.id === currentQQChatId);
    if (group) {
        group.avatar = url;
        ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
        document.getElementById('qqGroupAvatarPreview').style.backgroundImage = `url(${url})`;
        document.getElementById('qqGroupAvatarPreview').innerText = '';
        renderQQMessageList();
        
        broadcastQQGroupUpdate(group.id, { avatar: url });
    }
    closeQQGroupAvatarUrlModal();
};

window.openQQImagePreview = function(url) {
    const imgEl = document.getElementById('qqImagePreviewImg');
    if (imgEl) imgEl.src = url;
    const overlay = document.getElementById('qqImagePreviewOverlay');
    if (overlay) overlay.classList.add('show');
};

window.closeQQImagePreview = function() {
    const overlay = document.getElementById('qqImagePreviewOverlay');
    if (overlay) overlay.classList.remove('show');
    const imgEl = document.getElementById('qqImagePreviewImg');
    if (imgEl) imgEl.src = '';
};

// 终极安全图片预览函数 (防报错)
window.safeOpenImagePreview = function(url) {
    const imgEl = document.getElementById('qqImagePreviewImg');
    const overlay = document.getElementById('qqImagePreviewOverlay');
    if (imgEl && overlay) {
        imgEl.src = url;
        overlay.classList.add('show');
    } else {
        // 如果找不到，动态创建一个全屏预览层，绝对不会报错
        let dynamicOverlay = document.getElementById('dynamicSafeImagePreview');
        if (!dynamicOverlay) {
            dynamicOverlay = document.createElement('div');
            dynamicOverlay.id = 'dynamicSafeImagePreview';
            dynamicOverlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:#000; z-index:99999; display:flex; flex-direction:column;';
            
            const topBar = document.createElement('div');
            topBar.style.cssText = 'width: 100%; padding: calc(20px + env(safe-area-inset-top)) 20px 10px; display: flex; justify-content: flex-start; position: absolute; top: 0; left: 0; z-index: 10;';
            
            const closeBtn = document.createElement('div');
            closeBtn.style.cssText = 'width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; justify-content: center; align-items: center; cursor: pointer; backdrop-filter: blur(5px);';
            closeBtn.innerHTML = '<svg viewBox="0 0 24 24" width="20" height="20" stroke="#fff" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>';
            closeBtn.onclick = function(e) { e.stopPropagation(); dynamicOverlay.style.display = 'none'; };
            topBar.appendChild(closeBtn);
            
            const imgContainer = document.createElement('div');
            imgContainer.style.cssText = 'flex: 1; width: 100%; display: flex; justify-content: center; align-items: center; overflow: hidden;';
            
            const img = document.createElement('img');
            img.id = 'dynamicSafeImagePreviewImg';
            img.style.cssText = 'max-width: 100%; max-height: 100%; object-fit: contain;';
            imgContainer.appendChild(img);
            
            dynamicOverlay.appendChild(topBar);
            dynamicOverlay.appendChild(imgContainer);
            document.body.appendChild(dynamicOverlay);
        }
        document.getElementById('dynamicSafeImagePreviewImg').src = url;
        dynamicOverlay.style.display = 'flex';
    }
};
