// 删除朋友圈
function deleteQQMoment(id) {
    if (confirm('确定删除这条动态吗？')) {
        let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
        moments = moments.filter(m => m.id !== id);
        ChatDB.setItem('qq_moments', JSON.stringify(moments));
        renderQQMoments();
        broadcastQQMomentAction({ action: 'delete', momentId: id });
    }
}

// 点赞/取消点赞
function likeQQMoment(id) {
    let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
    let moment = moments.find(m => m.id === id);
    if (!moment) return;
    
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名"}');
    if (!moment.likes) moment.likes = [];
    
    let index = moment.likes.findIndex(l => l.id === qqMyOnlineId);
    let isLike = false;
    if (index > -1) {
        moment.likes.splice(index, 1); 
    } else {
        moment.likes.push({ id: qqMyOnlineId, name: myProfile.name }); 
        isLike = true;
    }
    
    ChatDB.setItem('qq_moments', JSON.stringify(moments));
    renderQQMoments();
    broadcastQQMomentAction({ action: 'like', momentId: id, isLike: isLike, user: { id: qqMyOnlineId, name: myProfile.name } });
}

// 评论
function commentQQMoment(id) {
    let content = prompt('请输入评论内容:');
    if (!content || !content.trim()) return;
    
    let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
    let moment = moments.find(m => m.id === id);
    if (!moment) return;
    
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名"}');
    if (!moment.comments) moment.comments = [];
    
    let commentObj = { id: Date.now().toString(), authorId: qqMyOnlineId, name: myProfile.name, content: content.trim(), time: Date.now() };
    moment.comments.push(commentObj);
    
    ChatDB.setItem('qq_moments', JSON.stringify(moments));
    renderQQMoments();
    broadcastQQMomentAction({ action: 'comment', momentId: id, comment: commentObj });
}

