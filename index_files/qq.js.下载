// 执行搜索并唤起韩系弹窗
window.executeQQSearch = async function(type) {
    const keyword = document.getElementById('qqSearchInput').value.trim();
    document.getElementById('qqSearchDropdown').style.display = 'none';
    document.getElementById('qqSearchInput').value = '';
    
    if (!keyword || keyword === qqMyOnlineId) return;

    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');

    if (type === 'group') {
        let allPublicGroups = JSON.parse(ChatDB.getItem('qq_all_public_groups') || '[]');
        let foundGroup = allPublicGroups.find(g => g.groupNumber === keyword || g.id === keyword);
        
        if (foundGroup) {
            if (friends.find(f => f.id === foundGroup.id)) {
                alert("你已经在该群聊中了");
                return;
            }
            showQQSearchResultModal(foundGroup, 'group');
            return;
        }
    } else {
        if (friends.find(f => f.id === keyword)) {
            alert("对方已经是你的好友了");
            return;
        }
    }

    // 如果本地没找到，尝试数据库查询 + 广播查询双管齐下
    if (typeof showToast === 'function') showToast('正在全网搜索...', 'loading');
    
    let foundInDb = false;
    if (type === 'friend') {
        try {
            const { data: userData, error } = await qqSupabase.from('qq_users').select('*').eq('id', keyword).single();
            if (userData) {
                if (typeof hideToast === 'function') hideToast();
                showQQSearchResultModal(userData, 'friend');
                foundInDb = true;
                return;
            }
        } catch (e) {
            console.warn("数据库查询失败，尝试广播查询...");
        }
    } else if (type === 'group') {
        try {
            // 新增：查询云端群聊数据库 (支持群号或群ID搜索)
            const { data: groupData, error } = await qqSupabase.from('qq_groups').select('*').or(`groupNumber.eq.${keyword},id.eq.${keyword}`).single();
            if (groupData) {
                if (typeof hideToast === 'function') hideToast();
                // 组装成前端需要的格式
                let formattedGroup = {
                    id: groupData.id,
                    groupNumber: groupData.groupNumber,
                    name: groupData.name,
                    avatar: groupData.avatar,
                    ownerId: groupData.ownerId,
                    isGroup: true
                };
                showQQSearchResultModal(formattedGroup, 'group');
                foundInDb = true;
                return;
            }
        } catch (e) {
            console.warn("数据库查询群聊失败，尝试广播查询...");
        }
    }

    if (!foundInDb) {
        // 发送全局广播寻找 (P2P 搜索，无需建表)
        publishSupabaseBroadcast("global_search", {
            senderId: qqMyOnlineId,
            type: 'search_req',
            searchType: type,
            keyword: keyword
        });

        // 设置超时
        window.searchTimeout = setTimeout(() => {
            if (typeof hideToast === 'function') hideToast();
            alert(type === 'group' ? '未找到该群聊，请检查群号是否正确，或确保群主在线' : '未找到该用户，请检查联机ID是否正确，或确保对方在线');
        }, 3000);
    }
};

let currentQQSearchTarget = null;

window.showQQSearchResultModal = function(data, type) {
    currentQQSearchTarget = { data, type };
    
    const avatarEl = document.getElementById('qqSearchResAvatar');
    const nameEl = document.getElementById('qqSearchResName');
    const idEl = document.getElementById('qqSearchResId');
    const btnEl = document.getElementById('qqSearchResBtn');

    if (data.avatar) {
        avatarEl.style.backgroundImage = `url('${data.avatar}')`;
        avatarEl.innerText = '';
    } else {
        avatarEl.style.backgroundImage = 'none';
        avatarEl.innerText = type === 'group' ? '群' : data.name.charAt(0);
        avatarEl.style.backgroundColor = type === 'group' ? '#f4f4f4' : '#111';
        avatarEl.style.color = type === 'group' ? '#111' : '#fff';
    }

    nameEl.innerText = data.name;
    idEl.innerText = type === 'group' ? `群号: ${data.groupNumber || data.id}` : `联机ID: ${data.id}`;
    
    if (type === 'group') {
        btnEl.innerText = '申请加入群聊';
        btnEl.onclick = sendQQGroupRequestFromModal;
    } else {
        btnEl.innerText = '申请加为好友';
        btnEl.onclick = sendQQFriendRequestFromModal;
    }

    document.getElementById('qqSearchResultModalOverlay').classList.add('show');
};

window.closeQQSearchResultModal = function() {
    document.getElementById('qqSearchResultModalOverlay').classList.remove('show');
    currentQQSearchTarget = null;
};

window.sendQQFriendRequestFromModal = async function() {
    if (!currentQQSearchTarget) return;
    
    let targetId = currentQQSearchTarget.data.id;
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":""}');
    
    if (myProfile.avatar && myProfile.avatar.startsWith('data:image/')) {
        myProfile.avatar = await ensureAvatarUrl(myProfile.avatar);
        ChatDB.setItem('qq_my_profile', JSON.stringify(myProfile));
    }

    // 1. 在线广播
    publishSupabaseBroadcast("user_" + targetId, {
        senderId: qqMyOnlineId,
        type: 'friend_request',
        profile: myProfile
    });

    // 2. 离线数据库存储 (保证对方离线也能收到)
    try {
        await supabaseClient.from('qq_messages').insert({
            sender_id: qqMyOnlineId,
            receiver_id: targetId,
            content: JSON.stringify(myProfile),
            msg_type: 'friend_request'
        });
    } catch(e) {}
    
    alert("已发送好友请求");
    closeQQSearchResultModal();
};

window.sendQQGroupRequestFromModal = async function() {
    if (!currentQQSearchTarget) return;
    
    let foundGroup = currentQQSearchTarget.data;
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":""}');
    
    if (myProfile.avatar && myProfile.avatar.startsWith('data:image/')) {
        myProfile.avatar = await ensureAvatarUrl(myProfile.avatar);
        ChatDB.setItem('qq_my_profile', JSON.stringify(myProfile));
    }

    publishSupabaseBroadcast("user_" + foundGroup.ownerId, {
        senderId: qqMyOnlineId,
        type: 'group_join_apply',
        groupId: foundGroup.id,
