// 聊天室逻辑
let qqChatDisplayCount = 50; 

function openQQChat(chatId, chatName, isGroup) {
    currentQQChatId = chatId;
    isGroupChat = isGroup;
    qqChatDisplayCount = 50; 
    document.getElementById('qqChatTitle').innerText = chatName;
    document.getElementById('qq-page-chat').classList.add('show');
    document.getElementById('qqChatSettingsPanel').style.display = 'none';
    
    const aiBtn = document.getElementById('qqAiReplyBtn');
    if (aiBtn) {
        aiBtn.style.display = 'flex';
    }

    clearUnread(chatId); // 清除未读红点
    renderQQChatHistory();
    
    // 新增：打开聊天窗口时，自动拉取云端的离线消息
    syncCloudMessages(chatId, isGroup);
}

// 新增：同步云端离线消息的专属函数
async function syncCloudMessages(chatId, isGroup) {
    try {
        let query = supabaseClient.from('qq_messages').select('*');
        if (isGroup) {
            query = query.eq('group_id', chatId);
        } else {
            // 找我和对方的单聊记录
            query = query.or(`and(sender_id.eq.${qqMyOnlineId},receiver_id.eq.${chatId}),and(sender_id.eq.${chatId},receiver_id.eq.${qqMyOnlineId})`);
        }
        
        // 拉取最近的 50 条记录
        const { data, error } = await query.order('created_at', { ascending: false }).limit(50);
        if (data && data.length > 0) {
            let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${chatId}`) || '[]');
            let changed = false;
            
            // Supabase 降序拉取，需要反转回升序
            data.reverse().forEach(msg => {
                let msgTime = new Date(msg.created_at).getTime();
                let displayContent = msg.content;
                let senderName = "未知";
                
                // 去重检测：如果本地已经有这条消息，就不添加
                let exists = history.find(m => Math.abs(m.timestamp - msgTime) < 5000 && m.content === displayContent);
                if (!exists) {
                    history.push({
                        // 修复：强制转换为字符串比对，防止数字 ID 导致自己发的消息被识别为 other
                        role: String(msg.sender_id) === String(qqMyOnlineId) ? 'me' : (msg.msg_type === 'system' ? 'system' : 'other'),
                        content: displayContent,
                        quote: msg.quote || '',
                        timestamp: msgTime,
                        senderName: senderName
                    });
                    changed = true;
                }
            });
            
            if (changed) {
                // 重新按时间排序并保存
                history.sort((a, b) => a.timestamp - b.timestamp);
                ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${chatId}`, JSON.stringify(history));
                if (currentQQChatId === chatId) renderQQChatHistory();
                renderQQMessageList();
            }
        }
    } catch (e) {
        console.warn("拉取云端离线记录失败", e);
    }
}

function closeQQChat() {
    currentQQChatId = null;
    document.getElementById('qq-page-chat').classList.remove('show');
}

// 格式化时间戳的辅助函数
function formatQQTime(ts) {
    let d = new Date(ts);
    let hours = d.getHours().toString().padStart(2, '0');
    let mins = d.getMinutes().toString().padStart(2, '0');
    let month = d.getMonth() + 1;
    let date = d.getDate();
    return `${month}月${date}日 ${hours}:${mins}`;
}

function renderQQChatHistory(keepScroll = false) {
    const historyEl = document.getElementById('qqChatHistory');
    if (!historyEl) return;
    
    const oldScrollHeight = historyEl.scrollHeight;
    const oldScrollTop = historyEl.scrollTop;
    
    historyEl.innerHTML = '';
    let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`) || '[]');
    
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":""}');
    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let friend = friends.find(f => f.id === currentQQChatId);
    
    const startIndex = Math.max(0, history.length - qqChatDisplayCount);
    const renderHistory = history.slice(startIndex);

    if (startIndex > 0) {
        const loadMoreBtn = document.createElement('div');
        loadMoreBtn.style.cssText = 'text-align: center; padding: 15px 0; color: #576b95; font-size: 13px; cursor: pointer; font-weight: bold;';
        loadMoreBtn.innerText = '点击加载更多历史记录';
        loadMoreBtn.onclick = () => {
            qqChatDisplayCount += 50;
            renderQQChatHistory(true);
        };
        historyEl.appendChild(loadMoreBtn);
    }
    
    let lastTime = 0;
    
    renderHistory.forEach(msg => {
        // 增加时间戳显示 (间隔大于5分钟)
        if (msg.timestamp - lastTime > 5 * 60 * 1000) {
            const timeRow = document.createElement('div');
            timeRow.className = 'chat-time';
            timeRow.innerText = formatQQTime(msg.timestamp);
            historyEl.appendChild(timeRow);
            lastTime = msg.timestamp;
        }
        if (msg.role === 'system') {
            const row = document.createElement('div');
            row.style.cssText = 'width: 100%; display: flex; justify-content: center; margin: 10px 0;';
            row.innerHTML = `<div style="background: rgba(0,0,0,0.1); color: #888; font-size: 11px; padding: 4px 10px; border-radius: 10px;">${msg.content}</div>`;
            historyEl.appendChild(row);
            return;
        }

        const isMe = msg.role === 'me';
        const row = document.createElement('div');
        row.className = `qq-msg-row ${isMe ? 'me' : 'other'}`;
        
        let senderNameHtml = '';
        let displayContent = msg.content;
        let senderName = msg.senderName || '';
        
        if (isGroupChat && !isMe) {
            const match = msg.content.match(/^([^<:：]+)[:：]\s*(.*)$/);
            if (match) {
                senderName = match[1];
                displayContent = match[2]; 
            }
            if (senderName) {
                senderNameHtml = `<div style="font-size: 11px; color: #888; margin-bottom: 4px; margin-left: 4px;">${senderName}</div>`;
            }
        }

        let avatarUrl = isMe ? myProfile.avatar : (friend ? friend.avatar : '');
        let fallbackText = isMe ? (myProfile.name ? myProfile.name.charAt(0) : '我') : (friend ? (friend.alias || friend.name).charAt(0) : '友');
        
        if (isGroupChat && !isMe && senderName && friend) {
            let foundChar = null;
            if (msg.senderId) {
                foundChar = friend.chars ? friend.chars.find(c => c.charId === msg.senderId) : null;
            }
            if (!foundChar) {
                foundChar = friend.chars ? friend.chars.find(c => c.name === senderName) : null;
            }

            if (foundChar) {
                avatarUrl = foundChar.avatar;
                fallbackText = foundChar.name.charAt(0);
            } else {
                let foundUser = friends.find(f => (f.alias || f.name) === senderName);
                if (foundUser) {
                    avatarUrl = foundUser.avatar;
                    fallbackText = (foundUser.alias || foundUser.name).charAt(0);
                } else {
                    fallbackText = senderName.charAt(0);
                    avatarUrl = '';
                }
            }
        }
        
        let avatarHtml = avatarUrl 
            ? `<div class="qq-msg-avatar" style="background-image: url('${avatarUrl}'); background-size: cover; background-position: center; background-color: #eee; color: transparent;"></div>`
            : `<div class="qq-msg-avatar" style="background: ${isMe?'#111':'#ccc'}; color: #fff;">${fallbackText}</div>`;

        let quoteHtml = '';
        if (msg.quote) {
            quoteHtml = `<div class="cr-quote-block" style="font-size: 12px; color: #888; background: rgba(0,0,0,0.04); padding: 4px 8px; border-radius: 6px; margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; word-break: break-all;">${msg.quote}</div>`;
        }

        let checkboxHtml = '';
        if (qqMultiSelectMode) {
            const isSelected = qqSelectedMsgs.has(msg.timestamp.toString());
            checkboxHtml = `
                <div class="qq-msg-checkbox ${isSelected ? 'selected' : ''}" style="width: 20px; height: 20px; border-radius: 50%; border: 1px solid #ccc; margin-right: 10px; flex-shrink: 0; display: flex; justify-content: center; align-items: center; transition: all 0.2s; ${isSelected ? 'background: #007aff; border-color: #007aff;' : ''}">
                    ${isSelected ? '<svg viewBox="0 0 24 24" width="14" height="14" stroke="#fff" stroke-width="3" fill="none"><polyline points="20 6 9 17 4 12"></polyline></svg>' : ''}
                </div>
            `;
            row.onclick = function() {
                toggleQQMsgSelect(msg.timestamp, this.querySelector('.qq-msg-checkbox'));
            };
        }

        row.innerHTML = `
            ${checkboxHtml}
            ${avatarHtml}
            <div style="display: flex; flex-direction: column; max-width: 80%;">
                ${senderNameHtml}
                <div style="display: flex; flex-direction: column;">
                    ${quoteHtml}
                    <div class="qq-msg-bubble">${displayContent}</div>
                </div>
            </div>
        `;
        
        if (!qqMultiSelectMode) {
            let pressTimer;
            let touchX = 0;
            let touchY = 0;
            row.addEventListener('touchstart', (e) => {
                if (e.touches && e.touches.length > 0) {
                    touchX = e.touches[0].clientX;
                    touchY = e.touches[0].clientY;
                }
                pressTimer = setTimeout(() => {
                    showQQBubbleMenu(touchX, touchY, msg.timestamp, senderName || fallbackText, displayContent);
                }, 500);
            });
            row.addEventListener('touchend', () => clearTimeout(pressTimer));
            row.addEventListener('touchmove', () => clearTimeout(pressTimer));
            
            row.addEventListener('contextmenu', (e) => {
                e.preventDefault();
                showQQBubbleMenu(e.clientX, e.clientY, msg.timestamp, senderName || fallbackText, displayContent);
            });
        }

        historyEl.appendChild(row);
    });

    requestAnimationFrame(() => {
        if (keepScroll) {
            historyEl.scrollTop = historyEl.scrollHeight - oldScrollHeight + oldScrollTop;
        } else {
            historyEl.scrollTop = historyEl.scrollHeight;
        }
    });
}

// ==========================================
// 改造：发送消息 (直接写入 Supabase 数据库)
// ==========================================
async function sendQQMessage() {
    const inputEl = document.getElementById('qqChatInput');
    const content = inputEl.value.trim();
    if (!content || !currentQQChatId) return;
    
    let nowTime = Date.now();
    let quote = qqQuoteContent || ''; 
    
    // 1. 立即在本地渲染（保证自己发消息不卡顿）
    let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`) || '[]');
    history.push({ role: 'me', content: content, quote: quote, timestamp: nowTime });
    ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`, JSON.stringify(history));
    
    inputEl.value = '';
    inputEl.style.height = '36px'; 
    cancelQQQuote(); 
    renderQQChatHistory();
    renderQQMessageList();

    // 2. 异步写入 Supabase 数据库 (保留，用于离线漫游)
    try {
        const msgData = {
            sender_id: qqMyOnlineId,
            content: content,
            quote: quote,
            msg_type: 'text'
        };
        if (isGroupChat) msgData.group_id = currentQQChatId;
        else msgData.receiver_id = currentQQChatId;
        await supabaseClient.from('qq_messages').insert(msgData);
    } catch (error) {
        console.error("消息发送到云端失败:", error);
    }

    // 3. 增加：实时广播发送 (保证在线必达，绕过数据库延迟和配置问题)
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名"}');
    if (isGroupChat) {
        publishSupabaseBroadcast("group_" + currentQQChatId, {
            senderId: qqMyOnlineId,
            type: 'group_chat',
            groupId: currentQQChatId,
            senderName: myProfile.name,
            content: content,
            quote: quote,
            timestamp: nowTime
        });
    } else {
        publishSupabaseBroadcast("user_" + currentQQChatId, {
            senderId: qqMyOnlineId,
            type: 'chat',
            senderName: myProfile.name,
            content: content,
            quote: quote,
            timestamp: nowTime
        });
    }
}

// 聊天设置面板
function toggleQQChatSettings() {
    const panel = document.getElementById('qqChatSettingsPanel');
    if (panel.style.display === 'flex') {
        panel.style.display = 'none';
    } else {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        let chatObj = friends.find(f => f.id === currentQQChatId);
        if (!chatObj) return;

        if (isGroupChat) {
            document.getElementById('qqGroupSettingsArea').style.display = 'block';
            document.getElementById('qqGroupMembersArea').style.display = 'block';
            document.getElementById('qqAliasSettingRow').style.display = 'none';
            document.getElementById('qqDeleteBtnText').innerText = '退出群聊';
            
            document.getElementById('qqGroupNameDisplay').innerText = chatObj.name || '未命名群聊';
            document.getElementById('qqGroupAvatarPreview').style.backgroundImage = chatObj.avatar ? `url(${chatObj.avatar})` : '';
            document.getElementById('qqGroupAvatarPreview').innerText = chatObj.avatar ? '' : '更换头像';
            
            if (!chatObj.groupNumber) {
                chatObj.groupNumber = Math.floor(10000000 + Math.random() * 90000000).toString();
                ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
                
                let allPublicGroups = JSON.parse(ChatDB.getItem('qq_all_public_groups') || '[]');
                let pubGroupIndex = allPublicGroups.findIndex(g => g.id === chatObj.id);
                if (pubGroupIndex > -1) {
                    allPublicGroups[pubGroupIndex] = chatObj;
                } else {
                    allPublicGroups.push(chatObj);
                }
                ChatDB.setItem('qq_all_public_groups', JSON.stringify(allPublicGroups));
            }
            document.getElementById('qqGroupNumberDisplay').innerText = chatObj.groupNumber;
            
            renderQQGroupMembers(chatObj);
        } else {
            document.getElementById('qqGroupSettingsArea').style.display = 'none';
            document.getElementById('qqGroupMembersArea').style.display = 'none';
            document.getElementById('qqAliasSettingRow').style.display = 'flex';
            document.getElementById('qqDeleteBtnText').innerText = '删除好友';
        }
