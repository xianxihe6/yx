function makeGomokuDraggable(el) {
    let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
    let startX = 0, startY = 0, isDragging = false;
    el.onmousedown = dragMouseDown;
    el.ontouchstart = dragMouseDown;

    function dragMouseDown(e) {
        e = e || window.event;
        el.style.transition = 'none'; 
        isDragging = false; 
        if (e.type === 'touchstart') {
            pos3 = e.touches[0].clientX;
            pos4 = e.touches[0].clientY;
        } else {
            pos3 = e.clientX;
            pos4 = e.clientY;
        }
        startX = pos3; 
        startY = pos4; 
        
        document.onmouseup = closeDragElement;
        document.onmousemove = elementDrag;
        document.ontouchend = closeDragElement;
        document.ontouchmove = elementDrag;
    }

    function elementDrag(e) {
        e = e || window.event;
        if (e.type === 'touchmove' && e.cancelable) {
            e.preventDefault(); 
        }
        let clientX, clientY;
        if (e.type === 'touchmove') {
            clientX = e.touches[0].clientX;
            clientY = e.touches[0].clientY;
        } else {
            clientX = e.clientX;
            clientY = e.clientY;
        }
        
        if (Math.abs(clientX - startX) > 5 || Math.abs(clientY - startY) > 5) {
            isDragging = true;
        }

        pos1 = pos3 - clientX;
        pos2 = pos4 - clientY;
        pos3 = clientX;
        pos4 = clientY;
        el.style.top = (el.offsetTop - pos2) + "px";
        el.style.left = (el.offsetLeft - pos1) + "px";
    }

    function closeDragElement() {
        document.onmouseup = null;
        document.onmousemove = null;
        document.ontouchend = null;
        document.ontouchmove = null;
        
        if (!isDragging) {
            if (el.id === 'gomokuPanel' && typeof gomokuIsMiniWindow !== 'undefined' && gomokuIsMiniWindow) {
                toggleGomokuMiniWindow();
            } else if (el.id === 'gomokuLoadingPanel' && typeof gomokuLoadingIsMiniWindow !== 'undefined' && gomokuLoadingIsMiniWindow) {
                toggleGomokuLoadingMiniWindow();
            }
        }
    }
}

