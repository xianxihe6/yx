    const topAvatarEl = document.getElementById('qqMainAvatarDisplay');
    const topNameEl = document.getElementById('qqMainNameDisplay');
    const topUnreadEl = document.getElementById('qqTotalUnreadText');
    
    if (topAvatarEl) {
        topAvatarEl.style.backgroundImage = myProfile.avatar ? `url('${myProfile.avatar}')` : "url('https://api.dicebear.com/7.x/notionists/svg?seed=User')";
    }
    if (topNameEl) {
        topNameEl.innerText = myProfile.name || 'User';
    }
    if (topUnreadEl) {
        let totalUnread = Object.values(unreadCounts).reduce((a, b) => a + b, 0);
        topUnreadEl.innerText = totalUnread > 0 ? `${totalUnread} 条未读消息` : '暂无未读消息';
    }
    // --------------------------------

    let filteredFriends = friends.filter(f => {
        if (currentQQMsgTab === 'all') return true; 
        if (currentQQMsgTab === 'group') return f.isGroup; 
        return !f.isGroup; 
    });

    let pinned = JSON.parse(ChatDB.getItem('qq_pinned_sessions') || '[]');

    // 按最新消息时间排序 (置顶最新消息)
    filteredFriends.sort((a, b) => {
        let isPinnedA = pinned.includes(a.id);
        let isPinnedB = pinned.includes(b.id);
        if (isPinnedA && !isPinnedB) return -1;
        if (!isPinnedA && isPinnedB) return 1;

        let histA = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${a.id}`) || '[]');
        let histB = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${b.id}`) || '[]');
        let timeA = histA.length > 0 ? histA[histA.length - 1].timestamp : 0;
        let timeB = histB.length > 0 ? histB[histB.length - 1].timestamp : 0;
        return timeB - timeA;
    });

    if (filteredFriends.length === 0) {
        listEl.innerHTML = '<div style="text-align: center; color: #aaa; font-size: 12px; padding: 20px;">暂无会话</div>';
        listEl.style.background = 'transparent';
        listEl.style.boxShadow = 'none';
        return;
    }
    
    listEl.style.background = 'var(--qq-bg-card)';
    listEl.style.boxShadow = '0 2px 10px rgba(0,0,0,0.02)';

    filteredFriends.forEach(f => {
        const isOnline = !!qqOnlineStatus[f.id]; 
        let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${f.id}`) || '[]');
        let lastMsg = history.length > 0 ? history[history.length - 1].content : '点击开始聊天';
        
        if (lastMsg.includes('邀请你玩')) {
            lastMsg = '[游戏邀请]';
        } else if (lastMsg.includes('<img')) {
            lastMsg = '[图片]';
        } else if (lastMsg.includes('📎')) {
            lastMsg = '[文件]';
        }

        let displayName = f.alias || f.name;
        let avatarText = f.isGroup ? '群' : displayName.charAt(0);
        
        let avatarHtml = f.avatar 
            ? `<div class="qq-chat-avatar" style="background-image: url('${f.avatar}'); background-size: cover; background-position: center; background-color: #eee; color: transparent;"></div>`
            : `<div class="qq-chat-avatar" style="background: ${f.isGroup?'#007aff':'#111'};">${avatarText}</div>`;
        
        // 未读红点 HTML
        let unreadBadge = unreadCounts[f.id] ? `<div style="background: #ff3b30; color: #fff; font-size: 10px; font-weight: bold; padding: 2px 6px; border-radius: 10px; margin-left: auto;">${unreadCounts[f.id]}</div>` : '';
        
        let isPinned = pinned.includes(f.id);
        let pinHtml = isPinned ? `<span style="font-size: 10px; background: #f0f0f0; color: #888; padding: 2px 6px; border-radius: 4px; margin-right: 6px;">置顶</span>` : '';

        const item = document.createElement('div');
        item.className = 'qq-chat-card';
        
        let pressTimer;
        let isLongPress = false;
        
        item.onclick = (e) => {
            if (isLongPress) {
                isLongPress = false;
                return;
            }
            openQQChat(f.id, displayName, f.isGroup);
        };
        
        item.addEventListener('touchstart', (e) => {
            isLongPress = false;
            pressTimer = setTimeout(() => {
                isLongPress = true;
                showQQSessionMenu(e, f.id, 'message');
            }, 500);
        });
        item.addEventListener('touchend', () => clearTimeout(pressTimer));
        item.addEventListener('touchmove', () => clearTimeout(pressTimer));
        item.addEventListener('contextmenu', (e) => {
            e.preventDefault();
            isLongPress = true;
            showQQSessionMenu(e, f.id, 'message');
        });

        item.innerHTML = `
            <div class="qq-chat-avatar-wrap">${avatarHtml}</div>
