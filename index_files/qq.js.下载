async function sendQQSystemMessage(groupId, content) {
    let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${groupId}`) || '[]');
    let sysMsg = { role: 'system', content: content, timestamp: Date.now() };
    history.push(sysMsg);
    ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${groupId}`, JSON.stringify(history));
    
    try {
        await qqSupabase.from('qq_messages').insert({
            sender_id: qqMyOnlineId,
            group_id: groupId,
            content: content,
            msg_type: 'system'
        });
    } catch (e) {
        console.error("系统消息同步失败", e);
    }
    
    if (currentQQChatId === groupId) renderQQChatHistory();
    renderQQMessageList();
}

