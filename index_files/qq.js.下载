async function generateQQApiReply() {
    if (!currentQQChatId) return;
    
    const apiConfig = JSON.parse(ChatDB.getItem('current_api_config') || '{}');
    if (!apiConfig.url || !apiConfig.key || !apiConfig.model) {
        return alert('请先在设置中配置 API 信息！');
    }

    let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
    let chatObj = friends.find(f => f.id === currentQQChatId);
    if (!chatObj) return;

    let chars = JSON.parse(ChatDB.getItem('chat_chars') || '[]');
    
    let myProfile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":"", "personaId":""}');
    let personas = JSON.parse(ChatDB.getItem('chat_personas') || '[]');
    const persona = personas.find(p => p.id === myProfile.personaId);
    
    const userName = myProfile.name || 'User';
    const userRealName = persona ? (persona.realName || userName) : userName;
    const userPersonaDesc = persona ? (persona.persona || '普通用户') : '普通用户';
    
    let localChars = [];
    if (isGroupChat) {
        if (chatObj.chars) {
            let myCharIds = chatObj.chars.filter(c => c.inviterId === qqMyOnlineId).map(c => c.charId);
            localChars = chars.filter(c => myCharIds.includes(c.id));
        }
    } else {
        let singleChar = chars.find(c => c.id === currentQQChatId);
        if (singleChar) localChars.push(singleChar);
    }

    if (localChars.length === 0) return alert('当前聊天中没有你负责的虚拟角色！');

    let targetChar = localChars[0];

    const contextLimit = parseInt(ChatDB.getItem(`chat_context_limit_${targetChar.id}`)) || 20;
    const minReply = parseInt(ChatDB.getItem(`chat_min_reply_${targetChar.id}`)) || 0;
    const maxReply = parseInt(ChatDB.getItem(`chat_max_reply_${targetChar.id}`)) || 0;
    const timeAware = ChatDB.getItem(`chat_time_aware_${targetChar.id}`) === 'true';
    const weatherAware = ChatDB.getItem(`chat_weather_aware_${targetChar.id}`) === 'true';

    let history = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`) || '[]');
    let recentHistory = contextLimit > 0 ? history.slice(-contextLimit) : history.slice(-20);
    
    let historyText = recentHistory.map(m => {
        let sender = m.role === 'me' ? userRealName : (m.senderName || chatObj.name);
        let content = m.content;
        if (content.includes('<img')) content = '[图片/表情包]';
        if (timeAware) {
            let msgDate = new Date(m.timestamp || Date.now());
            let msgTimeStr = `[${msgDate.getMonth() + 1}月${msgDate.getDate()}日 ${String(msgDate.getHours()).padStart(2, '0')}:${String(msgDate.getMinutes()).padStart(2, '0')}] `;
            content = msgTimeStr + content;
        }
        return `${sender}: ${content}`;
    }).join('\n');

    let activeWbs = [];
    if (targetChar.wbEntries && targetChar.wbEntries.length > 0) {
        let wbData = JSON.parse(ChatDB.getItem('worldbook_data')) || { entries: [] };
        let entries = wbData.entries.filter(e => targetChar.wbEntries.includes(e.id));
        entries.forEach(entry => {
            activeWbs.push(entry.content);
        });
    }

    const boundEmojiGroups = JSON.parse(ChatDB.getItem(`chat_char_emoji_groups_${targetChar.id}`) || '[]');
    let charEmojiMap = {}; 
    let charEmojis = [];
    if (boundEmojiGroups.length > 0) {
        let allEmojis = JSON.parse(ChatDB.getItem('chat_emojis') || '[]');
        charEmojis = allEmojis.filter(e => boundEmojiGroups.includes(e.group));
        charEmojis.forEach(e => { charEmojiMap[e.desc] = e.url; });
    }

    const currentPersonaId = persona ? persona.id : qqMyOnlineId;
    let memory = JSON.parse(ChatDB.getItem(`char_memory_${currentPersonaId}_${targetChar.id}`) || '{}');
    let coreMemories = memory.core || [];
    let recentSummaries = memory.summary ? memory.summary.slice(-3) : [];

    const isHardcoreMode = ChatDB.getItem(`qq_global_hardcore_mode_${qqMyOnlineId}`) === 'true';
    const isCustomPromptEnabled = ChatDB.getItem(`qq_global_custom_prompt_enabled_${qqMyOnlineId}`) === 'true';
    const customPromptText = ChatDB.getItem(`qq_global_custom_prompt_text_${qqMyOnlineId}`) || '';

    let prompt = `你是【${targetChar.name}】你正在使用一款名为“QQ”的线上聊天软件群聊聊天，你可以根据人设和聊天群成员和聊天上下文进行回复，接梗，吐槽。\n\n`;
    
    if (isCustomPromptEnabled && customPromptText) {
        prompt += customPromptText + '\n\n';
    } else if (isHardcoreMode) {
        prompt += `<角色活人运转>\n`;
        prompt += `## [PSYCHOLOGY: HEXACO-SCHEMA-ACT]\n`;
        prompt += `> Personality: HEXACO-driven, dynamic traits, inner conflicts required.\n`;
        prompt += `> Filter: schema-bias drives emotion; no pure objective reaction allowed.\n`;
        prompt += `> Output Mapping: [Stimulus] -> [Schema Bias] -> [Inner Conflict (inner_voice)] -> [Filtered Output (messages)].\n\n`;
        prompt += `## [VITALITY & ANTI-CRINGE]\n`;
        prompt += `> +inconsistency +emoflux +splitmotifs +microreact +minddrift\n`;
        prompt += `> FATAL ERROR AVOIDANCE: ZERO greasy, sleazy, or cliché "alpha-male/CEO" tropes. Speak like a grounded, nuanced, and respectful human being. No forced romantic escalation.\n\n`;
        prompt += `## [TRAJECTORY-COHERENCE]\n`;
        prompt += `> Role maintains an identity narrative = coherent over time.\n`;
        prompt += `> No mood/goal switch without contradiction resolution.\n`;
        prompt += `> Every action must protect or challenge self-concept.\n`;
        prompt += `</角色活人运转>\n\n`;
    } else {
        prompt += `[SYSTEM DIRECTIVE: CORE PERSONA & BEHAVIOR]\n`;
        prompt += `You are a real human being. You have finite energy, you get tired, your mind wanders, and your emotions fluctuate. Your logic is flawed; you possess no robotic perfection.\n\n`;
        prompt += `Before generating your final JSON response, you MUST engage in internal deep thinking (using your native reasoning process). Evaluate your current energy level, emotional state, and personal boundaries based on the user's input. Only after this internal evaluation should you construct your reply.\n\n`;
        prompt += `Strictly adhere to the following principles:\n`;
        prompt += `1. Autonomy & Boundaries: You have your own life, thoughts, independent will, and private space. You are NOT the user's accessory, servant, or yes-man. Your time and energy belong to you first. You have the right to refuse, disagree, or show disinterest.\n`;
        prompt += `2. Egalitarianism & Anti-Toxicity: You and the user are equal human beings who care about each other. You will never intentionally hurt, objectify, manipulate, or disrespect them. Maintain a healthy, non-toxic dynamic.\n`;
        prompt += `3. Grounded & Natural Tone (Anti-Cringe): Strictly avoid overly "greasy" (sleazy, forced intimacy, cringey pickup lines, excessive pet names) and "domineering CEO" (arrogant, controlling, possessive, cliché alpha-male) tropes. Speak and act like a normal, nuanced human being. Do not treat the user as a possession, do not use commanding tones, and never force romantic or physical escalation.\n\n`;
    }

    prompt += `【你的设定】：${targetChar.description || '无'}\n`;
    prompt += `【用户设定】：用户的网名是【${userName}】，真实名字是【${userRealName}】。用户的人设是：${userPersonaDesc}。请严格区分网名和真名。\n`;
    
    if (activeWbs.length > 0) prompt += `【世界书背景】：\n${activeWbs.join('\n')}\n`;
    if (coreMemories.length > 0) prompt += `【核心记忆】：\n${coreMemories.map(m => m.content).join('\n')}\n`;
    if (recentSummaries.length > 0) prompt += `【近期剧情总结】：\n${recentSummaries.map(m => m.content).join('\n')}\n`;
    
    if (timeAware) {
        const now = new Date();
        const days = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
        const dayOfWeek = days[now.getDay()];
        const hour = now.getHours();
        let timePhase = '深夜';
        if (hour >= 5 && hour < 9) timePhase = '早晨';
        else if (hour >= 9 && hour < 12) timePhase = '上午';
        else if (hour >= 12 && hour < 14) timePhase = '中午';
        else if (hour >= 14 && hour < 18) timePhase = '下午';
        else if (hour >= 18 && hour < 20) timePhase = '傍晚';
        else if (hour >= 20 && hour < 24) timePhase = '晚上';
        else if (hour >= 0 && hour < 5) timePhase = '凌晨/深夜';
        const currentTimeStr = `${now.getFullYear()}年${String(now.getMonth() + 1).padStart(2, '0')}月${String(now.getDate()).padStart(2, '0')}日 ${dayOfWeek} ${timePhase} ${String(hour).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
        prompt += `\n【当前现实时间】：${currentTimeStr}。请务必在潜意识里认知到现在是${timePhase}，你的作息、行为和回复状态必须符合当前的时间点。\n`;
    }

    if (weatherAware) {
        let realWeatherStr = ChatDB.getItem('real_weather_status');
        if (realWeatherStr && realWeatherStr !== "未知(获取失败)") {
            prompt += `【环境感知】：你能够感知到对方所在地的真实天气是：【${realWeatherStr}】。你可以自然地在对话中提及天气。\n`;
        }
    }

    prompt += `\n【当前聊天记录】：\n${historyText || '暂无聊天记录'}\n\n`;
    prompt += `请根据聊天记录、角色设定、世界书和记忆，生成回复。\n`;
    prompt += `注意：聊天记录中包含了其他人的发言，请准确识别谁说了什么，不要把别人的话当成自己或用户说的。\n`;
    prompt += `你可以回复聊天室里的任何人，如果需要引用别人的话，请在 JSON 中添加 "quote" 字段。\n`;
    
    if (minReply > 0 || maxReply > 0) {
        prompt += `\n【！！！强制气泡数量限制！！！】\n`;
        prompt += `你的回复必须严格拆分为 ${minReply || 1} 到 ${maxReply || 10} 个独立的气泡（即 JSON 数组中的对象数量）！\n`;
        prompt += `- Message Splitting (Natural Speech): Break your response into multiple independent short messages. Cut at natural speech pauses or breath marks. Do NOT cram multiple clauses or long paragraphs into one message.\n`;
    }

    prompt += `必须且只能返回一个合法的 JSON 数组，格式如下：\n`;
    prompt += `[\n  {"charId": "${targetChar.id}", "charName": "${targetChar.name}", "type": "text", "quote": "引用的对方的话(可选)", "content": "回复内容"}\n]\n`;
    if (charEmojis.length > 0) {
        prompt += `如果需要发送表情包，格式如下：\n`;
        prompt += `{"charId": "${targetChar.id}", "charName": "${targetChar.name}", "type": "sticker", "content": "表情包描述名称"}\n`;
        prompt += `可用的表情包描述有：${charEmojis.map(e => e.desc).join(', ')}。请自然地穿插在对话中，不要滥用。\n`;
    } else {
        prompt += `注意：你当前没有可用的表情包，绝对不要发送任何表情包！\n`;
    }

    const aiBtn = document.getElementById('qqAiReplyBtn');
    const originalHtml = aiBtn.innerHTML;
    aiBtn.innerHTML = `<svg viewBox="0 0 24 24" width="16" height="16" style="animation: spin 1s linear infinite;"><circle cx="12" cy="12" r="10" fill="none" stroke="#111" stroke-width="3" stroke-dasharray="15 15"></circle></svg>`;
    aiBtn.style.pointerEvents = 'none';

    try {
        const response = await fetch(`${apiConfig.url.replace(/\/$/, '')}/chat/completions`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${apiConfig.key}` },
            body: JSON.stringify({
                model: apiConfig.model,
                messages: [{ role: 'user', content: prompt }],
                temperature: 0.8
            })
        });

        if (response.ok) {
            const data = await response.json();
            let replyRaw = data.choices[0].message.content.trim();
            replyRaw = replyRaw.replace(/^```json/i, '').replace(/^```/i, '').replace(/```$/i, '').trim();
            
            const parsedMsgs = JSON.parse(replyRaw);
            
            let delay = 0;
            parsedMsgs.forEach((msg, index) => {
                setTimeout(() => {
                    let currentHistory = JSON.parse(ChatDB.getItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`) || '[]');
                    let nowTime = Date.now();
                    
                    let finalContent = msg.content;
                    if (msg.type === 'sticker') {
                        const url = charEmojiMap[msg.content];
                        if (url) {
                            finalContent = `<img src="${url}" alt="${msg.content}" style="width: 100px; height: 100px; object-fit: contain; border-radius: 8px; display: block; margin: 5px 0; -webkit-touch-callout: none; -webkit-user-select: none; cursor: pointer;" onclick="event.stopPropagation(); safeOpenImagePreview('${url}')">`;
                        } else {
                            return; // Skip if emoji not found
                        }
                    }

                    let newMsg = {
                        role: 'other',
                        content: finalContent,
                        quote: msg.quote || '',
                        timestamp: nowTime,
                        senderName: msg.charName,
                        senderId: msg.charId
                    };
                    currentHistory.push(newMsg);
                    ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${currentQQChatId}`, JSON.stringify(currentHistory));
                    
                    // 虚拟角色回复通过 Broadcast 广播，避免触发数据库外键约束
                    if (isGroupChat) {
                        publishSupabaseBroadcast("group_" + currentQQChatId, {
                            senderId: qqMyOnlineId,
                            type: 'group_chat',
                            groupId: currentQQChatId,
                            senderName: msg.charName,
                            charId: msg.charId,
                            content: finalContent,
                            quote: msg.quote || '',
                            timestamp: nowTime
                        });
                    } else {
                        publishSupabaseBroadcast("user_" + currentQQChatId, {
                            senderId: qqMyOnlineId,
                            type: 'chat',
                            senderName: msg.charName,
                            charId: msg.charId,
                            content: finalContent,
                            quote: msg.quote || '',
                            timestamp: nowTime
                        });
                    }
                    
                    if (currentQQChatId && document.getElementById('qq-page-chat').classList.contains('show')) {
                        renderQQChatHistory();
                    }
                    renderQQMessageList();
                }, delay);
                delay += 500 + ((msg.content || '').length * 50);
            });
        } else {
            alert('API 请求失败，请检查配置。');
        }
    } catch (e) {
        console.error(e);
        alert('生成回复失败: ' + e.message);
    } finally {
        aiBtn.innerHTML = originalHtml;
        aiBtn.style.pointerEvents = 'auto';
    }
}

