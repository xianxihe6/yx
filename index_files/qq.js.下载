window.actionQQSwitchGroup = function() {
    closeQQSessionMenu();
    let groups = JSON.parse(ChatDB.getItem('qq_friend_groups') || '["默认分组"]');
    let groupStr = groups.map((g, i) => `${i + 1}. ${g}`).join('\n');
    let choice = prompt(`请选择要移动到的分组序号:\n${groupStr}`);
    if (choice) {
        let index = parseInt(choice) - 1;
        if (index >= 0 && index < groups.length) {
            let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
            let friend = friends.find(f => f.id === qqCurrentLongPressId);
            if (friend) {
                friend.group = groups[index];
                ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
                renderQQContactList();
                alert("已移动到分组: " + groups[index]);
            }
        } else {
            alert("无效的序号");
        }
    }
};

window.actionQQPinSession = function() {
    closeQQSessionMenu();
    let pinned = JSON.parse(ChatDB.getItem('qq_pinned_sessions') || '[]');
    if (pinned.includes(qqCurrentLongPressId)) {
        pinned = pinned.filter(id => id !== qqCurrentLongPressId);
    } else {
        pinned.push(qqCurrentLongPressId);
    }
    ChatDB.setItem('qq_pinned_sessions', JSON.stringify(pinned));
    renderQQMessageList();
};

window.actionQQClearHistory = function() {
    closeQQSessionMenu();
    if (confirm("确定要清空聊天记录吗？")) {
        ChatDB.setItem(`qq_online_chat_${qqMyOnlineId}_${qqCurrentLongPressId}`, '[]');
        if (currentQQChatId === qqCurrentLongPressId) {
            renderQQChatHistory();
        }
        renderQQMessageList();
        alert("聊天记录已清空");
    }
};

window.actionQQDeleteFriend = function() {
    closeQQSessionMenu();
    if (confirm("确定要删除该好友/退出群聊吗？")) {
        let friends = JSON.parse(ChatDB.getItem('qq_online_friends') || '[]');
        friends = friends.filter(f => f.id !== qqCurrentLongPressId);
        ChatDB.setItem('qq_online_friends', JSON.stringify(friends));
        ChatDB.removeItem(`qq_online_chat_${qqMyOnlineId}_${qqCurrentLongPressId}`);
        if (currentQQChatId === qqCurrentLongPressId) {
            closeQQChat();
        }
        renderQQMessageList();
        renderQQContactList();
    }
};

