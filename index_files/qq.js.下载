async function handleQQMomentFile(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    if (file.type.startsWith('image/')) {
        try {
            const imageUrl = await uploadImageToUrl(file);
            tempQQMomentFile = imageUrl;
            tempQQMomentFileName = 'image';
            document.getElementById('qqMomentFilePreview').innerHTML = `<img src="${tempQQMomentFile}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">`;
        } catch (e) {
            alert(e.message);
        }
    } else {
        if (file.size > 500 * 1024) {
            alert('非图片文件不能超过 500KB！');
            event.target.value = '';
            return;
        }
        tempQQMomentFileName = file.name;
        const reader = new FileReader();
        reader.onload = function(e) {
            tempQQMomentFile = e.target.result;
            document.getElementById('qqMomentFilePreview').innerHTML = `<div style="width: 80px; height: 80px; background: #f0f0f0; border-radius: 8px; display: flex; justify-content: center; align-items: center; font-size: 12px; text-align: center; padding: 5px; word-break: break-all;">📎 ${file.name}</div>`;
        };
        reader.readAsDataURL(file);
    }
    event.target.value = '';
}

async function submitQQMoment() {
    const text = document.getElementById('qqMomentTextInput').value.trim();
    const pwd = document.getElementById('qqMomentPwdInput').value.trim();
    const visibilityEl = document.getElementById('qqMomentVisibility');
    const visibility = visibilityEl ? visibilityEl.value : 'public';
    
    if (!text && !tempQQMomentFile) {
        alert("请输入内容或上传文件！");
        return;
    }
    
    let profile = JSON.parse(ChatDB.getItem('qq_my_profile') || '{"name":"未命名", "avatar":""}');
    let moment = { 
        id: Date.now().toString(), 
        authorId: qqMyOnlineId, 
        name: profile.name, 
        avatar: profile.avatar, 
        text: text, 
        time: Date.now(),
        filePwd: pwd || null,
        visibility: visibility, 
        likes: [],     
        comments: []   
    };
    
    let imageUrl = null;
    let fileUrl = null;

    if (tempQQMomentFile) {
        if (tempQQMomentFile.startsWith('http')) {
            moment.image = tempQQMomentFile;
            imageUrl = tempQQMomentFile;
        } else {
            moment.fileName = tempQQMomentFileName;
            moment.fileData = tempQQMomentFile;
            fileUrl = tempQQMomentFile; // 暂存 Base64
        }
    }
    
    // 1. 先存本地并渲染
    let moments = JSON.parse(ChatDB.getItem('qq_moments') || '[]');
    moments.unshift(moment);
    moments.sort((a, b) => b.time - a.time);
    if (moments.length > 200) moments = moments.slice(0, 200);
    ChatDB.setItem('qq_moments', JSON.stringify(moments));
    renderQQMoments();
    closeQQPostMomentPanel();

    // 增加：实时广播朋友圈 (让在线的人瞬间看到)
    publishSupabaseBroadcast("public_moments", {
        senderId: qqMyOnlineId,
        type: 'new_moment',
        moment: moment
    });

    // 2. 异步写入 Supabase 数据库
    try {
        await supabaseClient.from('qq_moments').insert({
            author_id: qqMyOnlineId,
            content: text,
            image_url: imageUrl,
            file_url: fileUrl,
            visibility: visibility
        });
    } catch (e) {
        console.error("朋友圈同步云端失败", e);
    }
}

