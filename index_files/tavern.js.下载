                    <div style="padding: 15px 0; border-top: 1px solid var(--tav-border-color); margin-top: 10px; display: flex; gap: 10px;">
                        <div class="tav-ins-btn outline" style="flex: 1; color: #007aff; border-color: #007aff;" onclick="exportSingleTavStatusBar('${sb.id}')">导出</div>
                        <div class="tav-ins-btn outline" style="flex: 1; color: #ff9500; border-color: #ff9500;" onclick="moveTavStatusBar('${sb.id}')">移动分组</div>
                        <div class="tav-ins-btn outline" style="flex: 1; color: #ff3b30; border-color: #ff3b30;" onclick="deleteTavStatusBar('${sb.id}')">删除</div>
