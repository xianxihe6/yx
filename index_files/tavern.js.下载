// ==========================================
// 聊天流渲染逻辑 (Chat Stream)
// ==========================================
let tavDisplayCount = 30; // 新增：线下模式分页数量，防止 iOS 渲染过多 DOM 导致内存溢出闪退

function tavRenderChat(keepScroll = false) {
    const streamEl = document.getElementById('tavStoryStream');
    if (!streamEl) return;
    
    // 记录旧的滚动高度
    const oldScrollHeight = streamEl.scrollHeight;
    const oldScrollTop = streamEl.scrollTop;

    streamEl.innerHTML = '';

    const currentLoginId = ChatDB.getItem('current_login_account');
    if (!currentChatRoomCharId || !currentLoginId) {
        streamEl.innerHTML = '<div style="text-align:center; color:#ccc; font-size:12px; margin-top:40px;">暂无聊天记录</div>';
        return;
    }

    // 核心修改：使用 tav_chat_history_ 实现线下隔离
    let history = JSON.parse(ChatDB.getItem(`tav_chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    if (history.length === 0) {
        streamEl.innerHTML = '<div style="text-align:center; color:#ccc; font-size:12px; margin-top:40px;">暂无聊天记录</div>';
        return;
    }

    // --- 核心修复：引入分页渲染机制，防止 iOS 闪退 ---
    const startIndex = Math.max(0, history.length - tavDisplayCount);
    const renderHistory = history.slice(startIndex);

    // 【性能优化】：使用 DocumentFragment 在内存中组装 DOM，一次性插入，彻底消灭重绘卡顿！
    const fragment = document.createDocumentFragment();

    if (startIndex > 0) {
        const loadMoreBtn = document.createElement('div');
        loadMoreBtn.style.cssText = 'text-align: center; padding: 15px 0; color: #888; font-size: 12px; cursor: pointer; font-weight: bold;';
        loadMoreBtn.innerText = '点击加载更多历史记录';
        loadMoreBtn.onclick = () => {
            tavDisplayCount += 30;
            tavRenderChat(true);
        };
        fragment.appendChild(loadMoreBtn);
    }
    // -------------------------------------------------

    let allEntities = typeof getAllEntities === 'function' ? getAllEntities() : [];
    const char = allEntities.find(c => c.id === currentChatRoomCharId);
    const charAvatar = char ? (char.avatarUrl || '') : '';
    const charName = char ? (char.name || char.netName || 'Char') : 'Char';
    
    const me = allEntities.find(a => a.id === currentLoginId);
    const userAvatar = me ? (me.avatarUrl || '') : '';
    let personas = JSON.parse(ChatDB.getItem('chat_personas') || '[]');
    const persona = personas.find(p => p.id === (me ? me.personaId : null));
    const userRealName = persona ? (persona.realName || me?.netName || 'You') : (me ? (me.netName || 'You') : 'You');

    // 获取激活的正则规则
    let regexList = JSON.parse(ChatDB.getItem('tav_regex_list') || '[]').filter(r => r.active);
    
    // 获取激活的状态栏
    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]').filter(sb => sb.active);
    let latestGlobalStatusData = {};

    renderHistory.forEach(msg => {
        const isMe = msg.sender === 'me';
        let content = msg.content || '';
        
        let cardTopHtml = '';
        let cardBottomHtml = '';

        // 提取状态栏数据 (仅对角色的消息提取)
        if (!isMe) {
            statusBars.forEach(sb => {
                try {
                    const regex = new RegExp(sb.regex, 'g');
                    let match;
                    let lastMatch = null;
                    // 找到最后一次匹配
                    while ((match = regex.exec(content)) !== null) {
                        lastMatch = match;
                        // 🔪 核心修复：防止正则匹配到空字符串导致死循环卡死浏览器
                        if (match.index === regex.lastIndex) {
                            regex.lastIndex++;
                        }
                    }
                    
                    if (lastMatch) {
                        let renderedHtml = sb.html;
                        
                        // 宽泛匹配模式：如果正则只有一个捕获组，说明捕获了整段文本，需要按 | 分割
                        if (lastMatch.length === 2) {
                            const parts = lastMatch[1].split('|').map(s => s.trim());
                            for (let i = 0; i < parts.length; i++) {
                                renderedHtml = renderedHtml.replace(new RegExp(`\\{\\{${i+1}\\}\\}`, 'g'), parts[i]);
                            }
                            // 清理未被替换的占位符
                            renderedHtml = renderedHtml.replace(/\{\{\d+\}\}/g, '');
                        } else {
                            // 严格匹配模式：兼容旧的多个捕获组正则
                            for (let i = 1; i < lastMatch.length; i++) {
                                renderedHtml = renderedHtml.replace(new RegExp(`\\{\\{${i}\\}\\}`, 'g'), lastMatch[i]);
                            }
                        }
                        
                        // 核心修改：注入主题颜色 Class 和 按钮 ID
                        if (sb.theme) {
                            renderedHtml = renderedHtml.replace('class="hanxi-container"', `class="hanxi-container ${sb.theme}"`);
                        }
                        renderedHtml = renderedHtml.replace(/\{\{SB_ID\}\}/g, sb.id);
                        
                        // 从正文中移除匹配到的纯文本
                        content = content.replace(lastMatch[0], '').trim();
                        
                        if (sb.pos === 'card_top') {
                            cardTopHtml += renderedHtml;
                        } else if (sb.pos === 'card_bottom') {
                            cardBottomHtml += renderedHtml;
                        } else {
                            // 全局状态栏，记录最新的一条
                            latestGlobalStatusData[sb.id] = renderedHtml;
                        }
                    }
                } catch (e) { console.error('Status bar regex error:', e); }
            });
        }

        let isHtmlContent = false;
        let htmlCode = '';
        
        // 1. 匹配 markdown 的 ```html ... ``` 格式
        const htmlMatch = content.match(/```html\s*([\s\S]*?)\s*```/i);
        if (htmlMatch) {
            isHtmlContent = true;
            htmlCode = htmlMatch[1];
        } 
        // 2. 匹配包含 <style> 和 <script> 的代码块 (兼容用户直接输出的模块)
        else if (content.includes('<style>') && content.includes('<script>')) {
            isHtmlContent = true;
            htmlCode = content;
        }
        // 3. 匹配标准的 HTML 文档
        else if (content.includes('<!DOCTYPE html>') || content.includes('<html')) {
            isHtmlContent = true;
            htmlCode = content;
        }

        if (isHtmlContent) {
            // 提取出 HTML 后，将剩余的普通文本部分（如果有）也保留下来
            let textPart = content.replace(/```html\s*[\s\S]*?\s*```/i, '').trim();
            if (!htmlMatch) {
                // 如果没有 markdown 标记，假设整个 content 都是 HTML，不保留外部文本
                textPart = '';
            }

            // 处理普通文本部分的换行和正则
            if (textPart) {
                regexList.forEach(r => {
                    try {
                        const regex = new RegExp(r.pattern, 'g');
                        textPart = textPart.replace(regex, r.replace);
                    } catch (e) { console.error('Regex error:', e); }
                });
                textPart = textPart.replace(/\n/g, '<br>');
            }

            // 将 HTML 代码放入 iframe 中，设置合适的宽高和圆角
            // 必须转义 & 和 " 以确保 iframe 的 srcdoc 属性解析正确
            const safeHtml = htmlCode.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
            
            // 组合文本和 iframe 沙盒
            content = (textPart ? textPart + '<br><br>' : '') + 
                      `<iframe srcdoc="${safeHtml}" style="width: 100%; min-width: 280px; height: 500px; border: none; border-radius: 12px; background: #fff; display: block; box-shadow: 0 4px 15px rgba(0,0,0,0.1);"></iframe>`;
        } else {
            // 应用正则替换
            regexList.forEach(r => {
                try {
                    const regex = new RegExp(r.pattern, 'g');
                    content = content.replace(regex, r.replace);
                } catch (e) { console.error('Regex error:', e); }
            });

            // 转换换行为 <br>
            content = content.replace(/\n/g, '<br>');
        }

        const card = document.createElement('div');
        card.className = `tav-chat-card ${isMe ? 'user' : 'char'}`;
        
        // 动态生成菜单 HTML
        const menuHtml = `
            <div class="tav-msg-menu-container ${isMe ? 'user' : 'char'}">
                <div class="tav-msg-menu-btn" onclick="tavToggleMsgMenu(this, event)">
                    <svg viewBox="0 0 24 24"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg>
                </div>
                <div class="tav-msg-menu">
                    <div class="tav-msg-menu-item" onclick="tavEditMsg('${msg.id}')">编辑</div>
                    <div class="tav-msg-menu-item" onclick="tavEditMsgStatus('${msg.id}')">编辑状态栏</div>
                    <div class="tav-msg-menu-item danger" onclick="tavDeleteMsg('${msg.id}')">删除</div>
                </div>
            </div>
        `;

        let optionsHtml = '';
        if (!isMe && msg.replyOptions && msg.replyOptions.length > 0 && msg === history[history.length - 1]) {
            const labels = ['A', 'B', 'C'];
            let btnsHtml = msg.replyOptions.map((opt, index) => {
                const safeOpt = opt.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                return `<div class="tav-option-btn" onclick="tavFillInput('${safeOpt}')">${labels[index]}. ${opt}</div>`;
            }).join('');
            btnsHtml += `<div class="tav-option-btn custom" onclick="tavFocusInput()">D. 自定义回复</div>`;
            optionsHtml = `<div class="tav-reply-options">${btnsHtml}</div>`;
        }

        card.innerHTML = `
            <div class="tav-chat-card-header">
                <div class="tav-chat-card-avatar" style="background-image: url('${isMe ? userAvatar : charAvatar}');"></div>
                <div class="tav-chat-card-name">${isMe ? userRealName : charName}</div>
            </div>
            ${cardTopHtml ? `<div class="tav-demo-inner-status top">${cardTopHtml}</div>` : ''}
            <div class="tav-chat-card-content">${content}</div>
            ${optionsHtml}
            ${menuHtml}
        `;
        fragment.appendChild(card);

        // 核心修改：将底部状态栏独立出来，放在卡片外部，这样就不会受卡片背景影响
        if (cardBottomHtml) {
            const statusWrapper = document.createElement('div');
            statusWrapper.className = 'tav-demo-inner-status bottom external-status';
            statusWrapper.innerHTML = cardBottomHtml;
            fragment.appendChild(statusWrapper);
        }
    });

    // 一次性将所有组装好的 DOM 插入页面，避免频繁重绘导致卡屏
    streamEl.appendChild(fragment);

    // 更新全局状态栏
    updateGlobalStatusBars(statusBars, latestGlobalStatusData);

    // 滚动到底部或保持位置
    setTimeout(() => {
        if (keepScroll) {
            streamEl.scrollTop = streamEl.scrollHeight - oldScrollHeight + oldScrollTop;
        } else {
            streamEl.scrollTop = streamEl.scrollHeight;
        }
    }, 100);
}

function updateGlobalStatusBars(statusBars, latestData) {
    const floatingPanel = document.getElementById('tav-floating-panel-content');
    if (floatingPanel) floatingPanel.innerHTML = '';
    
    statusBars.forEach(sb => {
        if (latestData[sb.id]) {
            if (sb.pos === 'floating' && floatingPanel) {
                const div = document.createElement('div');
                div.innerHTML = latestData[sb.id];
                floatingPanel.appendChild(div);
            }
            // 如果有 top 或 bottom 的全局状态栏，可以在这里扩展
        }
    });
}

