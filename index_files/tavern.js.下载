            let themeName = '透明白';
            if (sb.theme === 'theme-black') themeName = '透明黑';
            if (sb.theme === 'theme-aqua') themeName = '水蓝色';
            if (sb.theme === 'theme-mint') themeName = '薄巧色';

            let previewHtml = sb.html;
            if (sb.theme) {
                previewHtml = previewHtml.replace('class="hanxi-container"', `class="hanxi-container ${sb.theme}"`);
            }

