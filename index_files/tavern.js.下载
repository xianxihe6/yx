function openTavGroupDetail(groupName) {
    window.currentTavStatusGroup = groupName;
    document.getElementById('tavGroupDetailTitle').innerText = groupName;
    
    const listEl = document.getElementById('tavGroupDetailList');
    listEl.innerHTML = '';
    
    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
    
    // 核心修改：如果进入的是默认分组，则显示所有状态栏
    let groupItems = [];
    if (groupName === '默认分组') {
        groupItems = statusBars;
    } else {
        groupItems = statusBars.filter(sb => {
            // 强制内置状态栏属于默认分组，防止旧数据没有 group 属性导致被分到未分类
            let gName = sb.id.startsWith('builtin_status_') ? '默认分组' : (sb.group || '未分类分组');
            return gName === groupName;
        });
    }

    if (groupItems.length === 0) {
        listEl.innerHTML = '<div style="text-align:center; color:#888; font-size:12px; padding:20px;">该分组下暂无状态栏</div>';
    } else {
        groupItems.forEach(sb => {
            const posMap = {
                'floating': '全局悬浮可拖动',
                'top': '顶部悬浮',
                'bottom': '底部悬浮',
                'card_top': '卡片内部顶部',
                'card_bottom': '卡片内部底部'
