// 拦截 openTavernMode，改为打开 Lobby
const originalOpenTavernMode = window.openTavernMode;
window.openTavernMode = function() {
    if (!currentChatRoomCharId) return alert('请先选择一个角色');
    const currentLoginId = ChatDB.getItem('current_login_account');
    if (!currentLoginId) return alert('请先登录');

    // 隐藏微信面板
    document.getElementById('wechatPanel').style.display = 'none';
    // 显示 Lobby 面板
    document.getElementById('tavernLobbyPanel').style.display = 'flex';

    tavRenderLobby();
};

function closeTavernLobby() {
    document.getElementById('tavernLobbyPanel').style.display = 'none';
    document.getElementById('wechatPanel').style.display = 'flex';
}

function tavRenderLobby() {
    const currentLoginId = ChatDB.getItem('current_login_account');
    
    // 渲染当前聊天记录卡片
    let history = JSON.parse(ChatDB.getItem(`tav_chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    const previewEl = document.getElementById('tavCurrentChatPreview');
    const timeEl = document.getElementById('tavCurrentChatTime');
    if (history.length > 0) {
        const lastMsg = history[history.length - 1];
        previewEl.innerText = lastMsg.content.replace(/<[^>]+>/g, '');
        const date = new Date(lastMsg.timestamp);
        timeEl.innerText = `${date.getMonth()+1}/${date.getDate()} ${String(date.getHours()).padStart(2,'0')}:${String(date.getMinutes()).padStart(2,'0')}`;
    } else {
        previewEl.innerText = '暂无内容，点击开始聊天...';
        timeEl.innerText = '';
    }

    // 渲染线下记忆总结列表
    const listEl = document.getElementById('tavOfflineMemoriesList');
    listEl.innerHTML = '';
    let memories = JSON.parse(ChatDB.getItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    
    if (memories.length === 0) {
        listEl.innerHTML = '<div style="text-align:center; color:#aaa; font-size:12px; padding:20px;">暂无记忆总结</div>';
        return;
    }

    memories.slice().reverse().forEach(mem => {
        const card = document.createElement('div');
        card.style.cssText = 'background: #fff; border-radius: 12px; border: 1px solid #eee; display: flex; flex-direction: column; overflow: hidden;';
        
        // 提取前15个字符作为折叠栏的标题预览
        let previewText = mem.content.replace(/<[^>]+>/g, '').substring(0, 15);
        if (mem.content.length > 15) previewText += '...';

        card.innerHTML = `
            <div style="padding: 15px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; background: #f9f9f9;" onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'none' ? 'flex' : 'none'; this.querySelector('svg').style.transform = this.nextElementSibling.style.display === 'none' ? 'rotate(0deg)' : 'rotate(180deg)';">
                <span style="font-size: 13px; font-weight: bold; color: #333; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 10px;">${previewText}</span>
                <svg viewBox="0 0 24 24" width="16" height="16" stroke="#888" stroke-width="2" fill="none" style="transition: transform 0.2s; transform: rotate(0deg); flex-shrink: 0;"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
            <div style="display: none; flex-direction: column; padding: 15px; border-top: 1px solid #eee; gap: 10px;">
                <div style="font-size: 13px; color: #333; line-height: 1.5; word-break: break-all;">${mem.content}</div>
                <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #eee; padding-top: 10px;">
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <span style="font-size: 12px; font-weight: bold; color: #111;">同步至线上</span>
                        <label class="ios-switch" style="transform: scale(0.7); margin: 0; transform-origin: left center;">
                            <input type="checkbox" ${mem.syncOnline ? 'checked' : ''} onchange="tavToggleMemorySync('${mem.id}', this)">
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div style="display: flex; gap: 12px;">
                        <span style="font-size: 12px; color: #007aff; cursor: pointer; font-weight: bold;" onclick="tavEditOfflineMemory('${mem.id}')">Edit</span>
                        <span style="font-size: 12px; color: #ff3b30; cursor: pointer; font-weight: bold;" onclick="tavDeleteOfflineMemory('${mem.id}')">Delete</span>
                    </div>
                </div>
            </div>
        `;
        listEl.appendChild(card);
    });
}

function tavOpenSummaryModal() {
    document.getElementById('tavSummaryModalOverlay').classList.add('show');
}

async function tavExecuteSummary(type) {
    document.getElementById('tavSummaryModalOverlay').classList.remove('show');
    const currentLoginId = ChatDB.getItem('current_login_account');
    
    let summaryText = '';

    if (type === 'vector') {
        const memories = JSON.parse(ChatDB.getItem(`tav_memory_${currentChatRoomCharId}`) || '[]');
        if (memories.length === 0) return alert('向量记忆库为空！');
        summaryText = memories[memories.length - 1].text;
    } else if (type === 'ai') {
        const apiConfig = JSON.parse(ChatDB.getItem('tav_api_config') || '{}');
        const url = apiConfig.url || localStorage.getItem('apiUrl');
        const key = apiConfig.key || localStorage.getItem('apiKey');
        const model = apiConfig.model || localStorage.getItem('apiModel') || 'gpt-4-turbo';

        if (!url || !key) return alert('请先配置 API！');

        let history = JSON.parse(ChatDB.getItem(`tav_chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
        if (history.length === 0) return alert('暂无聊天记录可总结！');

        const recentHistory = history.slice(-30).map(m => `${m.sender === 'me' ? 'User' : 'Char'}: ${m.content}`).join('\n');
        const prompt = `请总结以下聊天记录的核心事件和重要信息，使用第三人称陈述句，尽量简短精炼：\n\n${recentHistory}`;

        tavSetLoadingState(true);
        try {
            const cleanUrl = url.replace(/\/$/, '');
            const response = await fetch(cleanUrl + '/chat/completions', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${key}` },
                body: JSON.stringify({ model: model, messages: [{ role: 'user', content: prompt }], temperature: 0.5 })
            });
            if (!response.ok) {
                const err = await response.json();
                throw new Error(JSON.stringify(err, null, 2));
            }
            const data = await response.json();
            // 防止内容截断导致报错，返回多少提取多少
            summaryText = data.choices?.[0]?.message?.content?.trim() || '';
        } catch (e) {
            tavSetLoadingState(false);
            return alert('总结失败: ' + e.message);
        }
        tavSetLoadingState(false);
    }

    if (summaryText) {
        let memories = JSON.parse(ChatDB.getItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
        memories.push({
            id: Date.now().toString(),
            content: summaryText,
            syncOnline: false
        });
        ChatDB.setItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(memories));
        alert('记忆总结已生成并保存至大厅！');
    }
}

function tavToggleMemorySync(id, el) {
    const currentLoginId = ChatDB.getItem('current_login_account');
    let memories = JSON.parse(ChatDB.getItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    const mem = memories.find(m => m.id === id);
    if (mem) {
        mem.syncOnline = el.checked;
        ChatDB.setItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(memories));
        
        // --- 新增：同步到角色记忆库 (Memory Bank) ---
        // 获取当前用户的 personaId
        let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
        const account = accounts.find(a => a.id === currentLoginId);
        const personaId = account ? account.personaId : currentLoginId;
        
        let charMemory = JSON.parse(ChatDB.getItem(`char_memory_${personaId}_${currentChatRoomCharId}`) || 'null');
        if (!charMemory) {
            charMemory = { summary: [], core: [], note: [], settings: {} };
        }
        if (!charMemory.summary) charMemory.summary = [];
// 修改后
        if (el.checked) {
            // 勾选同步：加入角色记忆库，并打上时间轴
            // 核心修改：使用记忆原本的时间戳，而不是当前时间
            const memTime = parseInt(mem.id);
            const now = isNaN(memTime) ? new Date() : new Date(memTime);
            const timeStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
            const finalText = `[${timeStr} 线下记忆]\n${mem.content}`;
            
            // 核心修改：提取简单的关键词作为标签，帮助向量检索更容易命中
            let cleanText = mem.content.replace(/[^\u4e00-\u9fa5a-zA-Z0-9]/g, ' ');
            let words = cleanText.split(/\s+/).filter(w => w.length >= 2);
            const stopWords = ['什么','怎么','我们','你们','他们','这个','那个','就是','还是','可以','没有','知道','觉得','喜欢','为什么','时候','现在','今天','明天','昨天','真的','如果'];
            let tags = words.filter(w => !stopWords.includes(w)).slice(0, 5);

            charMemory.summary.push({
                id: mem.id, // 核心修改：使用原本的时间戳作为 ID
                sourceId: mem.id, 
                content: finalText,
                tags: tags, // 注入标签
                weight: 5
            });

            // 核心修改：按照时间戳(ID)重新排序，确保记忆按真实发生的时间顺序排列
            charMemory.summary.sort((a, b) => parseInt(a.id) - parseInt(b.id));

            // --- 新增：注入到线上聊天记录作为隐藏消息 ---
            let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
            history.push({
                role: 'system',
                type: 'hidden_system',
                linkedOfflineMemId: mem.id,
                content: `[系统提示：你们刚刚在线下见了一面，期间发生了以下事情：${mem.content}。请在接下来的线上聊天中自然地体现出这段记忆。]`,
                timestamp: Date.now()
            });
            ChatDB.setItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(history));

            let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`) || '[]');
            targetHistory.push({
                role: 'system',
                type: 'hidden_system',
                linkedOfflineMemId: mem.id,
                content: `[系统提示：你们刚刚在线下见了一面，期间发生了以下事情：${mem.content}。请在接下来的线上聊天中自然地体现出这段记忆。]`,
                timestamp: Date.now()
            });
            ChatDB.setItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`, JSON.stringify(targetHistory));
            // ---------------------------------------------
        } else {
            // 取消同步：从角色记忆库中移除对应的记录
            charMemory.summary = charMemory.summary.filter(m => m.sourceId !== mem.id);

            // --- 新增：从线上聊天记录中移除隐藏消息 ---
            let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
            history = history.filter(m => m.linkedOfflineMemId !== mem.id);
            ChatDB.setItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(history));

            let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`) || '[]');
            targetHistory = targetHistory.filter(m => m.linkedOfflineMemId !== mem.id);
            ChatDB.setItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`, JSON.stringify(targetHistory));
            // ---------------------------------------------
        }
        
        ChatDB.setItem(`char_memory_${personaId}_${currentChatRoomCharId}`, JSON.stringify(charMemory));
        // ---------------------------------------------
    }
}

function tavEditOfflineMemory(id) {
    const currentLoginId = ChatDB.getItem('current_login_account');
    let memories = JSON.parse(ChatDB.getItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    const mem = memories.find(m => m.id === id);
    if (!mem) return;

    const modal = document.getElementById('tavEditContentModalOverlay');
    document.getElementById('tavEditContentTitle').innerText = '编辑记忆总结';
    const textarea = document.getElementById('tavEditContentTextarea');
    textarea.value = mem.content;

    const saveBtn = document.getElementById('tavEditContentSaveBtn');
    saveBtn.onclick = () => {
        mem.content = textarea.value;
        ChatDB.setItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(memories));
        // 修改后
        // --- 新增：同步修改角色记忆库中的内容 ---
        if (mem.syncOnline) {
            let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
            const account = accounts.find(a => a.id === currentLoginId);
            const personaId = account ? account.personaId : currentLoginId;
            let charMemory = JSON.parse(ChatDB.getItem(`char_memory_${personaId}_${currentChatRoomCharId}`) || '{}');
            if (charMemory.summary) {
                const targetMem = charMemory.summary.find(m => m.sourceId === mem.id);
                if (targetMem) {
                    // 保留时间戳前缀，只替换后面的内容
                    const timePrefixMatch = targetMem.content.match(/^\[.*?\]\n/);
                    const timePrefix = timePrefixMatch ? timePrefixMatch[0] : '';
                    targetMem.content = timePrefix + mem.content;
                    
                    // 重新提取标签，确保编辑后的内容也能被向量检索命中
                    let cleanText = mem.content.replace(/[^\u4e00-\u9fa5a-zA-Z0-9]/g, ' ');
                    let words = cleanText.split(/\s+/).filter(w => w.length >= 2);
                    const stopWords = ['什么','怎么','我们','你们','他们','这个','那个','就是','还是','可以','没有','知道','觉得','喜欢','为什么','时候','现在','今天','明天','昨天','真的','如果'];
                    targetMem.tags = words.filter(w => !stopWords.includes(w)).slice(0, 5);

                    ChatDB.setItem(`char_memory_${personaId}_${currentChatRoomCharId}`, JSON.stringify(charMemory));
                }
            }
        }
        // ---------------------------------------
        
        modal.classList.remove('show');
        tavRenderLobby();
    };
    modal.classList.add('show');
}

function tavDeleteOfflineMemory(id) {
    if (confirm('确定删除这条记忆总结吗？')) {
        const currentLoginId = ChatDB.getItem('current_login_account');
        let memories = JSON.parse(ChatDB.getItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
        memories = memories.filter(m => m.id !== id);
        ChatDB.setItem(`tav_offline_memories_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(memories));
        
        // --- 新增：同步从角色记忆库中删除 ---
        let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
        const account = accounts.find(a => a.id === currentLoginId);
        const personaId = account ? account.personaId : currentLoginId;
        let charMemory = JSON.parse(ChatDB.getItem(`char_memory_${personaId}_${currentChatRoomCharId}`) || '{}');
        if (charMemory.summary) {
            charMemory.summary = charMemory.summary.filter(m => m.sourceId !== id);
            ChatDB.setItem(`char_memory_${personaId}_${currentChatRoomCharId}`, JSON.stringify(charMemory));
        }
        // -----------------------------------
        
        // --- 新增：同步从线上聊天记录中删除隐藏消息 ---
        let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
        history = history.filter(m => m.linkedOfflineMemId !== id);
        ChatDB.setItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(history));

        let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`) || '[]');
        targetHistory = targetHistory.filter(m => m.linkedOfflineMemId !== id);
        ChatDB.setItem(`chat_history_${currentChatRoomCharId}_${currentLoginId}`, JSON.stringify(targetHistory));
        // -----------------------------------

        tavRenderLobby();
    }
}

function tavEnterChat() {
    document.getElementById('tavernLobbyPanel').style.display = 'none';
    document.getElementById('tavernModePanel').style.display = 'flex';
    
    tavDisplayCount = 30; // 每次进入重置显示数量
    
    const currentLoginId = ChatDB.getItem('current_login_account');
    
    // 同步当前聊天角色的头像和名字，并注入开场白和预设
    if (typeof currentChatRoomCharId !== 'undefined' && currentChatRoomCharId) {
        let allEntities = typeof getAllEntities === 'function' ? getAllEntities() : [];
        const char = allEntities.find(c => c.id === currentChatRoomCharId);
        if (char) {
            document.getElementById('tavHeaderAvatar').style.backgroundImage = `url('${char.avatarUrl || ''}')`;
            document.getElementById('tavHeaderName').innerText = char.name || char.netName || '未命名';
            
            // 注入开场白
            let history = JSON.parse(ChatDB.getItem(`tav_chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
            if (history.length === 0 && char.firstMessage) {
                history.push({
                    id: Date.now().toString(),
                    sender: 'char',
                    content: char.firstMessage,
                    timestamp: new Date().toISOString()
                });
                ChatDB.setItem(`tav_chat_history_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(history));
            }
            
            // 注入角色自带的预设或用户修改过的预设
            const savedSys = ChatDB.getItem(`tav_active_prompt_system_${currentChatRoomCharId}`);
            const sysEl = document.getElementById('tavSystemPrompt');
            if (sysEl) sysEl.value = savedSys !== null ? savedSys : (char.systemPrompt || '');

            const savedJail = ChatDB.getItem(`tav_active_prompt_jailbreak_${currentChatRoomCharId}`);
            const jailEl = document.getElementById('tavJailbreakPrompt');
            if (jailEl) jailEl.value = savedJail !== null ? savedJail : (char.postHistoryInstructions || '');

            const savedStyle = ChatDB.getItem(`tav_active_prompt_style_${currentChatRoomCharId}`);
            const styleEl = document.getElementById('tavStylePrompt');
            if (styleEl) styleEl.value = savedStyle !== null ? savedStyle : '';

            const savedNote = ChatDB.getItem(`tav_active_prompt_note_${currentChatRoomCharId}`);
            const noteEl = document.getElementById('tavNotePrompt');
            if (noteEl) noteEl.value = savedNote !== null ? savedNote : (char.creatorNotes || '');
        }
    }

    tavRenderChat();
    renderTavRegexList();
    
    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
    const hasFloating = statusBars.some(sb => sb.active && sb.pos === 'floating');
    document.getElementById('tav-floating-ball-container').style.display = hasFloating ? 'flex' : 'none';

    // 读取并应用外观设置
    const savedBg = ChatDB.getItem('tav_bg_image');
    if (savedBg) {
        tavChangeBackground(savedBg);
        if (savedBg.length < 500) document.getElementById('tavBgUrlInput').value = savedBg;
    }
    
    const savedBall = ChatDB.getItem('tav_ball_image');
    if (savedBall) {
        tavChangeBallImage(savedBall);
        if (savedBall.length < 500) document.getElementById('tavBallUrlInput').value = savedBall;
    }

    const savedBrightness = ChatDB.getItem('tav_brightness') || '0';
    const brightnessInput = document.getElementById('tavBrightnessInput');
    if (brightnessInput) brightnessInput.value = savedBrightness;
    tavChangeBrightness(savedBrightness);

    const savedCardOpacity = ChatDB.getItem('tav_card_opacity') || '60';
    const cardOpacityInput = document.getElementById('tavCardOpacityInput');
    if (cardOpacityInput) cardOpacityInput.value = savedCardOpacity;
    tavChangeCardOpacity(savedCardOpacity);

    const savedFontSize = ChatDB.getItem('tav_font_size') || '15';
    const fontSizeInput = document.getElementById('tavFontSizeInput');
    if (fontSizeInput) fontSizeInput.value = savedFontSize;
    tavChangeFontSize(savedFontSize);

    const savedFontColor = ChatDB.getItem('tav_font_color');
    const fontColorInput = document.getElementById('tavFontColorInput');
    if (savedFontColor) {
        if (fontColorInput) fontColorInput.value = savedFontColor;
        tavChangeFontColor(savedFontColor);
    } else {
        if (fontColorInput) fontColorInput.value = '#111111';
        tavResetFontColor();
    }

    // 读取回复选项插件开关状态
    const isReplyOptionsEnabled = ChatDB.getItem('tav_plugin_reply_options') === 'true';
    const replyOptionsToggle = document.getElementById('tavReplyOptionsToggle');
    if (replyOptionsToggle) {
        if (isReplyOptionsEnabled) replyOptionsToggle.classList.add('active');
        else replyOptionsToggle.classList.remove('active');
    }

    // 新增：读取其他插件和预设开关状态
    ['tavSysPromptToggle', 'tavJailbreakToggle', 'tavStyleToggle', 'tavNoteToggle', 'tavVectorToggle', 'tavTimeAwareToggle'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            const saved = ChatDB.getItem(`tav_plugin_${id}`);
            if (String(saved) === 'false') el.classList.remove('active');
            else if (String(saved) === 'true') el.classList.add('active');
        }
    });
}

