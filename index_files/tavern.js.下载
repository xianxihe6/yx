// 状态栏导入导出逻辑
// ==========================================
function exportSingleTavStatusBar(id) {
    const statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
    const sb = statusBars.find(s => s.id === id);
    if (!sb) return alert('未找到该状态栏数据！');
    
    const blob = new Blob([JSON.stringify(sb, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    // 核心修改：文件名直接使用状态栏的名称，并过滤掉操作系统文件名不支持的特殊字符
    const safeName = sb.name.replace(/[\\/:*?"<>|]/g, '_');
    a.download = `${safeName}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
}

function importTavStatusBars() {
    const input = document.getElementById('tavStatusBarImportInput');
    if (input) input.click();
}

function handleTavStatusBarsImport(event) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const importedData = JSON.parse(e.target.result);
            let currentData = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
            
            // 兼容导入单个对象或数组
            const itemsToImport = Array.isArray(importedData) ? importedData : [importedData];
            
            if (itemsToImport.length === 0) throw new Error("文件中没有状态栏数据");

            itemsToImport.forEach(item => {
                // 强制生成新ID，防止冲突
                item.id = 'imported_' + Date.now() + Math.random().toString(36).substr(2, 5);
                // 如果没有分组，默认放入“导入分组”
                if (!item.group) item.group = '导入分组';
                currentData.push(item);
            });
            
            // 绝对不覆盖，永远是追加
            ChatDB.setItem('tav_status_bars', JSON.stringify(currentData));
            
            alert(`成功导入 ${itemsToImport.length} 个状态栏！(已追加到现有列表中)`);
            renderTavStatusBars();
            
            // 如果当前在分组详情页，刷新一下
            if (window.currentTavStatusGroup) {
                openTavGroupDetail(window.currentTavStatusGroup);
            }
        } catch (err) {
            alert('导入失败：文件格式不正确或已损坏。\n' + err.message);
        }
    };
    reader.readAsText(file);
    event.target.value = ''; 
}
