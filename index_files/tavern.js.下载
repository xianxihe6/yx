}

// ==========================================
// 状态栏分组增删改逻辑
// ==========================================
function openTavGroupActionMenu(groupName) {
    document.getElementById('tavActionGroupName').value = groupName;
    document.getElementById('tavGroupActionModalOverlay').classList.add('show');
}

function closeTavGroupActionMenu() {
    document.getElementById('tavGroupActionModalOverlay').classList.remove('show');
}

function openTavGroupEditModal(mode) {
    closeTavGroupActionMenu();
    document.getElementById('tavGroupEditMode').value = mode;
    const inputEl = document.getElementById('tavGroupEditInput');
    
    if (mode === 'create') {
        document.getElementById('tavGroupEditTitle').innerText = '创建分组';
        inputEl.value = '';
    } else if (mode === 'rename') {
        document.getElementById('tavGroupEditTitle').innerText = '修改分组名称';
        inputEl.value = document.getElementById('tavActionGroupName').value;
    }
    
    document.getElementById('tavGroupEditModalOverlay').classList.add('show');
}

function closeTavGroupEditModal() {
    document.getElementById('tavGroupEditModalOverlay').classList.remove('show');
}

function confirmTavGroupEdit() {
    const mode = document.getElementById('tavGroupEditMode').value;
    const newName = document.getElementById('tavGroupEditInput').value.trim();
    
    if (!newName) return alert('分组名称不能为空！');
    if (newName === '默认分组' || newName === '未分类分组') return alert('保留分组名称不可使用！');

    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');

    if (mode === 'create') {
        statusBars.push({
            id: 'placeholder_' + Date.now(),
            name: '占位符', pos: 'floating', regex: 'none', prompt: '', html: '', active: false,
            group: newName, isPlaceholder: true
        });
    } else if (mode === 'rename') {
        const oldName = document.getElementById('tavActionGroupName').value;
        if (oldName === '默认分组' || oldName === '未分类分组') return alert('默认分组不可重命名！');
        
        statusBars.forEach(sb => {
            if (sb.group === oldName) sb.group = newName;
        });
    }

    ChatDB.setItem('tav_status_bars', JSON.stringify(statusBars));
    closeTavGroupEditModal();
    renderTavStatusBars();
}

function deleteTavStatusGroup() {
    const groupName = document.getElementById('tavActionGroupName').value;
    if (groupName === '默认分组' || groupName === '未分类分组') return alert('默认分组不可删除！');
    
    if (confirm(`确定删除分组【${groupName}】吗？\n该分组下的所有状态栏将被移至“未分类分组”。`)) {
        let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
        
        statusBars = statusBars.filter(sb => !(sb.group === groupName && sb.isPlaceholder));
        statusBars.forEach(sb => {
            if (sb.group === groupName) sb.group = '未分类分组';
        });

        ChatDB.setItem('tav_status_bars', JSON.stringify(statusBars));
        closeTavGroupActionMenu();
        renderTavStatusBars();
    }
}

function toggleTavStatusBar(id, el) {
    el.classList.toggle('active');
    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
    const sb = statusBars.find(s => s.id === id);
    if (sb) {
        sb.active = el.classList.contains('active');
        ChatDB.setItem('tav_status_bars', JSON.stringify(statusBars));
    }
}

function deleteTavStatusBar(id) {
    if (confirm('确定删除此状态栏吗？')) {
        let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
        statusBars = statusBars.filter(s => s.id !== id);
        ChatDB.setItem('tav_status_bars', JSON.stringify(statusBars));
        renderTavStatusBars();
        if (window.currentTavStatusGroup) {
            openTavGroupDetail(window.currentTavStatusGroup);
        }
    }
}

function moveTavStatusBar(id) {
    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
    const sb = statusBars.find(s => s.id === id);
    if (!sb) return;
    
    document.getElementById('tavMoveTargetSbId').value = id;
    
    // 获取所有分组
    let groups = new Set(['默认分组', '未分类分组']);
    statusBars.forEach(s => {
        if (s.group) groups.add(s.group);
    });
    
    const listEl = document.getElementById('tavMoveGroupList');
    listEl.innerHTML = '';
    
    groups.forEach(g => {
        const item = document.createElement('div');
        item.style.cssText = 'padding: 12px; background: #f4f4f5; border-radius: 12px; font-size: 14px; color: #333; cursor: pointer; text-align: center; font-weight: bold; transition: background 0.2s;';
        if (g === (sb.group || '默认分组')) {
            item.style.background = '#111';
            item.style.color = '#fff';
        }
        item.innerText = g;
        item.onclick = () => {
            // 单选逻辑
            Array.from(listEl.children).forEach(child => {
                child.style.background = '#f4f4f5';
                child.style.color = '#333';
                child.dataset.selected = 'false';
            });
            item.style.background = '#111';
            item.style.color = '#fff';
            item.dataset.selected = 'true';
        };
        if (g === (sb.group || '默认分组')) {
            item.dataset.selected = 'true';
        }
        listEl.appendChild(item);
    });
    
    document.getElementById('tavMoveGroupModalOverlay').classList.add('show');
}

function closeTavMoveGroupModal() {
    document.getElementById('tavMoveGroupModalOverlay').classList.remove('show');
}

function confirmTavMoveGroup() {
    const id = document.getElementById('tavMoveTargetSbId').value;
    const listEl = document.getElementById('tavMoveGroupList');
    let selectedGroup = null;
    Array.from(listEl.children).forEach(child => {
        if (child.dataset.selected === 'true') {
            selectedGroup = child.innerText;
        }
    });
    
    if (!selectedGroup) return alert('请选择目标分组！');
    
    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
    const sb = statusBars.find(s => s.id === id);
    if (sb) {
        sb.group = selectedGroup;
        ChatDB.setItem('tav_status_bars', JSON.stringify(statusBars));
        closeTavMoveGroupModal();
        if (window.currentTavStatusGroup) {
            openTavGroupDetail(window.currentTavStatusGroup);
        }
        renderTavStatusBars();
    }
}

function updateTavStatusBar(id, field, value) {
    let statusBars = JSON.parse(ChatDB.getItem('tav_status_bars') || '[]');
    const sb = statusBars.find(s => s.id === id);
    if (sb) {
        sb[field] = value;
        ChatDB.setItem('tav_status_bars', JSON.stringify(statusBars));
    }
}

