        }

        folderItem.innerHTML = `
            <div class="tav-folder-icon">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 12C4 9.79086 5.79086 8 8 8H17.1716C18.2324 8 19.2497 8.42143 20 9.17157L22.8284 12H40C42.2091 12 44 13.7909 44 16V36C44 38.2091 42.2091 40 40 40H8C5.79086 40 4 38.2091 4 36V12Z" fill="#60A5FA"/>
                    <path d="M4 16C4 13.7909 5.79086 12 8 12H40C42.2091 12 44 13.7909 44 16V36C44 38.2091 42.2091 40 40 40H8C5.79086 40 4 38.2091 4 36V16Z" fill="#7DD3FC"/>
