            if (['builtin_status_1', 'builtin_status_2', 'builtin_status_3'].includes(sb.id)) {
                themeRowHtml = `
                    <div class="tav-setting-row" style="padding: 10px 0; border-bottom: 1px solid var(--tav-border-color);">
                        <span>主题颜色</span>
                        <div class="tav-ins-btn outline" style="padding: 4px 12px; font-size: 12px; border-color: #888; color: #555; display: flex; align-items: center; gap: 6px;" onclick="tavOpenThemeSelector('${sb.id}')">
                            ${themeName} 
                            <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5"></circle><circle cx="17.5" cy="10.5" r=".5"></circle><circle cx="8.5" cy="7.5" r=".5"></circle><circle cx="6.5" cy="12.5" r=".5"></circle><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path></svg>
                        </div>
                    </div>
                `;
            }

            const card = document.createElement('div');
            card.className = 'tav-status-item-card';
            card.innerHTML = `
                <div class="tav-status-header" onclick="this.parentElement.classList.toggle('open')">
                    <div class="tav-status-header-left">
                        <div class="tav-toggle-switch ${sb.active ? 'active' : ''}" onclick="event.stopPropagation(); toggleTavStatusBar('${sb.id}', this)"></div>
                        <span class="tav-status-title">${sb.name}</span>
                    </div>
                    <div class="tav-status-header-right">
                        <svg class="tav-status-arrow" viewBox="0 0 24 24" fill="none" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </div>
                </div>
                <div class="tav-status-body">
                    ${themeRowHtml}
