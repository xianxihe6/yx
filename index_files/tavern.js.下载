                        <span>HTML 预览</span>
                        <div class="tav-status-preview-box" style="margin-top:4px; padding:10px; background:#f9f9f9; border-radius:8px; border:1px dashed #ccc; overflow-y: auto; -webkit-overflow-scrolling: touch; overscroll-behavior: contain; scroll-behavior: smooth; min-height: 40px; max-height: 300px;">
