function showCustomNotification(type, targetId, title, content, avatarUrl, bgColor, text) {
    const notifEl = document.getElementById('inAppNotification');
    const avatarEl = document.getElementById('notifAvatar');
    
    if (avatarUrl) {
        avatarEl.style.backgroundImage = `url('${avatarUrl}')`;
        avatarEl.style.backgroundColor = 'transparent';
        avatarEl.innerText = '';
    } else {
        avatarEl.style.backgroundImage = 'none';
        avatarEl.style.backgroundColor = bgColor || '#111';
        avatarEl.style.color = '#fff';
        avatarEl.style.display = 'flex';
        avatarEl.style.justifyContent = 'center';
        avatarEl.style.alignItems = 'center';
        avatarEl.innerText = text || title.charAt(0);
    }
    
    document.getElementById('notifName').innerText = title;
    document.getElementById('notifDesc').innerText = content;

    currentNotifType = type;
    currentNotifTargetId = targetId;

    // 核心修复：判断是否在当前聊天室，如果在，则不显示内部弹窗
    let isCurrentChatVisible = false;
    if (type === 'chat') {
        const chatRoomPanel = document.getElementById('chatRoomPanel');
        const musicPlayerPanel = document.getElementById('musicPlayerPanel');
        if (targetId === currentChatRoomCharId && chatRoomPanel && window.getComputedStyle(chatRoomPanel).display !== 'none') {
            isCurrentChatVisible = true;
        } else if (targetId === window.currentListenTogetherCharId && musicPlayerPanel && window.getComputedStyle(musicPlayerPanel).display !== 'none') {
            isCurrentChatVisible = true;
        }
    } else if (type === 'alipay') {
        const alipayChatRoomPage = document.getElementById('alipayChatRoomPage');
        if (typeof currentAlipayChatCharId !== 'undefined' && targetId === currentAlipayChatCharId && alipayChatRoomPage && alipayChatRoomPage.classList.contains('show')) {
            isCurrentChatVisible = true;
        }
    } else if (type === 'sms') {
        const smsChatPage = document.getElementById('smsChatPage');
        if (typeof currentSmsTargetId !== 'undefined' && targetId === currentSmsTargetId && smsChatPage && !smsChatPage.classList.contains('hidden')) {
            isCurrentChatVisible = true;
        }
    }

    // 只有不在聊天室时，才弹出内部弹窗
    if (!isCurrentChatVisible) {
        notifEl.classList.remove('show');
        void notifEl.offsetWidth; 
        notifEl.classList.add('show');

        clearTimeout(notifTimeout);
        notifTimeout = setTimeout(() => {
            notifEl.classList.remove('show');
        }, 4000);
    }

    const soundUrl = ChatDB.getItem('sys_notif_sound');
    if (soundUrl) {
        const audio = new Audio(soundUrl);
        audio.play().catch(e => console.log("自动播放提示音被拦截:", e));
    }

    // 触发系统级通知 (融合真实浏览器通知逻辑)
    const notifMode = ChatDB.getItem('sys_notif_mode') || 'off';
    let shouldSend = false;
    if (notifMode === 'always') {
        shouldSend = true;
    } else if (notifMode === 'background') {
        if (document.hidden || document.visibilityState !== 'visible') {
            shouldSend = true;
        }
    }

    const now = new Date();
    const timeStr = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
    const finalBody = `[${timeStr}] ${content}`;

    if (shouldSend && "Notification" in window && Notification.permission === "granted") {
        // 核心修复：移除 navigator.serviceWorker.controller 的判断。
        // 在 iOS PWA 或首次加载时，controller 可能为空，但 ready 是可用的。
        // iOS 必须使用 ServiceWorkerRegistration.showNotification()，直接 new Notification 会报错拦截。
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.ready.then(function(registration) {
                registration.showNotification(title, {
                    body: finalBody,
                    icon: avatarUrl || 'https://i.postimg.cc/d3z037tr/IMG-20260519-094026.png',
                    badge: avatarUrl || 'https://i.postimg.cc/d3z037tr/IMG-20260519-094026.png',
                    timestamp: Date.now(),
                    vibrate: [200, 100, 200],
                    tag: 'msg-' + Date.now() + '-' + Math.floor(Math.random() * 1000),
                    renotify: true
                }).catch(function(err) {
                    console.error("ServiceWorker 通知发送失败，尝试降级:", err);
                    fallbackNotification();
                });
            });
        } else {
            fallbackNotification();
        }

        function fallbackNotification() {
            try {
                const sysNotif = new Notification(title, {
                    body: finalBody,
                    icon: avatarUrl || 'https://i.postimg.cc/d3z037tr/IMG-20260519-094026.png',
                    timestamp: Date.now()
                });
                sysNotif.onclick = function() {
                    window.focus();
                    handleNotificationClick();
                    sysNotif.close();
                };
            } catch (e) {
                console.error("原生通知发送失败 (移动端不支持new Notification):", e);
            }
        }
    }
}

