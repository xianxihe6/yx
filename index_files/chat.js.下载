// 新增：计算热记忆 Token 容量
function updateMemoryTokenBar() {
    const personaId = getCurrentPersonaIdForMemory();
    let memory = JSON.parse(ChatDB.getItem(`char_memory_${personaId}_${currentProfileCharId}`) || '{}');
    
    let totalTokens = 0;
    if (memory.core) memory.core.forEach(m => totalTokens += (m.content || '').length);
    if (memory.summary) memory.summary.forEach(m => totalTokens += (m.content || '').length);
    if (memory.note) memory.note.forEach(m => totalTokens += (m.content || '').length);
    
    const maxTokens = 8000; // 假设最大安全上下文为 8000
    const percentage = Math.min(100, (totalTokens / maxTokens) * 100);
    
    const textEl = document.getElementById('memoryTokenUsageText');
    const fillEl = document.getElementById('memoryTokenProgressFill');
    
    if (textEl) textEl.innerText = `${totalTokens} / ${maxTokens} Tokens`;
    if (fillEl) {
        fillEl.style.width = `${percentage}%`;
        if (percentage > 80) {
            fillEl.classList.add('warning');
            textEl.style.color = '#ff3b30';
        } else {
            fillEl.classList.remove('warning');
            textEl.style.color = '#888';
        }
    }
}

