// ==========================================
// 主动发消息后台检测逻辑 (Web Worker 防休眠版)
// ==========================================
function isCharSleeping(charId) {
    let routineStr = ChatDB.getItem(`day_routine_char_${charId}`);
    if (!routineStr) return false; // 默认不睡眠
    try {
        let routine = JSON.parse(routineStr);
        if (!routine.wake || !routine.sleep) return false;
        let wakeParts = routine.wake.split(':').map(Number);
        let sleepParts = routine.sleep.split(':').map(Number);
        
        let now = new Date();
        let currentMinutes = now.getHours() * 60 + now.getMinutes();
        let wakeMinutes = wakeParts[0] * 60 + wakeParts[1];
        let sleepMinutes = sleepParts[0] * 60 + sleepParts[1];
        
        if (sleepMinutes < wakeMinutes) {
            // 跨天情况 (如 23:00 到 07:00)
            if (currentMinutes >= sleepMinutes || currentMinutes < wakeMinutes) return true;
        } else {
            // 不跨天情况 (如 01:00 到 07:00)
            if (currentMinutes >= sleepMinutes && currentMinutes < wakeMinutes) return true;
        }
    } catch (e) {
        return false;
    }
    return false;
}

function checkActiveMessages() {
    const currentLoginId = ChatDB.getItem('current_login_account');
    if (!currentLoginId) return;

    let sessions = JSON.parse(ChatDB.getItem(`chat_sessions_${currentLoginId}`) || '[]');
    const now = Date.now();

    sessions.forEach(charId => {
        const isActiveEnabled = ChatDB.getItem(`chat_active_msg_${charId}`) === 'true';
        if (!isActiveEnabled) return;
        
        if (isCharSleeping(charId)) return; // 睡眠期间不主动发消息

        const intervalMinutes = parseInt(ChatDB.getItem(`chat_active_msg_interval_${charId}`)) || 60;
        const intervalMs = intervalMinutes * 60 * 1000;

        let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${charId}`) || '[]');
        if (history.length === 0) return;

        const lastMsg = history[history.length - 1];
        
        // 距离最后一条消息超过了设定的间隔时间
        if (now - lastMsg.timestamp >= intervalMs) {
            const lastProactiveTime = parseInt(ChatDB.getItem(`last_proactive_time_${currentLoginId}_${charId}`) || '0');
            // 确保距离上次主动触发也超过了间隔时间，防止频繁触发
            if (now - lastProactiveTime >= intervalMs) {
                ChatDB.setItem(`last_proactive_time_${currentLoginId}_${charId}`, now.toString());
                // 触发主动发消息
                generateApiReply(true, charId);
            }
        }
    });
}

// 初始化 Web Worker
if (window.Worker) {
    const keepAliveWorker = new Worker('worker.js');
    
    // 接收 Worker 发来的心跳信号
    keepAliveWorker.addEventListener('message', (e) => {
        if (e.data === 'tick') {
            checkActiveMessages();
        }
    });

    // 启动 Worker，每 60 秒触发一次
    keepAliveWorker.postMessage({ command: 'start', interval: 60000 });
} else {
    // 兜底方案：如果浏览器不支持 Worker，退回使用 setInterval
    setInterval(checkActiveMessages, 60000);
}

