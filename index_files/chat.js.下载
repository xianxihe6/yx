    if (html.includes('<img')) {
        const match = html.match(/src="([^"]+)"/);
        if (match && match[1]) {
            contentEl.innerHTML = `<img src="${match[1]}">`;
        }
    } else if (html.includes('chat-desc-img-120')) {
        const match = html.match(/<div class="img-text">([\s\S]*?)<\/div>/);
