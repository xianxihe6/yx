async function summaryFetchModels() {
    const urlInput = document.getElementById('memApiUrl').value.trim().replace(/\/$/, '');
    const key = document.getElementById('memApiKey').value.trim();
    const select = document.getElementById('memApiModel');
    
    if (!urlInput || !key) return alert('请先填写总结专属 API 的 URL 和 Key');

    select.innerHTML = '<option>拉取中...</option>';
    const targetUrl = `${urlInput}/models`;

    try {
        let res;
        try {
            res = await fetch(targetUrl, {
                method: 'GET',
                headers: { 'Authorization': `Bearer ${key}` }
            });
        } catch (directErr) {
            const proxyUrl = `https://corsproxy.io/?${encodeURIComponent(targetUrl)}`;
            res = await fetch(proxyUrl, {
                method: 'GET',
                headers: { 'Authorization': `Bearer ${key}` }
            });
        }
        
        if (!res.ok) throw new Error(`HTTP 状态码错误: ${res.status}`);
        const data = await res.json();
        
        if (data.data && Array.isArray(data.data)) {
            window.summaryFetchedModels = data.data.map(m => ({ id: m.id })); 
            summaryRenderModelSelect(); 
            saveMemorySettingsDirectly(); // 拉取成功后自动保存
            alert(`成功拉取 ${data.data.length} 个模型！`);
        } else {
            window.summaryFetchedModels = [];
            select.innerHTML = '<option>未找到模型</option>';
            alert("拉取失败：接口返回的数据格式不正确");
        }
    } catch (e) {
        window.summaryFetchedModels = [];
        select.innerHTML = '<option>拉取失败</option>';
        alert('拉取失败！请检查地址、Key是否正确。\n详细错误: ' + e.message);
    }
}

