// 批量执行召唤
async function executeMomentSummonBatch() {
    if (selectedSummonCharIds.length === 0) return alert('请先选择要召唤的角色！');
    document.getElementById('momentSummonModalOverlay').classList.remove('show');

    showToast(`正在召唤 ${selectedSummonCharIds.length} 个角色...`, 'loading');

    let successCount = 0;
    // 使用 for 循环按顺序请求，防止并发过多导致 API 报错或数据库写入冲突
    for (let charId of selectedSummonCharIds) {
        try {
            await executeMomentSummonSingle(charId);
            successCount++;
        } catch (e) {
            console.error(`召唤角色 ${charId} 失败:`, e);
        }
    }

    hideToast();
    alert(`成功召唤 ${successCount} 个角色！`);
    
    // 统一刷新朋友圈 UI
    if (document.getElementById('tab-moment').style.display === 'flex') {
        renderMoments();
    }
}

// 单个角色召唤逻辑 (剥离了 UI 刷新和弹窗，专供批量调用)
async function executeMomentSummonSingle(charId) {
    const currentLoginId = ChatDB.getItem('current_login_account');
    if (!currentLoginId || !currentSummonMomentId) return;

    const apiConfig = JSON.parse(ChatDB.getItem('current_api_config') || '{}');
    if (!apiConfig.url || !apiConfig.key || !apiConfig.model) throw new Error('未配置API');

    let allEntities = getAllEntities();
    const char = allEntities.find(c => c.id === charId);
    if (!char) return;

    let moments = JSON.parse(ChatDB.getItem(`moments_${currentLoginId}`) || '[]');
    const moment = moments.find(m => m.id === currentSummonMomentId);
    if (!moment) return;

    const author = allEntities.find(e => e.id === moment.authorId);
    const authorName = author ? (author.netName || author.name) : '未知';
    
    let authorRoleDesc = moment.authorId === currentLoginId ? `用户 ${authorName}` : (moment.authorId === charId ? `你自己` : `其他好友 ${authorName}`);

    let imgInfo = moment.images && moment.images.length > 0 ? moment.images.map(img => img.type === 'desc' ? `[图片描述: ${img.text}]` : "[真实图片]").join(" ") : "无";
    let comments = (moment.comments || []).map(c => {
        let cAuthor = allEntities.find(e => e.id === c.authorId);
        let cName = cAuthor ? (cAuthor.netName || cAuthor.name) : '未知';
        return `${cName}: ${c.content}`;
    }).join(" | ");

    let momentContext = `【朋友圈动态信息】\n发布者: ${authorRoleDesc}\n内容: ${moment.content}\n配图: ${imgInfo}\n已有评论: ${comments || '暂无评论'}`;

    let activeWbs = [];
    if (char.wbEntries && char.wbEntries.length > 0) {
        let wbData = JSON.parse(ChatDB.getItem('worldbook_data')) || { entries: [] };
        let entries = wbData.entries.filter(e => char.wbEntries.includes(e.id));
        entries.forEach(entry => { if (entry.constant) activeWbs.push(entry.content); });
    }
    
    let memory = JSON.parse(ChatDB.getItem(`char_memory_${currentLoginId}_${charId}`) || '{}');
    let coreMemories = memory.core || [];

    // 获取用户人设
    let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
    const account = accounts.find(a => a.id === currentLoginId);
    let personas = JSON.parse(ChatDB.getItem('chat_personas') || '[]');
    const persona = personas.find(p => p.id === (account ? account.personaId : null));
    const userPersonaText = persona ? persona.persona : '无';

    // 获取最近聊天记录
    let chatHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${charId}`) || '[]');
    let recentHistory = chatHistory.slice(-10).map(m => `${m.role === 'user' ? 'User' : 'Char'}: ${m.content}`).join('\n');

    const prompt = `你是：${char.name}，你正在使用一款名为“微信”的线上聊天软件，请完全沉浸在你的角色设定和现实生活。
【你的设定】：${char.description || '无'}
【用户设定】：${userPersonaText}
【世界书背景】：${activeWbs.join('\n')}
【核心记忆】：${coreMemories.map(m => m.content).join('\n')}
【最近聊天记录】：
${recentHistory || '暂无聊天记录'}

你刚刚看到了以下这条朋友圈动态：
${momentContext}

请根据你的人设，对这条朋友圈做出反应。你可以选择点赞、评论，或者因为这条朋友圈的内容而主动私聊发布者。
必须且只能返回一个合法的 JSON 对象，格式如下：
{
  "action": "like" 或 "comment" 或 "chat",
  "commentContent": "如果选择评论，这里填写评论内容(可包含回复某人)",
  "chatContent": "如果选择私聊，这里填写私聊发过去的第一句话"
}
注意：如果你选择私聊，请在 chatContent 中自然地提及这条朋友圈的内容。`;

    const response = await fetch(`${apiConfig.url.replace(/\/$/, '')}/chat/completions`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${apiConfig.key}` },
        body: JSON.stringify({ model: apiConfig.model, messages: [{ role: 'user', content: prompt }], temperature: 0.8 })
    });

    if (!response.ok) throw new Error('API 请求失败');

    const data = await response.json();
    let replyRaw = data.choices[0].message.content.trim();
    replyRaw = replyRaw.replace(/^```json/i, '').replace(/^```/i, '').replace(/```$/i, '').trim();
    const parsed = JSON.parse(replyRaw);

    let momentsUpdated = false;

    if (parsed.action === 'like') {
        if (!moment.likes) moment.likes = [];
        if (!moment.likes.includes(charId)) {
            moment.likes.push(charId);
            momentsUpdated = true;
        }
    } else if (parsed.action === 'comment' && parsed.commentContent) {
        if (!moment.comments) moment.comments = [];
        moment.comments.push({
            id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
            authorId: charId,
            content: parsed.commentContent
        });
        momentsUpdated = true;
    } else if (parsed.action === 'chat' && parsed.chatContent) {
        let history = JSON.parse(ChatDB.getItem(`chat_history_${moment.authorId}_${charId}`) || '[]');
        history.push({
            role: 'char',
            content: parsed.chatContent,
            timestamp: Date.now()
        });
        ChatDB.setItem(`chat_history_${moment.authorId}_${charId}`, JSON.stringify(history));
        
        let sessions = JSON.parse(ChatDB.getItem(`chat_sessions_${moment.authorId}`) || '[]');
        sessions = sessions.filter(id => id !== charId);
        sessions.unshift(charId);
        ChatDB.setItem(`chat_sessions_${moment.authorId}`, JSON.stringify(sessions));
        
        let unreadCount = parseInt(ChatDB.getItem(`unread_${moment.authorId}_${charId}`) || '0');
        ChatDB.setItem(`unread_${moment.authorId}_${charId}`, (unreadCount + 1).toString());
        
        if (ChatDB.getItem('sys_notif_mode') === 'always' || document.hidden) {
            showCustomNotification('chat', charId, char.netName || char.name, parsed.chatContent, char.avatarUrl);
        }
    }

    if (momentsUpdated) {
        ChatDB.setItem(`moments_${currentLoginId}`, JSON.stringify(moments));
    }
}

