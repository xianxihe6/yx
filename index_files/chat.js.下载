            if (keys.length > 0) {
                const randomKey = keys[Math.floor(Math.random() * keys.length)];
                randomKey.classList.add('active-press');
                setTimeout(() => randomKey.classList.remove('active-press'), 50);
            }
            setTimeout(type, 50 + Math.random() * 50);
        }
    }
    type();
}

