function actionDeleteSession() {
    if (currentActionSessionId === 'linked_account_virtual_id') {
        alert('关联账号会话无法直接删除，请前往设置关闭开关。');
        closeSessionMenu();
        return;
    }
    if (confirm('确定删除该会话吗？聊天记录将保留。')) {
        const currentLoginId = ChatDB.getItem('current_login_account');
        let sessions = JSON.parse(ChatDB.getItem(`chat_sessions_${currentLoginId}`) || '[]');
        sessions = sessions.filter(id => id !== currentActionSessionId);
        ChatDB.setItem(`chat_sessions_${currentLoginId}`, JSON.stringify(sessions));
        
        // 双向同步删除会话
        let targetSessions = JSON.parse(ChatDB.getItem(`chat_sessions_${currentActionSessionId}`) || '[]');
        targetSessions = targetSessions.filter(id => id !== currentLoginId);
        ChatDB.setItem(`chat_sessions_${currentActionSessionId}`, JSON.stringify(targetSessions));
        
        renderChatList();
        closeSessionMenu();
    }
}

function actionMarkRead() {
    closeSessionMenu();
}

let currentMoveTargetGroup = '';

function actionMoveGroup() {
    closeSessionMenu();
    if (currentActionSessionId === 'linked_account_virtual_id') {
        alert('关联账号虚拟会话无法移动分组。');
        return;
    }

    const currentLoginId = ChatDB.getItem('current_login_account');
    let userGroups = JSON.parse(ChatDB.getItem(`contact_groups_${currentLoginId}`) || '["默认分组"]');

    // 获取当前实体的分组
    let allEntities = getAllEntities();
    const targetEntity = allEntities.find(e => e.id === currentActionSessionId);
    if (!targetEntity) return;
    
    currentMoveTargetGroup = targetEntity.contactGroup || '默认分组';

    // 动态创建 ins 风弹窗
    let modalOverlay = document.getElementById('moveGroupModalOverlay');
    if (!modalOverlay) {
        const modalHtml = `
        <div class="preset-modal-overlay" id="moveGroupModalOverlay" style="z-index: 10000;">
            <div class="preset-modal" style="width: 280px; max-height: 70vh; border-radius: 20px;">
                <div class="preset-modal-title" style="font-size: 16px; font-weight: bold; padding-top: 20px;">移动分组</div>
                <div id="moveGroupList" style="width: 100%; overflow-y: auto; padding: 15px 20px; display: flex; flex-direction: column; gap: 12px;">
                </div>
                <div class="preset-modal-actions" style="border-top: 1px solid #f0f0f0;">
                    <div class="preset-btn-cancel" style="color: #888; font-weight: normal;" onclick="document.getElementById('moveGroupModalOverlay').classList.remove('show')">取消</div>
                    <div class="preset-btn-confirm" style="color: #007AFF;" onclick="executeMoveGroup()">完成</div>
                </div>
            </div>
        </div>`;
        document.body.insertAdjacentHTML('beforeend', modalHtml);
        modalOverlay = document.getElementById('moveGroupModalOverlay');
    }

    renderMoveGroupList(userGroups);
    modalOverlay.classList.add('show');
}

function renderMoveGroupList(userGroups) {
    const listContainer = document.getElementById('moveGroupList');
    listContainer.innerHTML = '';
    
    userGroups.forEach(g => {
        const isChecked = (g === currentMoveTargetGroup);
        const item = document.createElement('label');
        // ins 风 UI：浅灰背景，圆角，选中时加深边框
        item.style.cssText = 'display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; background: #f7f7f8; border-radius: 14px; cursor: pointer; border: 1.5px solid ' + (isChecked ? '#111' : 'transparent') + '; transition: all 0.2s ease;';
        
        // 自定义圆形勾选框
        item.innerHTML = `
            <div style="font-size: 15px; font-weight: 600; color: ${isChecked ? '#111' : '#333'};">${g}</div>
            <div style="width: 22px; height: 22px; border-radius: 50%; border: 2px solid ${isChecked ? '#111' : '#ddd'}; display: flex; justify-content: center; align-items: center; background: ${isChecked ? '#111' : 'transparent'}; transition: all 0.2s ease;">
                ${isChecked ? '<svg viewBox="0 0 24 24" width="14" height="14" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>' : ''}
            </div>
        `;
        
        item.onclick = (e) => {
            e.preventDefault(); // 阻止默认行为，接管点击
            currentMoveTargetGroup = g;
            renderMoveGroupList(userGroups); // 重新渲染刷新勾选状态
        };
        listContainer.appendChild(item);
    });
}

function executeMoveGroup() {
    if (!currentMoveTargetGroup) return alert('请选择一个分组！');
    
    let allEntities = getAllEntities();
    const targetEntity = allEntities.find(e => e.id === currentActionSessionId);
    if (!targetEntity) return;

    let modified = false;
    if (targetEntity.isAccount) {
        let accounts = JSON.parse(ChatDB.getItem('chat_accounts') || '[]');
        const idx = accounts.findIndex(a => a.id === currentActionSessionId);
        if (idx !== -1) {
            accounts[idx].contactGroup = currentMoveTargetGroup;
            ChatDB.setItem('chat_accounts', JSON.stringify(accounts));
            modified = true;
        }
    } else if (targetEntity.isNPC) {
        let npcs = JSON.parse(ChatDB.getItem('chat_npcs') || '[]');
        const idx = npcs.findIndex(n => n.id === currentActionSessionId);
        if (idx !== -1) {
            npcs[idx].contactGroup = currentMoveTargetGroup;
            ChatDB.setItem('chat_npcs', JSON.stringify(npcs));
            modified = true;
        }
    } else {
        let chars = JSON.parse(ChatDB.getItem('chat_chars') || '[]');
        const idx = chars.findIndex(c => c.id === currentActionSessionId);
        if (idx !== -1) {
            chars[idx].contactGroup = currentMoveTargetGroup;
            ChatDB.setItem('chat_chars', JSON.stringify(chars));
            modified = true;
        }
    }

    if (modified) {
        document.getElementById('moveGroupModalOverlay').classList.remove('show');
        showToast(`已移动至 ${currentMoveTargetGroup}`, 'success', 1500);
        if (typeof renderContactList === 'function') renderContactList();
    }
}

// --- 通讯录子 Tab 切换逻辑 ---

function switchContactSubTab(tabName) {
    const btns = document.querySelectorAll('.contact-nav-btn');
    const wrapper = document.getElementById('contactSliderWrapper');
    
    btns.forEach(btn => btn.classList.remove('active'));
    
    if (tabName === 'categories') {
        btns[0].classList.add('active');
        wrapper.style.transform = 'translateX(0%)';
