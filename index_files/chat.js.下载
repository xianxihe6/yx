function renderMemoryTimeline() {
    const personaId = getCurrentPersonaIdForMemory();
    let memory = JSON.parse(ChatDB.getItem(`char_memory_${personaId}_${currentProfileCharId}`) || '{}');
    const container = document.getElementById('memoryTimelineList');
    container.innerHTML = '';

    // 将 summary 和 archive 混合并按时间戳(id)排序
    let allTimelineData = [];
    if (memory.summary) memory.summary.forEach(m => allTimelineData.push({...m, _type: 'summary'}));
    if (memory.archive) memory.archive.forEach(m => allTimelineData.push({...m, _type: 'archive'}));

    if (allTimelineData.length === 0) {
        container.innerHTML = '<div style="text-align: center; color: #aaa; font-size: 13px; margin-top: 40px;">暂无记忆记录</div>';
        return;
    }

    // 按 ID (时间戳) 倒序排列，最新的在上面
    allTimelineData.sort((a, b) => parseInt(b.id) - parseInt(a.id));

    allTimelineData.forEach(item => {
        const date = new Date(parseInt(item.id));
        const dateStr = `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-${String(date.getDate()).padStart(2,'0')}`;
        const isArchive = item._type === 'archive';
        
        const card = document.createElement('div');
        card.className = 'mem-tl-card';
        card.innerHTML = `
            <div class="mem-tl-dot ${isArchive ? 'archive' : ''}">${isArchive ? '冷' : '热'}</div>
            <div class="mem-tl-content">
                <div class="mem-tl-header">
                    <span class="mem-tl-date">${dateStr}</span>
                    <span class="mem-tl-type">${isArchive ? '已归档' : '活跃总结'}</span>
                </div>
                <div class="mem-tl-body">${item.content.replace(/\n/g, '<br>')}</div>
            </div>
        `;
        container.appendChild(card);
    });
}

