let currentPlayingAudio = null;
let currentPlayingWaves = null;

async function playVoiceMessage(index, element) {
    toggleVoiceText(index); // 保持原有的展开文字功能

    const currentLoginId = ChatDB.getItem('current_login_account');
    if (!currentLoginId || !currentChatRoomCharId) return;

    let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`) || '[]');
    const msg = history[index];
    if (!msg || !msg.content) return;

    const wavesEl = element.querySelector('.voice-waves');

    // 停止当前正在播放的音频
    if (currentPlayingAudio) {
        currentPlayingAudio.pause();
        if (currentPlayingWaves) {
            Array.from(currentPlayingWaves.children).forEach(w => w.style.animationPlayState = 'paused');
        }
    }

    // 播放完成的回调
    const onEnded = () => {
        Array.from(wavesEl.children).forEach(w => w.style.animationPlayState = 'paused');
        currentPlayingAudio = null;
        currentPlayingWaves = null;
    };

    // 如果已经有缓存的音频数据，直接播放 (防重复扣费)
    if (msg.audioData) {
        currentPlayingAudio = new Audio(msg.audioData);
        currentPlayingWaves = wavesEl;
        Array.from(wavesEl.children).forEach(w => w.style.animationPlayState = 'running');
        currentPlayingAudio.onended = onEnded;
        currentPlayingAudio.play().catch(e => {
            console.error("播放缓存音频失败:", e);
            onEnded();
        });
        return;
    }

    // 如果没有缓存，调用 MiniMax API 生成
    const ttsConfig = JSON.parse(ChatDB.getItem('minimax_api_config') || '{}');
    
    // 检查是否开启了真实语音开关
    if (ttsConfig.enabled === false) {
        return; // 未开启则直接返回，仅展示文字，不消耗额度
    }

    if (!ttsConfig.key || !ttsConfig.groupId) {
        alert('请先在设置中配置 MiniMax 语音 API 的 Key 和 Group ID！');
        return;
    }

    // 获取角色音色 ID
    let voiceId = ttsConfig.defaultVoiceId || 'male-qn-qingnian';
    if (msg.role === 'char') {
        let chars = JSON.parse(ChatDB.getItem('chat_chars') || '[]');
        const char = chars.find(c => c.id === currentChatRoomCharId);
        if (char && char.voiceId) {
            voiceId = char.voiceId;
        }
    }

    const baseUrl = ttsConfig.region === 'overseas' ? 'https://api.minimaxi.chat' : 'https://api.minimax.chat';
    const url = `${baseUrl}/v1/t2a_v2?GroupId=${ttsConfig.groupId}`;

    showToast('正在生成语音...', 'loading');
    try {
        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${ttsConfig.key}`
            },
            body: JSON.stringify({
                model: ttsConfig.model || 'speech-2.8-hd',
                text: msg.content,
                stream: false,
                voice_setting: {
                    voice_id: voiceId,
                    speed: 1,
                    vol: 1,
                    pitch: 0
                },
                audio_setting: {
                    sample_rate: 32000,
                    bitrate: 128000,
                    format: "mp3"
                }
            })
        });

        if (!response.ok) {
            const err = await response.json();
            throw new Error(err.base_resp ? err.base_resp.status_msg : '请求失败');
        }

        const data = await response.json();
        if (data.base_resp && data.base_resp.status_code !== 0) {
            throw new Error(data.base_resp.status_msg);
        }

        // 将返回的 hex 字符串转为 Base64
        const hexString = data.data.audio;
        const bytes = new Uint8Array(Math.ceil(hexString.length / 2));
        for (let i = 0; i < bytes.length; i++) {
            bytes[i] = parseInt(hexString.substr(i * 2, 2), 16);
        }
        let binary = '';
        for (let i = 0; i < bytes.byteLength; i++) {
            binary += String.fromCharCode(bytes[i]);
        }
        const base64Audio = 'data:audio/mp3;base64,' + window.btoa(binary);

        // 存入缓存并保存到数据库
        msg.audioData = base64Audio;
        history[index] = msg;
        ChatDB.setItem(`chat_history_${currentLoginId}_${currentChatRoomCharId}`, JSON.stringify(history));

        hideToast();

        // 播放生成的音频
        currentPlayingAudio = new Audio(base64Audio);
        currentPlayingWaves = wavesEl;
        Array.from(wavesEl.children).forEach(w => w.style.animationPlayState = 'running');
        currentPlayingAudio.onended = onEnded;
        currentPlayingAudio.play().catch(e => {
            console.error("播放生成的音频失败:", e);
            onEnded();
        });

    } catch (error) {
        hideToast();
        alert('语音生成失败: ' + error.message);
    }
}

