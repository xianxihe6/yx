// 兼容旧版浏览器的 CSS 作用域限制函数
function scopeCss(css, scopeSelector) {
    if (!css) return '';
    let processed = css.replace(/\/\*[\s\S]*?\*\//g, ''); // 移除注释
    return processed.replace(/(^|\})\s*([^{]+)\s*\{/g, function(match, before, selector) {
        let scopedSelector = selector.split(',').map(s => {
            s = s.trim();
            // 忽略 @ 规则 (如 @media, @keyframes) 和动画关键帧 (from, to, 50%)
            if (!s || s.startsWith('@') || s === 'from' || s === 'to' || /^[0-9]+%$/.test(s)) return s;
            
            // 【核心修复】：检查用户写的 CSS 是否已经自带了作用域前缀
            let scopes = scopeSelector.split(',').map(x => x.trim());
            for (let scope of scopes) {
                if (s.startsWith(scope)) {
                    return s; // 如果已经自带了前缀（比如 #wechatPanel），就直接返回，防止变成 #wechatPanel #wechatPanel
                }
            }
            
            // 如果没有自带前缀，才自动拼接
            return scopes.map(scope => scope + ' ' + s).join(', ');
        }).join(', ');
        return before + '\n' + scopedSelector + ' {';
    });
}

