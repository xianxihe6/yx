    // 搜索过滤
    if (keyword) {
        list = list.filter(m => m.content.toLowerCase().includes(keyword) || (m.tags && m.tags.join(',').toLowerCase().includes(keyword)));
    }

    if (list.length === 0) {
        container.innerHTML = '<div style="text-align: center; color: #aaa; font-size: 13px; margin-top: 40px;">暂无数据</div>';
