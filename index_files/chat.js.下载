function showAvatarUploadOptions(onLocalClick, onUrlSubmit) {
    let overlay = document.getElementById('avatarUploadOptionsOverlay');
    if (!overlay) {
        overlay = document.createElement('div');
        overlay.id = 'avatarUploadOptionsOverlay';
        overlay.className = 'preset-modal-overlay';
        overlay.style.zIndex = '9999'; // 强制最高层级，防止被面具面板遮挡
        overlay.innerHTML = `
            <div class="preset-modal" style="width: 280px;">
                <div class="preset-modal-title">更换头像</div>
                <div class="preset-modal-desc">请选择上传方式</div>
                <div style="width: 100%; padding: 15px 20px; display: flex; flex-direction: column; gap: 10px;">
                    <button id="btnAvatarLocal" style="width: 100%; padding: 12px; border-radius: 10px; border: none; background: #111; color: #fff; font-size: 14px; font-weight: bold; cursor: pointer;">本地相册上传</button>
                    <button id="btnAvatarUrl" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #ddd; background: #fff; color: #333; font-size: 14px; font-weight: bold; cursor: pointer;">使用 URL 上传</button>
                </div>
                <div class="preset-modal-actions">
                    <div class="preset-btn-cancel" style="width: 100%;" onclick="document.getElementById('avatarUploadOptionsOverlay').classList.remove('show')">取消</div>
                </div>
            </div>
        `;
        document.body.appendChild(overlay);
    }
    
    document.getElementById('btnAvatarLocal').onclick = () => {
        overlay.classList.remove('show');
        if (onLocalClick) onLocalClick();
    };
    
    document.getElementById('btnAvatarUrl').onclick = () => {
        overlay.classList.remove('show');
        setTimeout(() => {
            openGlobalPrompt('URL 上传', '请输入图片 URL', 'https://...', (url) => {
                if (url && url.trim()) {
                    if (onUrlSubmit) onUrlSubmit(url.trim());
                }
            });
        }, 300);
    };
    
    overlay.classList.add('show');
}

