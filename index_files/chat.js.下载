            item.innerHTML = `
                <input type="checkbox" value="${charId}" class="target-clear-cb" checked style="width: 18px; height: 18px; accent-color: #111; flex-shrink: 0;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background-image: url('${char ? char.avatarUrl : ''}'); background-size: cover; background-color: #ccc; flex-shrink: 0;"></div>
                <span style="font-size: 14px; color: #333; font-weight: bold; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${charName}</span>
            `;
            listContainer.appendChild(item);
        }
    }

    if (!hasCss) {
        listContainer.innerHTML = '<div style="text-align:center; color:#888; font-size:13px; padding: 20px 0;">当前账号下没有设置过自定义 CSS 的角色</div>';
    }

    document.getElementById('targetedClearModalOverlay').classList.add('show');
}

function closeTargetedClearModal() {
    document.getElementById('targetedClearModalOverlay').classList.remove('show');
}

function executeTargetedClear() {
    const currentLoginId = ChatDB.getItem('current_login_account');
    const checkboxes = document.querySelectorAll('.target-clear-cb:checked');
    
    if (checkboxes.length === 0) {
        return alert('请至少勾选一个要清空的角色！');
    }

    let clearCount = 0;
    checkboxes.forEach(cb => {
        const charId = cb.value;
        ChatDB.removeItem(`chat_current_css_${currentLoginId}_${charId}`);
        clearCount++;
        
        // 如果清空的是当前正在聊天的角色，实时清空预览
        if (charId === currentChatRoomCharId) {
            const input = document.getElementById('chatCustomCssInput');
            if (input) input.value = '';
            const styleTag = document.getElementById('customChatCssTag');
            if (styleTag) styleTag.innerHTML = '';
        }
    });

    if (typeof updateChatRoomAppearance === 'function') updateChatRoomAppearance();

    closeTargetedClearModal();
    showToast(`成功清空 ${clearCount} 个角色的 CSS`, 'success', 1500);
}

// 强制清空弹窗的关闭与执行
function closeForceClearAllCssModal() {
    document.getElementById('forceClearAllCssModalOverlay').classList.remove('show');
}

function executeForceClearAllCss() {
    let clearCount = 0;
    const keysToRemove = [];
    
    // 核心修复：遍历 ChatMemoryCache 而不是 localStorage，解决清空 0 个的问题
    for (let key in window.ChatMemoryCache) {
        if (key && key.includes('chat_current_css_')) {
            keysToRemove.push(key);
        }
    }
    
    keysToRemove.forEach(key => {
        ChatDB.removeItem(key);
        clearCount++;
    });
    
    // 清空当前输入框和全局样式渲染
    const input = document.getElementById('chatCustomCssInput');
    if (input) input.value = '';
    const styleTag = document.getElementById('customChatCssTag');
    if (styleTag) styleTag.innerHTML = '';
    
    closeForceClearAllCssModal();
    alert(`已强制清空全站 ${clearCount} 个角色的自定义 CSS！`);
}
