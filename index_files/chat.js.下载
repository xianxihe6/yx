// AI 生图核心引擎 (支持 Free / OpenAI / NovelAI)
// ==========================================
async function generateImageFromAPI(prompt, charId, config) {
    let allEntities = getAllEntities();
    const char = allEntities.find(c => c.id === charId);
    
    // 拼接提示词
    let finalPrompt = "";
    if (config.globalPositive) finalPrompt += config.globalPositive + ", ";
    if (char && char.appearance) finalPrompt += char.appearance + ", ";
    finalPrompt += prompt;

    const size = config.size || '832x1216';
    let width = 832, height = 1216;
    if (size === '1024x1024') { width = 1024; height = 1024; }
    else if (size === '1216x832') { width = 1216; height = 832; }

    if (config.engine === 'free') {
        // Pollinations.ai 免费节点
        const url = `https://image.pollinations.ai/prompt/${encodeURIComponent(finalPrompt)}?width=${width}&height=${height}&nologo=true`;
        const res = await fetch(url);
        if (!res.ok) throw new Error('Free API failed');
        const blob = await res.blob();
        return new Promise((resolve) => {
            const reader = new FileReader();
            reader.onloadend = () => resolve(reader.result);
            reader.readAsDataURL(blob);
        });
    } 
    else if (config.engine === 'openai') {
        // OpenAI 兼容节点 (DALL-E / Midjourney)
        const url = (config.openaiUrl || 'https://api.openai.com/v1').replace(/\/$/, '') + '/images/generations';
        const res = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${config.openaiKey}`
            },
            body: JSON.stringify({
                model: config.openaiModel || 'dall-e-3',
                prompt: finalPrompt,
                n: 1,
                size: size === '832x1216' ? '1024x1792' : (size === '1216x832' ? '1792x1024' : '1024x1024'), // DALL-E 3 标准尺寸映射
                response_format: 'b64_json'
            })
        });
        if (!res.ok) throw new Error('OpenAI API failed');
        const data = await res.json();
        if (data.data && data.data[0] && data.data[0].b64_json) {
            return `data:image/png;base64,${data.data[0].b64_json}`;
        }
        throw new Error('No b64_json in response');
    }
    else if (config.engine === 'novelai') {
        // NovelAI 专属节点
        const url = 'https://api.novelai.net/ai/generate-image';
        const payload = {
            input: finalPrompt,
            model: config.novelaiModel || 'nai-diffusion-3',
            action: "generate",
            parameters: {
                width: width,
                height: height,
                scale: 5.0,
                sampler: "k_euler",
                steps: config.quality === 'hd' ? 28 : 20,
                n_samples: 1,
                ucPreset: 0,
                qualityToggle: true,
                sm: false,
                sm_dyn: false,
                dynamic_thresholding: false,
                controlnet_strength: 1,
                legacy: false,
                add_original_image: true,
                uncond_scale: 1,
                cfg_rescale: 0,
                noise_schedule: "native",
                negative_prompt: config.globalNegative || "lowres, bad anatomy, bad hands, text, error, missing fingers, extra digit, fewer digits, cropped, worst quality, low quality, normal quality, jpeg artifacts, signature, watermark, username, blurry"
            }
        };

        // 如果有参考图，加入图生图参数
        if (char && char.refImageUrl && char.refImageUrl.startsWith('data:image')) {
            const b64Data = char.refImageUrl.split(',')[1];
            payload.parameters.image = b64Data;
            payload.parameters.extra_noise_seed = 42;
            payload.parameters.strength = 0.6; // 图生图强度
        }

        const res = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${config.novelaiKey}`
            },
            body: JSON.stringify(payload)
        });

        if (!res.ok) throw new Error('NovelAI API failed');
        
        // NovelAI 返回的是一个 ZIP 文件 (包含 txt 和 png)
        const arrayBuffer = await res.arrayBuffer();
        const uint8Array = new Uint8Array(arrayBuffer);
        
        // 简单的 ZIP 提取 PNG 逻辑 (寻找 PNG 文件头 89 50 4E 47 0D 0A 1A 0A)
        const pngHeader = [0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A];
        let pngStart = -1;
        for (let i = 0; i < uint8Array.length - 8; i++) {
            let match = true;
            for (let j = 0; j < 8; j++) {
                if (uint8Array[i + j] !== pngHeader[j]) {
                    match = false;
                    break;
                }
            }
            if (match) {
                pngStart = i;
                break;
            }
        }

        if (pngStart !== -1) {
            // 找到 PNG 结尾 (IEND chunk: 49 45 4E 44 AE 42 60 82)
            const iend = [0x49, 0x45, 0x4E, 0x44, 0xAE, 0x42, 0x60, 0x82];
            let pngEnd = -1;
            for (let i = pngStart; i < uint8Array.length - 8; i++) {
                let match = true;
                for (let j = 0; j < 8; j++) {
                    if (uint8Array[i + j] !== iend[j]) {
                        match = false;
                        break;
                    }
                }
                if (match) {
                    pngEnd = i + 8;
                    break;
                }
            }
            
            if (pngEnd !== -1) {
                const pngData = uint8Array.slice(pngStart, pngEnd);
                let binary = '';
                for (let i = 0; i < pngData.byteLength; i++) {
                    binary += String.fromCharCode(pngData[i]);
                }
                return `data:image/png;base64,${window.btoa(binary)}`;
            }
        }
        throw new Error('Failed to extract PNG from NovelAI response');
    }
    return null;
}

// ==========================================
// 读心术 (True Thoughts) 刮刮乐交互逻辑
// ==========================================
// (原有的 scratchState 声明已移至顶部)

function handleScratchStart(e, index) {
    if (isChatMultiSelecting) return;
    
    // 同时触发长按菜单计时器
    handleBubbleTouchStart(e, index);

    const wrapper = document.getElementById(`thought-wrap-${index}`);
    if (!wrapper || wrapper.classList.contains('revealed')) return;

    const rect = wrapper.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    const x = clientX - rect.left;
    const y = clientY - rect.top;

    if (!scratchState[index]) {
        scratchState[index] = { path: '', length: 0, isDrawing: false, lastPoint: null };
    }
    scratchState[index].isDrawing = true;
    scratchState[index].lastPoint = { x, y };
    scratchState[index].path += `M ${x} ${y} `;
    
    const pathEl = document.getElementById(`scratch-path-${index}`);
    if (pathEl) pathEl.setAttribute('d', scratchState[index].path);
}

function handleScratchMove(e, index) {
    if (!scratchState[index] || !scratchState[index].isDrawing) return;
    
    // 【核心修复】：阻止默认行为，防止 iOS 触发页面滑动导致擦除中断和卡顿
    if (e.cancelable) {
        e.preventDefault();
    }
    
    // 如果手指移动了，取消长按菜单的触发
    handleBubbleTouchEnd();

    const wrapper = document.getElementById(`thought-wrap-${index}`);
    if (!wrapper || wrapper.classList.contains('revealed')) return;

    const rect = wrapper.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    const x = clientX - rect.left;
    const y = clientY - rect.top;

    // 【核心修复】：限制路径点密度，防止 iOS Safari 因 SVG Path 过长导致 GPU 渲染崩溃（变空白）
    const lastPoint = scratchState[index].lastPoint;
    if (lastPoint) {
        const dx = x - lastPoint.x;
        const dy = y - lastPoint.y;
        if (dx * dx + dy * dy < 100) { // 距离小于 10px 不记录，大幅减少路径节点
            return;
        }
    }
    scratchState[index].lastPoint = { x, y };

    scratchState[index].path += `L ${x} ${y} `;
    scratchState[index].length += 1; // 粗略计算滑动距离
    
    const pathEl = document.getElementById(`scratch-path-${index}`);
    if (pathEl) pathEl.setAttribute('d', scratchState[index].path);

    // 计算是否达到 80% 自动全显
    // 假设笔刷宽度为 30，粗略估算面积
    const bubbleArea = rect.width * rect.height;
    const scratchedArea = scratchState[index].length * 15 * 30; // 调整估算面积
    
    if (scratchedArea > bubbleArea * 0.8) {
        wrapper.classList.add('revealed');
        scratchState[index].isDrawing = false;
        
        // 【核心修复】：彻底移除 mask 并隐藏表层，防止 iOS Safari 渲染 Bug 导致气泡变空白
        const surfaceBubble = wrapper.querySelector('.cr-bubble-surface');
        if (surfaceBubble) {
            surfaceBubble.style.webkitMask = 'none';
            surfaceBubble.style.mask = 'none';
            surfaceBubble.style.display = 'none';
        }
    }
}

// 监听全局鼠标抬起，停止刮画
document.addEventListener('mouseup', () => {
    for (let key in scratchState) {
        scratchState[key].isDrawing = false;
    }
});
document.addEventListener('touchend', () => {
    for (let key in scratchState) {
        scratchState[key].isDrawing = false;
    }
});

// --- 恢复心声状态 ---
function actionRestoreThought() {
    closeChatBubbleMenu();
    const index = currentActionMsgIndex;
    const wrapper = document.getElementById(`thought-wrap-${index}`);
    const pathEl = document.getElementById(`scratch-path-${index}`);
    
    if (wrapper) {
        wrapper.classList.remove('revealed');
        
        // 【核心修复】：恢复表层气泡的显示和遮罩
        const surfaceBubble = wrapper.querySelector('.cr-bubble-surface');
        const maskEl = wrapper.querySelector('mask');
        if (surfaceBubble && maskEl) {
            surfaceBubble.style.display = '';
            surfaceBubble.style.webkitMask = `url(#${maskEl.id})`;
            surfaceBubble.style.mask = `url(#${maskEl.id})`;
        }

        if (pathEl) pathEl.setAttribute('d', '');
        if (scratchState[index]) {
            scratchState[index].path = '';
            scratchState[index].length = 0;
            scratchState[index].lastPoint = null;
        }
    }
}

