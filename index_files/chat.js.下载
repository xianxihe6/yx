// --- Web Push 核心逻辑 ---
// 辅助函数：将 Base64 的 VAPID 公钥转换为 Uint8Array
function urlBase64ToUint8Array(base64String) {
    const padding = '='.repeat((4 - base64String.length % 4) % 4);
    const base64 = (base64String + padding).replace(/\-/g, '+').replace(/_/g, '/');
    const rawData = window.atob(base64);
    const outputArray = new Uint8Array(rawData.length);
    for (let i = 0; i < rawData.length; ++i) {
        outputArray[i] = rawData.charCodeAt(i);
    }
    return outputArray;
}

// 申请通知权限并获取推送订阅
async function subscribeToPush(vapidPublicKey) {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
        throw new Error('当前浏览器不支持离线推送功能。');
    }
    const registration = await navigator.serviceWorker.ready;
    const convertedVapidKey = urlBase64ToUint8Array(vapidPublicKey);
    
    let subscription = await registration.pushManager.getSubscription();
    if (!subscription) {
        subscription = await registration.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: convertedVapidKey
        });
    }
    return subscription;
}

// 核心函数：将上下文和凭证同步给用户的专属后端
async function syncPushContextToBackend(isTest = false) {
    const currentLoginId = ChatDB.getItem('current_login_account');
    if (!currentLoginId) throw new Error('未登录');

    const configStr = ChatDB.getItem(`push_config_${currentLoginId}`);
    if (!configStr) throw new Error('未配置推送参数');
    const config = JSON.parse(configStr);

    if (!config.enabled) throw new Error('推送未启用');
    if (!config.vapidKey) throw new Error('VAPID 公钥为空');

    let backendUrl = '';
    let headers = { 'Content-Type': 'application/json' };

    if (config.platform === 'cloudflare') {
        backendUrl = config.cfUrl;
    } else if (config.platform === 'supabase') {
        backendUrl = config.sbUrl;
        if (config.sbKey) headers['Authorization'] = `Bearer ${config.sbKey}`;
    } else {
        backendUrl = config.customUrl;
    }

    if (!backendUrl) throw new Error('后端 URL 为空');

    // 1. 获取订阅凭证
    const subscription = await subscribeToPush(config.vapidKey);

    // 2. 组装发给后端的 Payload
    const apiConfig = JSON.parse(ChatDB.getItem('current_api_config') || '{}');
    
    let payload = {
        action: isTest ? "test_push" : "sync_context",
        push_subscription: subscription,
        llm_config: apiConfig,
        user_info: {},
        active_chars: [] // 存放所有需要离线推送的 Char
    };

    if (!isTest) {
        let allEntities = getAllEntities();
        const me = allEntities.find(a => a.id === currentLoginId);
        
        // 获取用户面具 (真实名称)
        let personas = JSON.parse(ChatDB.getItem('chat_personas') || '[]');
        const persona = personas.find(p => p.id === (me ? me.personaId : null));
        
        payload.user_info = {
            netName: me ? (me.netName || 'User') : 'User',
            realName: persona ? (persona.realName || 'User') : 'User',
            personaDesc: persona ? (persona.persona || '普通用户') : '普通用户'
        };

        // 遍历所有会话，找出开启了“主动发消息”的 Char
        let sessions = JSON.parse(ChatDB.getItem(`chat_sessions_${currentLoginId}`) || '[]');
        
        sessions.forEach(charId => {
            const isActiveEnabled = ChatDB.getItem(`chat_active_msg_${charId}`) === 'true';
            if (!isActiveEnabled) return; // 没开启主动发消息的跳过
            
            if (isCharSleeping(charId)) return; // 睡眠期间不推送离线消息

            const char = allEntities.find(c => c.id === charId);
            if (!char || char.isAccount) return; // 排除真实用户账号

            const intervalMinutes = parseInt(ChatDB.getItem(`chat_active_msg_interval_${charId}`)) || 60;
            let history = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${charId}`) || '[]');
            
            if (history.length === 0) return;
            const lastMsgTimestamp = history[history.length - 1].timestamp;

            // 提取世界书
            let activeWbs = [];
            if (char.wbEntries && char.wbEntries.length > 0) {
                let wbData = JSON.parse(ChatDB.getItem('worldbook_data')) || { entries: [] };
                let entries = wbData.entries.filter(e => char.wbEntries.includes(e.id));
                entries.forEach(entry => { if (entry.constant) activeWbs.push(entry.content); });
            }

            // 提取记忆库 (Core + Summary)
            const currentPersonaId = persona ? persona.id : currentLoginId;
            let memory = JSON.parse(ChatDB.getItem(`char_memory_${currentPersonaId}_${charId}`) || '{}');
            let memoryText = "";
            if (memory.core && memory.core.length > 0) {
                memoryText += "[核心记忆]\n" + memory.core.map(m => m.content).join('\n') + "\n";
            }
            if (memory.summary && memory.summary.length > 0) {
                // 取最近 3 条总结
                memoryText += "[近期剧情]\n" + memory.summary.slice(-3).map(m => m.content).join('\n');
            }

            // 提取最近 30 轮聊天记录 (60条)
            let recentHistory = history.slice(-60).map(m => ({
                role: m.role,
                content: m.content,
                timestamp: m.timestamp
            }));

            payload.active_chars.push({
                char_id: charId,
                char_name: char.name,
                char_desc: char.description || '',
                scenario: char.scenario || '',
                interval_minutes: intervalMinutes,
                last_msg_timestamp: lastMsgTimestamp,
                worldbook: activeWbs.join('\n'),
                memory: memoryText,
                history: recentHistory
            });
        });
    }

    // 3. 发送给后端
    const response = await fetch(backendUrl, {
        method: 'POST',
        headers: headers,
        body: JSON.stringify(payload)
    });

    if (!response.ok) {
        const errText = await response.text();
        throw new Error(`后端响应错误 (${response.status}): ${errText}`);
    }
    
    return await response.json();
}

