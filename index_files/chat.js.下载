                                return `<img src="${url}" alt="${desc.trim()}" style="width: 100px; height: 100px; object-fit: contain; border-radius: 8px; display: block; margin: 5px 0;">`;
                            }
                            return ''; // 如果表情包不存在，直接删掉这段幻觉文本
                        });

                        // 拦截 AI 幻觉输出的图片文本
                        const imgRegex = /\*?[^\*]*发送了一张(?:真实)?图片[：:]\s*\[?([^\]\*]+)\]?\*?/g;
                        textContent = textContent.replace(imgRegex, (match, desc) => {
                            return `<div class="chat-desc-img-120"><div class="img-text">${desc.trim()}</div></div>`;
                        });

                        textContent = textContent.trim();
                    }
                    newMsg.content = textContent;
                    if (!newMsg.content) continue; 
                }

                newMsg.quote = msgObj.quote || '';
                
                // 【核心修复】：提取并保存 AI 返回的真心话字段
                if (msgObj.true_thought) {
                    newMsg.true_thought = msgObj.true_thought;
                }

                let updatedHistory = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${targetCharId}`) || '[]');
                updatedHistory.push(newMsg);
                ChatDB.setItem(`chat_history_${currentLoginId}_${targetCharId}`, JSON.stringify(updatedHistory));
                
                if (char.isGroup) {
                    if (char.memberIds) {
                        char.memberIds.forEach(memberId => {
                            if (memberId === currentLoginId) return;
                            let memberHistory = JSON.parse(ChatDB.getItem(`chat_history_${memberId}_${targetCharId}`) || '[]');
                            let memberMsg = { ...newMsg, role: 'char' };
                            memberHistory.push(memberMsg);
                            ChatDB.setItem(`chat_history_${memberId}_${targetCharId}`, JSON.stringify(memberHistory));
                            
                            let memberSessions = JSON.parse(ChatDB.getItem(`chat_sessions_${memberId}`) || '[]');
                            memberSessions = memberSessions.filter(id => id !== targetCharId);
                            memberSessions.unshift(targetCharId);
                            ChatDB.setItem(`chat_sessions_${memberId}`, JSON.stringify(memberSessions));
                            
                            let unreadCount = parseInt(ChatDB.getItem(`unread_${memberId}_${targetCharId}`) || '0');
                            ChatDB.setItem(`unread_${memberId}_${targetCharId}`, (unreadCount + 1).toString());
                        });
                    }
                } else {
                    let targetHistory = JSON.parse(ChatDB.getItem(`chat_history_${targetCharId}_${currentLoginId}`) || '[]');
                    let targetMsg = { ...newMsg, role: 'user' }; 
                    targetHistory.push(targetMsg);
                    ChatDB.setItem(`chat_history_${targetCharId}_${currentLoginId}`, JSON.stringify(targetHistory));
                    
                    let targetSessions = JSON.parse(ChatDB.getItem(`chat_sessions_${targetCharId}`) || '[]');
                    targetSessions = targetSessions.filter(id => id !== currentLoginId);
                    targetSessions.unshift(currentLoginId);
                    ChatDB.setItem(`chat_sessions_${targetCharId}`, JSON.stringify(targetSessions));
                    
                    // 【核心修复】：AI (Char) 回复 User 时，不应该增加 Char 自己的未读数，否则会导致关联账号一直显示红点
                }
                
                updateInteractionStats(targetCharId, false);
                
                const chatRoomPanel = document.getElementById('chatRoomPanel');
                const isChatRoomVisible = chatRoomPanel && window.getComputedStyle(chatRoomPanel).display !== 'none';

                if (targetCharId === currentChatRoomCharId && isChatRoomVisible) {
                    renderChatHistory(currentChatRoomCharId);
                    // 核心修复：如果开启了全程弹窗，即使在聊天室内也触发真实系统通知
                    if (ChatDB.getItem('sys_notif_mode') === 'always') {
                        showMsgNotification(targetCharId, newMsg.content);
                    }
                } else {
                    let unreadCount = parseInt(ChatDB.getItem(`unread_${currentLoginId}_${targetCharId}`) || '0');
                    ChatDB.setItem(`unread_${currentLoginId}_${targetCharId}`, (unreadCount + 1).toString());
                    
                    showMsgNotification(targetCharId, newMsg.content);
                    if (typeof renderChatList === 'function') renderChatList();
                }
                
                const musicChatPanel = document.getElementById('musicChatPanel');
                if (musicChatPanel && window.getComputedStyle(musicChatPanel).display !== 'none' && targetCharId === window.currentListenTogetherCharId) {
                    if (typeof renderMusicChatHistory === 'function') renderMusicChatHistory();
                }

                if (i < messagesArray.length - 1) {
                    await new Promise(resolve => setTimeout(resolve, 1000));
                }
            }

            // 【恢复：触发分块自动总结】
            let latestHistoryForAuto = JSON.parse(ChatDB.getItem(`chat_history_${currentLoginId}_${targetCharId}`) || '[]');
            let validMsgsForAuto = latestHistoryForAuto.filter(m => m.type !== 'system' && m.type !== 'hidden_system');
            const currentTurns = Math.floor(validMsgsForAuto.length / 2); 
            
            let charMemoryForAuto = JSON.parse(ChatDB.getItem(`char_memory_${currentPersonaId}_${targetCharId}`) || '{}');
            
            if (charMemoryForAuto.settings && charMemoryForAuto.settings.autoSummarize) {
                const autoTurns = charMemoryForAuto.settings.autoTurns || 10;
                let lastTurn = charMemoryForAuto.lastAutoSummaryTurn || 0;
                
                // 【核心修复】：如果当前轮数小于上次总结轮数（说明清空了记录或删除了消息），重置 lastTurn
                if (currentTurns < lastTurn) {
                    lastTurn = currentTurns;
                    let latestMemory = JSON.parse(ChatDB.getItem(`char_memory_${currentPersonaId}_${targetCharId}`) || '{}');
                    latestMemory.lastAutoSummaryTurn = lastTurn;
                    ChatDB.setItem(`char_memory_${currentPersonaId}_${targetCharId}`, JSON.stringify(latestMemory));
                }

                // 修复：只要当前轮数减去上次总结的轮数 >= 设定的间隔，就触发总结，防止因多发消息跳过整数倍导致中断
                if (currentTurns - lastTurn >= autoTurns) {
                    // 核心修复：重新读取最新的 memory，防止覆盖
                    let latestMemory = JSON.parse(ChatDB.getItem(`char_memory_${currentPersonaId}_${targetCharId}`) || '{}');
                    latestMemory.lastAutoSummaryTurn = currentTurns;
                    ChatDB.setItem(`char_memory_${currentPersonaId}_${targetCharId}`, JSON.stringify(latestMemory));
                    // 静默调用总结，提取这几轮的独立记忆
                    executeSilentAutoSummary(targetCharId, currentTurns, currentTurns - lastTurn);
                }
            }

        } else {
            const err = await response.json();
            showApiErrorModal(JSON.stringify(err, null, 2));
        }
    } catch (e) {
        showApiErrorModal(e.message || '网络请求失败，请检查 API 地址或网络连接。');
    } finally {
        isGeneratingApiReply = false; 
        if (apiBtn) {
            apiBtn.innerHTML = originalBtnHtml;
            apiBtn.style.pointerEvents = 'auto';
        }
        if (titleEl) {
            titleEl.innerHTML = originalTitleHtml; // 修复：恢复完整的 HTML 结构，防止互动标识消失
        }
        // 隐藏一起听歌页面的正在回复气泡
        const typingBubble = document.getElementById('mpListenTogetherTyping');
        if (typingBubble) typingBubble.style.display = 'none';
    }
}

