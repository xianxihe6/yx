// ==========================================
// IndexedDB 异步存储引擎 (突破 5MB 限制，无限存储)
// ==========================================
const CHAT_DB_NAME = 'ChatAppDB_V1';
const CHAT_STORE_NAME = 'chat_data_store';
let chatDBInstance = null;
window.ChatMemoryCache = {}; 

// ==========================================
// 全局图片极速压缩引擎 (解决 Base64 爆内存卡顿问题)
// ==========================================
window.globalCompressImage = function(file, maxWidth, callback) {
    const reader = new FileReader();
    reader.onload = function(e) {
        const img = new Image();
        img.onload = function() {
            let width = img.width;
            let height = img.height;
            
            // 按比例缩放
            if (width > maxWidth || height > maxWidth) {
                if (width > height) {
                    height = Math.round((height * maxWidth) / width);
                    width = maxWidth;
                } else {
                    width = Math.round((width * maxWidth) / height);
                    height = maxWidth;
                }
            }
            
            const canvas = document.createElement('canvas');
            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, width, height);
            
            // 智能判断图片格式：如果是 PNG 或 GIF，保留透明底；否则压缩为 JPEG
            let compressedDataUrl;
            if (file.type === 'image/png' || file.type === 'image/gif') {
                compressedDataUrl = canvas.toDataURL('image/png');
            } else {
                compressedDataUrl = canvas.toDataURL('image/jpeg', 0.8);
            }
            
            callback(compressedDataUrl);
        };
        img.src = e.target.result;
    };
    reader.readAsDataURL(file);
};

// 封装的 ChatDB 对象，完美替代 localStorage
window.ChatDB = {
    getItem: function(key) {
        // 如果内存里有，直接返回
        if (window.ChatMemoryCache.hasOwnProperty(key)) {
            let val = window.ChatMemoryCache[key];
            if (val === "[object Object]") return null;
            return val;
        }
        // 如果内存里没有，且数据库还没就绪，尝试从 localStorage 兜底读取，防止初始化时数据被空值覆盖
        if (!chatDBInstance) {
            let val = localStorage.getItem(key);
            if (val === "[object Object]") return null;
            return val;
        }
        return null;
    },
    setItem: function(key, value) {
        // 防御性拦截：如果传入的是对象，自动转换为 JSON 字符串，防止变成 "[object Object]"
        if (typeof value === 'object' && value !== null) {
            try { value = JSON.stringify(value); } catch(e) {}
        }
        window.ChatMemoryCache[key] = value; // 同步更新内存，保证页面不卡顿
        if (chatDBInstance) {
            const tx = chatDBInstance.transaction(CHAT_STORE_NAME, 'readwrite');
            tx.objectStore(CHAT_STORE_NAME).put({ key: key, value: value });
        } else {
            try { localStorage.setItem(key, value); } catch(e){} // 兜底
        }
    },
    removeItem: function(key) {
        delete window.ChatMemoryCache[key];
        try { localStorage.removeItem(key); } catch(e){} // 强制清理 localStorage 中的残留，防止老数据变成“僵尸”复活
        if (chatDBInstance) {
            const tx = chatDBInstance.transaction(CHAT_STORE_NAME, 'readwrite');
            tx.objectStore(CHAT_STORE_NAME).delete(key);
        }
    }
};

// 申请持久化存储权限，防止浏览器自动清空数据
async function requestPersistentStorage() {
    if (navigator.storage && navigator.storage.persist) {
        const isPersisted = await navigator.storage.persisted();
        if (!isPersisted) {
            const granted = await navigator.storage.persist();
            if (granted) {
                console.log("✅ 存储已持久化，浏览器不会自动清空数据");
            } else {
                console.log("⚠️ 持久化存储申请被拒绝");
            }
        } else {
            console.log("✅ 存储已经是持久化状态");
        }
    }
}
requestPersistentStorage();

// 立即初始化并自动迁移老数据
(function initChatDB() {
    const request = indexedDB.open(CHAT_DB_NAME, 1);
    request.onupgradeneeded = (e) => {
        const db = e.target.result;
        if (!db.objectStoreNames.contains(CHAT_STORE_NAME)) {
            db.createObjectStore(CHAT_STORE_NAME, { keyPath: 'key' });
        }
    };
    request.onsuccess = (e) => {
        chatDBInstance = e.target.result;
        // 必须使用 readwrite 事务，因为迁移时需要写入
        const tx = chatDBInstance.transaction(CHAT_STORE_NAME, 'readwrite');
        const store = tx.objectStore(CHAT_STORE_NAME);
        const getAllReq = store.getAll();
        
        getAllReq.onsuccess = () => {
            const dbData = getAllReq.result;
            
            // 1. 自动迁移 localStorage 里的老数据 (无损过渡)
            let migrated = false;
            for (let i = 0; i < localStorage.length; i++) {
                const key = localStorage.key(i);
                const val = localStorage.getItem(key);
                // 如果 IndexedDB 里没有这个 key，才需要迁移
                if (!dbData.find(item => item.key === key)) {
                    store.put({ key: key, value: val });
                    // 同时加到 dbData 数组里，方便下一步统一加载到内存
                    dbData.push({ key: key, value: val });
                    migrated = true;
                }
            }
            if (migrated) console.log("老数据已成功迁移至 IndexedDB！");

            // 2. 加载所有数据到内存 (覆盖全局可能产生的临时空数据)
            dbData.forEach(item => {
                window.ChatMemoryCache[item.key] = item.value;
            });
            
            // 触发数据库就绪事件，通知 UI 恢复状态
            window.dispatchEvent(new Event('ChatDBReady'));
        };
    };
    request.onerror = (e) => console.error("IndexedDB 初始化失败", e);
})();
