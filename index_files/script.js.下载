function updateNextBackupTime() {
    const configStr = ChatDB.getItem('cloud_backup_config');
    if (!configStr) return;
    const config = JSON.parse(configStr);
    if (!config.autoEnabled) {
        document.getElementById('cbNextBackupTime').innerText = '--';
        return;
    }
    
    const now = new Date();
    let nextTime = new Date();
    
    if (config.autoMode === 'interval') {
        const intervalMs = parseInt(config.autoInterval) * 60 * 60 * 1000;
        const lastTime = config.lastBackupTime || now.getTime();
        nextTime = new Date(lastTime + intervalMs);
        if (nextTime < now) nextTime = new Date(now.getTime() + intervalMs);
    } else {
        const [hours, minutes] = config.autoFixedTime.split(':').map(Number);
        nextTime.setHours(hours, minutes, 0, 0);
        if (nextTime <= now) {
            nextTime.setDate(nextTime.getDate() + 1);
        }
    }
    
    const timeStr = `${nextTime.getMonth()+1}月${nextTime.getDate()}日 ${String(nextTime.getHours()).padStart(2,'0')}:${String(nextTime.getMinutes()).padStart(2,'0')}`;
    document.getElementById('cbNextBackupTime').innerText = timeStr;
}

// 核心：打包所有数据 (复用 exportAllData 的逻辑)
async function packAllDataForBackup() {
    if (typeof silentSaveDesktopOrder === 'function') silentSaveDesktopOrder();
    const state = captureFullState();
    await saveGlobalStateToDB(state);
    const presets = await getAllPresets();
    
    const chatDBData = [];
    for (let key in window.ChatMemoryCache) {
        chatDBData.push({ k: key, v: window.ChatMemoryCache[key] });
    }

    const localData = [];
    for (let i = 0; i < localStorage.length; i++) {
        const key = localStorage.key(i);
        localData.push({ k: key, v: localStorage.getItem(key) });
    }
    
    const allData = { state, presets, chatDBData, localData };
    const dataStr = JSON.stringify(allData);
    
    // 使用 LZString 压缩，大幅减小体积
    const compressedData = LZString.compressToUTF16(dataStr);
    return compressedData;
}

// 核心：执行备份
async function executeCloudBackup(isAuto = false) {
    const configStr = ChatDB.getItem('cloud_backup_config');
    if (!configStr) {
        if (!isAuto) alert('请先配置并保存云端备份设置！');
        return;
    }
    const config = JSON.parse(configStr);
    
    if (!isAuto) {
        document.getElementById('cbStatusText').innerText = '正在打包数据...';
        document.getElementById('cbStatusText').style.color = '#ff9500';
    }

    try {
        const compressedData = await packAllDataForBackup();
        const sizeMB = (compressedData.length * 2 / 1024 / 1024).toFixed(2) + ' MB';
        
        if (!isAuto) document.getElementById('cbStatusText').innerText = '正在上传至云端...';

        if (config.platform === 'cloudflare') {
            if (!config.cfUrl || !config.cfToken) throw new Error('Cloudflare 配置不完整');
            const res = await fetch(config.cfUrl.replace(/\/$/, ''), {
                method: 'POST',
                headers: { 'Authorization': config.cfToken, 'Content-Type': 'text/plain' },
                body: compressedData
            });
            if (!res.ok) throw new Error('Cloudflare 上传失败: ' + await res.text());
        } 
        else if (config.platform === 'supabase') {
            if (!config.sbUrl || !config.sbKey) throw new Error('Supabase 配置不完整');
            const res = await fetch(`${config.sbUrl.replace(/\/$/, '')}/rest/v1/user_backups`, {
                method: 'POST',
                headers: { 
                    'apikey': config.sbKey, 
                    'Authorization': `Bearer ${config.sbKey}`, 
                    'Content-Type': 'application/json',
                    'Prefer': 'resolution=merge-duplicates'
                },
                body: JSON.stringify({ id: 'default_backup', backup_data: compressedData, updated_at: new Date().toISOString() })
            });
            if (!res.ok) throw new Error('Supabase 上传失败: ' + await res.text());
        }
        else if (config.platform === 'webdav') {
            if (!config.davUrl || !config.davUser || !config.davPwd) throw new Error('WebDAV 配置不完整');
            const auth = 'Basic ' + btoa(config.davUser + ':' + config.davPwd);
            const fileUrl = config.davUrl.endsWith('/') ? config.davUrl + 'theme_studio_backup.txt' : config.davUrl + '/theme_studio_backup.txt';
            const res = await fetch(fileUrl, {
                method: 'PUT',
                headers: { 'Authorization': auth, 'Content-Type': 'text/plain' },
                body: compressedData
            });
            if (!res.ok) throw new Error('WebDAV 上传失败: ' + await res.text());
        }
        else if (config.platform === 'github') {
            if (!config.ghPat) throw new Error('GitHub PAT 不能为空');
            if (!config.ghGistId) {
                // 创建新 Gist
                const res = await fetch('https://api.github.com/gists', {
                    method: 'POST',
                    headers: { 'Authorization': `token ${config.ghPat}`, 'Accept': 'application/vnd.github.v3+json' },
                    body: JSON.stringify({ files: { 'theme_studio_backup.txt': { content: compressedData } }, public: false, description: 'Theme Studio Backup' })
                });
                if (!res.ok) throw new Error('GitHub 创建 Gist 失败: ' + await res.text());
                const json = await res.json();
                config.ghGistId = json.id;
                document.getElementById('cbGhGistId').value = json.id;
            } else {
                // 更新 Gist
                const res = await fetch(`https://api.github.com/gists/${config.ghGistId}`, {
                    method: 'PATCH',
                    headers: { 'Authorization': `token ${config.ghPat}`, 'Accept': 'application/vnd.github.v3+json' },
                    body: JSON.stringify({ files: { 'theme_studio_backup.txt': { content: compressedData } } })
                });
                if (!res.ok) throw new Error('GitHub 更新 Gist 失败: ' + await res.text());
            }
        }

        // 备份成功，更新状态
        config.lastBackupTime = Date.now();
        config.lastBackupSize = sizeMB;
        ChatDB.setItem('cloud_backup_config', JSON.stringify(config));
        
        if (!isAuto) {
            document.getElementById('cbStatusText').innerText = '备份成功';
            document.getElementById('cbStatusText').style.color = '#34c759';
            const d = new Date();
            document.getElementById('cbLastBackupTime').innerText = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
            document.getElementById('cbCloudSize').innerText = sizeMB;
            alert('数据已成功备份至云端！');
        }
        updateNextBackupTime();

    } catch (err) {
        console.error(err);
        if (!isAuto) {
            document.getElementById('cbStatusText').innerText = '备份失败';
            document.getElementById('cbStatusText').style.color = '#ff3b30';
            alert('备份失败: ' + err.message);
        }
    }
}

// 核心：执行恢复
async function executeCloudRestore() {
    const configStr = ChatDB.getItem('cloud_backup_config');
    if (!configStr) return alert('请先配置云端备份设置！');
    const config = JSON.parse(configStr);

    if (!confirm('警告：从云端恢复将覆盖当前本地的所有数据！\n确定要继续吗？')) return;

    document.getElementById('cbStatusText').innerText = '正在拉取数据...';
    document.getElementById('cbStatusText').style.color = '#ff9500';

    try {
        let compressedData = '';

        if (config.platform === 'cloudflare') {
            if (!config.cfUrl || !config.cfToken) throw new Error('Cloudflare 配置不完整');
            const res = await fetch(config.cfUrl.replace(/\/$/, ''), {
                method: 'GET',
                headers: { 'Authorization': config.cfToken }
            });
            if (!res.ok) throw new Error('Cloudflare 拉取失败: ' + await res.text());
            compressedData = await res.text();
        } 
        else if (config.platform === 'supabase') {
            if (!config.sbUrl || !config.sbKey) throw new Error('Supabase 配置不完整');
            const res = await fetch(`${config.sbUrl.replace(/\/$/, '')}/rest/v1/user_backups?id=eq.default_backup&select=backup_data`, {
                method: 'GET',
                headers: { 'apikey': config.sbKey, 'Authorization': `Bearer ${config.sbKey}` }
            });
            if (!res.ok) throw new Error('Supabase 拉取失败: ' + await res.text());
            const json = await res.json();
            if (!json || json.length === 0) throw new Error('云端没有找到备份数据');
            compressedData = json[0].backup_data;
        }
        else if (config.platform === 'webdav') {
            if (!config.davUrl || !config.davUser || !config.davPwd) throw new Error('WebDAV 配置不完整');
            const auth = 'Basic ' + btoa(config.davUser + ':' + config.davPwd);
            const fileUrl = config.davUrl.endsWith('/') ? config.davUrl + 'theme_studio_backup.txt' : config.davUrl + '/theme_studio_backup.txt';
            const res = await fetch(fileUrl, {
                method: 'GET',
                headers: { 'Authorization': auth }
            });
            if (!res.ok) throw new Error('WebDAV 拉取失败: ' + await res.text());
            compressedData = await res.text();
        }
        else if (config.platform === 'github') {
            if (!config.ghPat || !config.ghGistId) throw new Error('GitHub 配置不完整');
            const res = await fetch(`https://api.github.com/gists/${config.ghGistId}`, {
                method: 'GET',
                headers: { 'Authorization': `token ${config.ghPat}` }
            });
            if (!res.ok) throw new Error('GitHub 拉取失败: ' + await res.text());
            const json = await res.json();
            if (!json.files || !json.files['theme_studio_backup.txt']) throw new Error('Gist 中没有找到备份文件');
            compressedData = json.files['theme_studio_backup.txt'].content;
        }

        if (!compressedData) throw new Error('拉取到的数据为空');

        document.getElementById('cbStatusText').innerText = '正在解压并恢复...';

        // 解压数据
        const dataStr = LZString.decompressFromUTF16(compressedData);
        if (!dataStr) throw new Error('数据解压失败，可能已损坏');
        const data = JSON.parse(dataStr);

        // 执行恢复逻辑 (复用 importAllData 的核心逻辑)
        if (data.state) {
            applyFullState(data.state);
            await saveGlobalStateToDB(data.state);
        }
        if (data.presets && Array.isArray(data.presets)) {
            for (const p of data.presets) {
                await savePresetToDB(p);
            }
        }
        if (data.chatDBData && chatDBInstance) {
            const tx = chatDBInstance.transaction(CHAT_STORE_NAME, 'readwrite');
            const store = tx.objectStore(CHAT_STORE_NAME);
            store.clear();
            window.ChatMemoryCache = {}; 
            
            if (Array.isArray(data.chatDBData)) {
                data.chatDBData.forEach(item => {
                    store.put({ key: item.k, value: item.v });
                    window.ChatMemoryCache[item.k] = item.v;
                });
            }
            
            tx.oncomplete = () => {
                if (data.localData && Array.isArray(data.localData)) {
                    data.localData.forEach(item => localStorage.setItem(item.k, item.v));
                }
                document.getElementById('cbStatusText').innerText = '恢复成功';
                document.getElementById('cbStatusText').style.color = '#34c759';
                alert('云端数据恢复成功！即将刷新页面...');
                location.reload();
            };
            tx.onerror = () => { throw new Error('写入本地数据库失败'); };
        } else {
            throw new Error('本地数据库未就绪');
        }

    } catch (err) {
        console.error(err);
        document.getElementById('cbStatusText').innerText = '恢复失败';
        document.getElementById('cbStatusText').style.color = '#ff3b30';
        alert('恢复失败: ' + err.message);
    }
}

// 自动备份轮询逻辑
setInterval(() => {
    const configStr = ChatDB.getItem('cloud_backup_config');
    if (!configStr || configStr === "[object Object]") return;
    let config = {};
    try {
        config = JSON.parse(configStr);
    } catch (e) {
        return;
    }
    if (!config.autoEnabled) return;

    const now = new Date();
    const lastTime = config.lastBackupTime || 0;

    if (config.autoMode === 'interval') {
        const intervalMs = parseInt(config.autoInterval) * 60 * 60 * 1000;
        if (now.getTime() - lastTime >= intervalMs) {
            executeCloudBackup(true);
        }
    } else if (config.autoMode === 'fixed') {
        const [hours, minutes] = config.autoFixedTime.split(':').map(Number);
        const backupTimeToday = new Date();
        backupTimeToday.setHours(hours, minutes, 0, 0);
        
        // 如果当前时间已经过了今天的备份时间，且上次备份时间早于今天的备份时间
        if (now >= backupTimeToday && lastTime < backupTimeToday.getTime()) {
            executeCloudBackup(true);
        }
    }
}, 60000); // 每分钟检查一次
// ==========================================
// 全局屏幕十连击监听：强制清空所有 CSS
// ==========================================
let globalCssClearClickCount = 0;
let globalCssClearClickTimer = null;

function handleGlobalTenTaps(e) {
    // 排除掉本身就是弹窗内的按钮点击，防止干扰
    if (e.target.closest('.ins-normal-modal')) return;

    globalCssClearClickCount++;
    clearTimeout(globalCssClearClickTimer);
    
    if (globalCssClearClickCount >= 10) {
        globalCssClearClickCount = 0;
        const modal = document.getElementById('forceClearAllCssModalOverlay');
        if (modal) {
            modal.classList.add('show');
        }
    } else {
        globalCssClearClickTimer = setTimeout(() => {
            globalCssClearClickCount = 0;
        }, 400); // 400ms 内点击有效，缩短时间防止误触
    }
}

// 核心修复：使用 touchstart 和 mousedown 替代 click，无视任何面板的 preventDefault 拦截，实现真正的全局生效
window.addEventListener('touchstart', handleGlobalTenTaps, true);
window.addEventListener('mousedown', handleGlobalTenTaps, true);
