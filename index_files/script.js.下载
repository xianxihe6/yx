async function checkUpdate(e) {
    if(e) e.stopPropagation();
    
    // 显示加载提示
    if (typeof showToast === 'function') {
        showToast('正在检查更新...', 'loading');
    }
    
    try {
        let hasUpdate = false;

        // 尝试通过 Service Worker 检查更新
        if ('serviceWorker' in navigator) {
            const registration = await navigator.serviceWorker.ready;
            // 强制 Service Worker 去服务器检查是否有新版本
            await registration.update();
            
            // 检查是否有新的 worker 正在等待激活
            if (registration.waiting) {
                hasUpdate = true;
                if (typeof hideToast === 'function') hideToast();
                if (confirm('发现新版本！是否立即刷新以应用更新？')) {
                    // 通知 Service Worker 跳过等待，立即接管
                    registration.waiting.postMessage({ type: 'SKIP_WAITING' });
                    // 稍微延迟一下等待 SW 激活后刷新页面
                    setTimeout(() => {
                        window.location.reload();
                    }, 500);
                }
                return;
            }
        }
        
        // 如果没有检测到 Service Worker 更新，模拟一个短暂的网络请求延迟，让用户感知到“正在检查”
        if (!hasUpdate) {
            await new Promise(resolve => setTimeout(resolve, 1200));
            if (typeof hideToast === 'function') hideToast();
            alert("当前已是最新版本！");
        }
        
    } catch (err) {
        if (typeof hideToast === 'function') hideToast();
        alert("检查更新失败，请检查网络连接。");
        console.error("Update check failed:", err);
    }
}

