async function testMcpConnection() {
    const url = document.getElementById('mcpAddressInput').value.trim();
    const dot = document.getElementById('mcpStatusDot');
    const text = document.getElementById('mcpStatusText');
    
    if (!url) {
        alert('请先输入 MCP 服务器 URL！');
        return;
    }

    text.innerText = '连接中...';
    dot.style.background = '#ffcc00'; // 黄色
    
    try {
        // 尝试发送一个 GET 请求测试连通性
        const response = await fetch(url, {
            method: 'GET',
            // 设置 5 秒超时时间，防止一直卡住
            signal: AbortSignal.timeout(5000) 
        });
        
        // 只要服务器有响应（即使是 404/405，也说明服务器存在且网络可达）
        if (response.ok || response.status === 404 || response.status === 405) {
            text.innerText = '已连接';
            dot.style.background = '#34c759'; // 绿色
        } else {
            text.innerText = '连接异常';
            dot.style.background = '#ff3b30'; // 红色
        }
    } catch (error) {
        text.innerText = '连接失败';
        dot.style.background = '#ff3b30'; // 红色
        console.error('MCP 连接测试失败:', error);
    }
}
