// 导入桌面美化数据
// 修改后
function importThemeData(e) {
    if(e) e.stopPropagation();
    uploadJson(async (data) => {
        if (data && typeof data === 'object' && !data.apiConfig) {
            const state = data.state || data; // 兼容老版本
            applyFullState(state);
            await saveGlobalStateToDB(state);
            
            if (data.importedWidgets) {
                const widgetStr = typeof data.importedWidgets === 'string' ? data.importedWidgets : JSON.stringify(data.importedWidgets);
                localStorage.setItem('imported_widgets', widgetStr);
            }

            // 核心修复：确保桌面布局数据 100% 写入硬盘后再刷新页面
            if (data.desktopOrder && typeof chatDBInstance !== 'undefined' && chatDBInstance) {
                const orderStr = typeof data.desktopOrder === 'string' ? data.desktopOrder : JSON.stringify(data.desktopOrder);
                const tx = chatDBInstance.transaction('chat_data_store', 'readwrite');
                const store = tx.objectStore('chat_data_store');
                store.put({ key: 'desktop_order', value: orderStr });
                window.ChatMemoryCache['desktop_order'] = orderStr;
                
                tx.oncomplete = () => {
                    alert('桌面美化数据导入成功！即将刷新页面...');
                    location.reload();
                };
                tx.onerror = () => {
                    alert('数据写入硬盘失败，请重试！');
                };
            } else {
                // 兜底逻辑
                if (data.desktopOrder) {
                    const orderStr = typeof data.desktopOrder === 'string' ? data.desktopOrder : JSON.stringify(data.desktopOrder);
                    ChatDB.setItem('desktop_order', orderStr);
                }
                setTimeout(() => {
                    alert('桌面美化数据导入成功！即将刷新页面...');
                    location.reload();
                }, 800);
            }
        } else {
            alert('无效的数据格式，请确保导入的是桌面美化数据');
        }
    });
    const themePopup = document.getElementById('themePopup');
    if(themePopup) themePopup.classList.remove('show');
}


