async function confirmExport() {
    let fileName = document.getElementById('exportNameInput').value.trim();
    if (!fileName) fileName = 'backup_data';
    if (!fileName.endsWith('.json')) fileName += '.json';

    if (currentExportType === 'theme') {
        silentSaveDesktopOrder(); // 强制保存最新桌面布局
        const state = captureFullState();
        await saveGlobalStateToDB(state);
        
        let desktopOrder = [];
        try {
            const orderStr = ChatDB.getItem('desktop_order') || localStorage.getItem('desktop_order');
            if (orderStr) desktopOrder = JSON.parse(orderStr);
        } catch(e){}
        
        let importedWidgets = [];
        try {
            const widgetStr = localStorage.getItem('imported_widgets');
            if (widgetStr) importedWidgets = JSON.parse(widgetStr);
        } catch(e){}

        const dataStr = JSON.stringify({ state, desktopOrder, importedWidgets }, null, 2);
        downloadJson(dataStr, fileName);
    } else if (currentExportType === 'all') {

        silentSaveDesktopOrder(); // 强制保存最新桌面布局
        const state = captureFullState();
        await saveGlobalStateToDB(state);
        const presets = await getAllPresets();
        
        // 收集所有 ChatDB 数据 (使用数组防止枚举溢出)
        const chatDBData = [];
        for (let key in window.ChatMemoryCache) {
            chatDBData.push({ k: key, v: window.ChatMemoryCache[key] });
        }

        // 收集所有 localStorage 数据 (双重保险，确保没有任何遗漏)
        const localData = [];
        for (let i = 0; i < localStorage.length; i++) {
            const key = localStorage.key(i);
            localData.push({ k: key, v: localStorage.getItem(key) });
        }
        
        const allData = { state, presets, chatDBData, localData };
        const dataStr = JSON.stringify(allData, null, 2);
        downloadJson(dataStr, fileName);
    }
    hideExportModal();
}

