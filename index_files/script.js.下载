// 导入世界书文件
function importWbEntry() {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.txt,.json,.doc,.docx';
    input.onchange = (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        const fileName = file.name.replace(/\.[^/.]+$/, "");
        wbData = JSON.parse(ChatDB.getItem('worldbook_data')) || { groups: ['默认分组', '未分类'], entries: [] };

        // 专门处理 docx 格式
        if (file.name.endsWith('.docx')) {
            if (typeof mammoth === 'undefined') {
                alert('缺少 docx 解析库，请检查网络连接！');
                return;
            }
            const reader = new FileReader();
            reader.onload = function(event) {
                const arrayBuffer = event.target.result;
                mammoth.extractRawText({arrayBuffer: arrayBuffer})
                    .then(function(result) {
                        const text = result.value;
                        importAsText(fileName, text);
                        ChatDB.setItem('worldbook_data', JSON.stringify(wbData));
                        renderWbList();
                    })
                    .catch(function(err) {
                        alert('docx 解析失败: ' + err.message);
                    });
            };
            reader.readAsArrayBuffer(file);
        } 
        // 拦截古老的 doc 格式
        else if (file.name.endsWith('.doc')) {
            alert('抱歉宝宝，.doc 是非常古老的二进制格式，浏览器无法直接完美解析，建议另存为 .docx 或 .txt 后导入哦~');
        } 
        // 处理 txt 和 json 格式
        else {
            const reader = new FileReader();
            reader.onload = (event) => {
                const content = event.target.result;
                
                if (file.name.endsWith('.json')) {
                    try {
                        const data = JSON.parse(content);
                        let entriesToImport = [];

                        // 1. 兼容酒馆 (SillyTavern) 的 Lorebook 格式
                        if (data.entries) {
                            const entriesArray = Array.isArray(data.entries) ? data.entries : Object.values(data.entries);
                            entriesArray.forEach(item => {
                                let kw = '';
                                if (Array.isArray(item.key)) kw = item.key.join(', ');
                                else if (Array.isArray(item.keys)) kw = item.keys.join(', ');
                                else if (typeof item.key === 'string') kw = item.key;
                                else if (typeof item.keys === 'string') kw = item.keys;

                                entriesToImport.push({
                                    id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
                                    active: item.enabled !== false && item.disable !== true,
                                    title: item.comment || item.name || '未命名',
                                    group: '未分类',
                                    position: 'before',
                                    constant: !!item.constant,
                                    exact: true,
                                    keywords: kw,
                                    content: item.content || ''
                                });
                            });
                        } 
                        // 2. 兼容普通的 JSON 数组格式
                        else if (Array.isArray(data)) {
                            data.forEach(item => {
                                entriesToImport.push({
                                    id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
                                    active: item.active !== false,
                                    title: item.title || '未命名',
                                    group: '未分类',
                                    position: item.position || 'before',
                                    constant: !!item.constant,
                                    exact: item.exact !== false,
                                    keywords: item.keywords || '',
                                    content: item.content || ''
                                });
                            });
                        }
                        // 3. 兼容单个 JSON 对象
                        else {
                            entriesToImport.push({
                                id: Date.now().toString(),
                                active: data.active !== false,
                                title: data.title || fileName,
                                group: '未分类',
                                position: data.position || 'before',
                                constant: !!data.constant,
                                exact: data.exact !== false,
                                keywords: data.keywords || '',
                                content: data.content || ''
                            });
                        }

                        if (entriesToImport.length > 0) {
                            wbData.entries.push(...entriesToImport);
                            alert(`成功导入 ${entriesToImport.length} 个词条！`);
                        } else {
                            alert('未在 JSON 中找到有效的词条数据。');
                        }

                    } catch (err) {
                        console.error(err);
                        alert('JSON 解析失败，将作为普通文本导入');
                        importAsText(fileName, content);
                    }
                } else {
                    importAsText(fileName, content);
                }
                
                // 强制同步写入数据库
                ChatDB.setItem('worldbook_data', JSON.stringify(wbData));
                renderWbList();
            };
            reader.readAsText(file);
        }
    };
    input.click();
}

function importAsText(title, content) {
    wbData.entries.push({
        id: Date.now().toString(),
        active: true,
        title: title,
        group: '未分类',
        position: 'before',
        constant: false,
        exact: true,
        keywords: title, // 默认关键词为文件名
        content: content.trim()
    });
    alert(`成功导入文本词条：${title}`);
}

// ==========================================
// 世界书数据转移 (智能模糊解析)
// ==========================================
let tempTransferEntries = []; // 临时存储扫描到的词条

function triggerWbDataTransfer() {
    document.getElementById('wbDataTransferInput').value = '';
    document.getElementById('wbDataTransferInput').click();
}

async function handleWbDataTransferFile(e) {
    const file = e.target.files[0];
    if (!file) return;
    
    const fileName = file.name.toLowerCase();
    const reader = new FileReader();
    
    // 读取 ArrayBuffer 以支持二进制解压
    reader.onload = async (event) => {
        try {
            const buffer = event.target.result;
            let rawText = "";

            // 1. 智能解压：如果是 .gz, .bin, .ee 尝试使用浏览器原生 GZIP 解压
            if (fileName.endsWith('.gz') || fileName.endsWith('.bin') || fileName.endsWith('.ee')) {
                try {
                    const ds = new DecompressionStream('gzip');
                    const writer = ds.writable.getWriter();
                    writer.write(buffer);
                    writer.close();
                    rawText = await new Response(ds.readable).text();
                } catch (err) {
                    console.warn("GZIP 解压失败，尝试作为纯文本读取", err);
                    rawText = new TextDecoder().decode(buffer);
                }
            } else {
                rawText = new TextDecoder().decode(buffer);
            }

            let data;
            try {
                data = JSON.parse(rawText);
            } catch (err) {
                alert('解析失败：文件内容不是有效的 JSON 格式！');
                return;
            }

            tempTransferEntries = [];
            let allObjects = [];
            let visited = new Set();

            // 2. 彻底解包：把所有被转成字符串的 JSON 全部还原成对象
            function deepParse(obj) {
                if (!obj || typeof obj !== 'object') return obj;
                if (visited.has(obj)) return obj;
                visited.add(obj);

                if (Array.isArray(obj)) {
                    for (let i = 0; i < obj.length; i++) {
                        if (typeof obj[i] === 'string' && (obj[i].trim().startsWith('{') || obj[i].trim().startsWith('['))) {
                            try { obj[i] = deepParse(JSON.parse(obj[i])); } catch(e) {}
                        } else if (typeof obj[i] === 'object') {
                            obj[i] = deepParse(obj[i]);
                        }
                    }
                } else {
                    for (let key in obj) {
                        if (Object.prototype.hasOwnProperty.call(obj, key)) {
                            let val = obj[key];
                            if (typeof val === 'string' && (val.trim().startsWith('{') || val.trim().startsWith('['))) {
                                try { obj[key] = deepParse(JSON.parse(val)); } catch(e) {}
                            } else if (typeof val === 'object') {
                                obj[key] = deepParse(val);
                            }
                        }
                    }
                }
                return obj;
            }

            data = deepParse(data);
            visited.clear();

            // 【新增精准提取逻辑】：通过键名智能匹配，兼容所有衍生项目
            let isProjectBackup = !!(data.state || data.chatDBData || data.localData || data.presets || data.ios_theme_wb_entries || (data.data && data.data.ios_theme_wb_entries) || data.signature);
            let exactEntries = null;
            
            // 涵盖各个衍生版本可能使用的世界书键名
            const wbKeywords = ['worldbook', 'wb_entries', 'wbdata', 'lorebook', 'character_book', 'ios_theme_wb', 'world_book', 'lore_book', 'worldinfo', 'world_info'];

            // 辅助函数：从已知是世界书的值中提取数组
            function extractFromKnownKey(val) {
                if (!val) return null;
                try {
                    const parsed = typeof val === 'string' ? JSON.parse(val) : val;
                    if (!parsed) return null;
                    if (Array.isArray(parsed.entries)) return parsed.entries;
                    if (Array.isArray(parsed.data)) return parsed.data;
                    if (Array.isArray(parsed)) return parsed;
                    if (typeof parsed === 'object') {
                        const vals = Object.values(parsed);
                        if (vals.length > 0 && (vals[0].content || vals[0].desc || vals[0].description || vals[0].text)) {
                            return vals;
                        }
                    }
                } catch(e) {}
                return null;
            }

            // 1. 检查 chatDBData 或 localData (数组或对象格式)
            if (!exactEntries && data.chatDBData) {
                const arr = Array.isArray(data.chatDBData) ? data.chatDBData : Object.keys(data.chatDBData).map(k => ({k, v: data.chatDBData[k]}));
                const item = arr.find(i => i.k && wbKeywords.some(wk => i.k.toLowerCase().includes(wk)));
                if (item) exactEntries = extractFromKnownKey(item.v);
            }

            if (!exactEntries && data.localData) {
                const arr = Array.isArray(data.localData) ? data.localData : Object.keys(data.localData).map(k => ({k, v: data.localData[k]}));
                const item = arr.find(i => i.k && wbKeywords.some(wk => i.k.toLowerCase().includes(wk)));
                if (item) exactEntries = extractFromKnownKey(item.v);
            }

            // 2. 检查根目录下的世界书字段
            if (!exactEntries) {
                const rootKey = Object.keys(data).find(k => wbKeywords.some(wk => k.toLowerCase().includes(wk)));
                if (rootKey) {
                    isProjectBackup = true;
                    exactEntries = extractFromKnownKey(data[rootKey]);
                }
            }

            // 3. 兼容 data.data 内部的世界书 (某些特殊版本的嵌套)
            if (!exactEntries && data.data && typeof data.data === 'object') {
                const dataKey = Object.keys(data.data).find(k => wbKeywords.some(wk => k.toLowerCase().includes(wk)));
                if (dataKey) {
                    isProjectBackup = true;
                    exactEntries = extractFromKnownKey(data.data[dataKey]);
                }
            }

            // 4. 兼容直接导出的数组
            if (!exactEntries && Array.isArray(data)) {
                exactEntries = extractFromKnownKey(data);
            }

            // 移除本项目备份强制阻断逻辑，允许所有未精确匹配的文件进入模糊扫描，
            // 以兼容其他衍生项目或修改过键名的备份文件。
            // if (isProjectBackup && !exactEntries) {
            //     exactEntries = [];
            // }

            if (exactEntries && exactEntries.length > 0) {
                // 如果精准找到了世界书数据，直接使用，跳过模糊扫描
                exactEntries.forEach(item => {
                    // 兼容 SillyTavern 的 key/keys
                    let kw = '';
                    let rawKw = item.keywords || item.keys || item.keyword || item.key;
                    if (!rawKw) rawKw = item.name || item.title || item.comment || '';
                    if (Array.isArray(rawKw)) kw = rawKw.join(', ');
                    else if (typeof rawKw === 'string') kw = rawKw;

                    tempTransferEntries.push({
                        id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
                        active: item.active !== false && item.enabled !== false && item.disable !== true,
                        title: item.title || item.name || item.comment || '未命名',
                        group: item.group || item.type || '未分类', // 兼容 ios_theme_wb_entries 的 type 字段
                        position: item.position || 'before',
                        constant: !!item.constant,
                        exact: item.exact !== false,
                        keywords: kw,
                        content: item.content || item.description || item.text || item.desc || '' // 兼容 ios_theme_wb_entries 的 desc 字段
                    });
                });
            } else {
                // 3. 暴力铺平：收集所有非数组的对象 (仅针对非本项目备份的未知 JSON)
                function collectAllObjects(obj) {
                    if (!obj || typeof obj !== 'object') return;
                    if (visited.has(obj)) return;
                    visited.add(obj);

                    if (!Array.isArray(obj)) {
                        allObjects.push(obj);
                    }

                    for (let key in obj) {
                        if (Object.prototype.hasOwnProperty.call(obj, key)) {
                            if (typeof obj[key] === 'object') {
                                collectAllObjects(obj[key]);
                            }
                        }
                    }
                }

                collectAllObjects(data);

                // 4. 鸭子类型严格过滤：判断哪些对象是真正的世界书词条
                let uniqueIds = new Set();

                allObjects.forEach((item, index) => {
                    if (!item || typeof item !== 'object') return;

                    const keys = Object.keys(item).map(k => k.toLowerCase());

                    // 【特征 1】：必须包含内容字段
                    const hasContentField = keys.some(k => ['content', 'description', 'text', 'detail', 'entry'].includes(k));
                    
                    // 【特征 2】：必须包含明确的触发词字段，或者包含世界书特有字段
                    const hasKeywordField = keys.some(k => ['key', 'keys', 'keyword', 'keywords'].includes(k));
                    const hasWbSpecificField = keys.some(k => ['constant', 'position', 'insertion_order', 'group', 'selective', 'secondary_keys', 'extensions'].includes(k));

                    // 【特征 3】：绝对不能包含聊天、角色卡、设置等干扰字段 (严格黑名单)
                    const isNotChat = !keys.some(k => ['role', 'mes', 'message', 'is_user', 'send_date', 'chat_history'].includes(k));
                    const isNotChar = !keys.some(k => ['personality', 'first_mes', 'mes_example', 'scenario', 'creator_notes', 'system_prompt'].includes(k));
                    const isNotSetting = !keys.some(k => ['api_key', 'temperature', 'max_tokens', 'url', 'endpoint'].includes(k));
                    
                    // 【特征 4】：APP 记录与用户面具黑名单 (剔除容易误杀的 date, time, image, author)
                    const isNotAppRecord = !keys.some(k => [
                        'phone', 'call', 'moment', 'post', 'browser', 'history', 
                        'likes', 'comments', 'price', 'shop', 'song', 'artist',
                        'views', 'replies', 'persona', 'user_persona', 'user_name', 'user_avatar'
                    ].includes(k));

                    // 判定逻辑：必须有内容，且不能是聊天/角色/设置
                    let isValidWb = false;
                    if (hasContentField && isNotChat && isNotChar && isNotSetting) {
                        // 1. 同时拥有触发词和世界书专属字段 (100% 确定是世界书，无视 APP 黑名单)
                        if (hasKeywordField && hasWbSpecificField) {
                            isValidWb = true;
                        } 
                        // 2. 拥有触发词或专属字段，且不在 APP 黑名单中 (大概率是世界书)
                        else if ((hasKeywordField || hasWbSpecificField) && isNotAppRecord) {
                            isValidWb = true;
                        }
                    }

                    if (isValidWb) {
                        
                        // 找标题
                        let title = item.title || item.name || item.comment || item.id || item.uid || `未命名词条 ${index + 1}`;
                        
                        // 找内容
                        let contentStr = item.content || item.description || item.text || item.detail || item.entry || '';
                        
                        // 找触发词
                        let kw = '';
                        let rawKw = item.keywords || item.keys || item.keyword || item.key;
                        if (!rawKw) rawKw = item.name || item.title || item.comment || ''; // 兜底
                        
                        if (Array.isArray(rawKw)) {
                            kw = rawKw.join(', ');
                        } else if (typeof rawKw === 'string') {
                            kw = rawKw;
                        }

                        if (typeof contentStr === 'string' && contentStr.trim() !== '') {
                            // 去重：用标题+内容前20个字符作为唯一标识
                            let hash = title + contentStr.substring(0, 20);
                            if (!uniqueIds.has(hash)) {
                                uniqueIds.add(hash);
                                tempTransferEntries.push({
                                    id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
                                    active: item.active !== false && item.enabled !== false && item.disable !== true,
                                    title: title,
                                    group: '未分类',
                                    position: item.position || 'before',
                                    constant: !!item.constant,
                                    exact: item.exact !== false,
                                    keywords: kw,
                                    content: contentStr
                                });
                            }
                        }
                    }
                });
            }

            if (tempTransferEntries.length === 0) {
                alert('未能在文件中扫描到有效的世界书数据！\n(已自动过滤聊天记录、角色卡等无关数据)');
                return;
            }

            // 5. 渲染弹窗列表
            const listEl = document.getElementById('wbDataTransferList');
            listEl.innerHTML = '';
            document.getElementById('wbDataTransferCount').innerText = `共扫描到 ${tempTransferEntries.length} 个词条`;

            tempTransferEntries.forEach((entry, idx) => {
                const itemDiv = document.createElement('div');
                itemDiv.style.cssText = 'display: flex; align-items: center; gap: 10px; padding: 10px; background: #f9f9f9; border-radius: 8px; border: 1px solid #eee; cursor: pointer;';
                itemDiv.innerHTML = `
                    <input type="checkbox" class="wb-transfer-checkbox" value="${idx}" checked style="width: 16px; height: 16px; accent-color: #111; flex-shrink: 0; pointer-events: none;">
                    <div style="display: flex; flex-direction: column; overflow: hidden;">
                        <span style="font-size: 14px; font-weight: bold; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${entry.title}</span>
                        <span style="font-size: 11px; color: #888; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">触发词: ${entry.keywords}</span>
                    </div>
                `;
